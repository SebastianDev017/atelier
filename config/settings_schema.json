[
  {
    "name": "theme_info",
    "theme_name": "Atelier V2",
    "theme_version": "2.0.0",
    "theme_author": "Ruiz Digital",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://help.shopify.com/manual/online-store/themes"
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "header",
        "content": "Fonts"
      },
      {
        "type": "font_picker",
        "id": "heading_font",
        "default": "eb_garamond_n4",
        "label": "Heading font",
        "info": "Display serif — used for headings and product titles. EB Garamond ships by default."
      },
      {
        "type": "font_picker",
        "id": "body_font",
        "default": "lora_n4",
        "label": "Body font",
        "info": "Reading serif — used for body copy and navigation. Eyebrows, prices, and buttons use a built-in monospace face."
      },
      {
        "type": "header",
        "content": "Scale"
      },
      {
        "type": "range",
        "id": "heading_scale",
        "min": 85,
        "max": 140,
        "step": 5,
        "unit": "%",
        "label": "Heading size",
        "default": 100
      },
      {
        "type": "range",
        "id": "body_scale",
        "min": 90,
        "max": 120,
        "step": 5,
        "unit": "%",
        "label": "Body size",
        "default": 100
      },
      {
        "type": "header",
        "content": "Letter casing"
      },
      {
        "type": "checkbox",
        "id": "uppercase_headings",
        "label": "Uppercase headings",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "uppercase_nav",
        "label": "Uppercase navigation",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "uppercase_buttons",
        "label": "Uppercase buttons & labels",
        "default": true
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "background_color",
        "default": "#FBF8F2",
        "label": "Background"
      },
      {
        "type": "color",
        "id": "text_color",
        "default": "#2E3030",
        "label": "Text"
      },
      {
        "type": "color",
        "id": "accent_color",
        "default": "#766356",
        "label": "Accent",
        "info": "Used for hover states and emphasis."
      },
      {
        "type": "color",
        "id": "border_color",
        "default": "#E3DCCE",
        "label": "Borders & dividers",
        "info": "Hairline rules, card edges, and input borders."
      },
      {
        "type": "color",
        "id": "button_color",
        "default": "#2E3030",
        "label": "Button background"
      },
      {
        "type": "color",
        "id": "button_text_color",
        "default": "#FBF8F2",
        "label": "Button label"
      },
      {
        "type": "color",
        "id": "color_text_heading",
        "label": "Heading color",
        "default": "#2C1810",
        "info": "Overrides the color scheme heading color"
      },
      {
        "type": "color",
        "id": "color_text_body",
        "label": "Body text color",
        "default": "#5C3D2E"
      },
      {
        "type": "color",
        "id": "color_text_muted",
        "label": "Muted / label color",
        "default": "#A0826D"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1100,
        "max": 1800,
        "step": 20,
        "unit": "px",
        "label": "Page width",
        "default": 1540
      },
      {
        "type": "range",
        "id": "page_margin",
        "min": 16,
        "max": 80,
        "step": 2,
        "unit": "px",
        "label": "Page side margin",
        "default": 40
      },
      {
        "type": "range",
        "id": "section_spacing",
        "min": 40,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Default section spacing",
        "default": 140
      },
      {
        "type": "range",
        "id": "header_height",
        "min": 48,
        "max": 120,
        "step": 2,
        "unit": "px",
        "label": "Header height",
        "info": "Used on inner elements; the navigation is a full-height left sidebar.",
        "default": 64
      },
      {
        "type": "range",
        "id": "sidebar_width",
        "min": 180,
        "max": 300,
        "step": 4,
        "unit": "px",
        "label": "Sidebar width",
        "info": "Width of the left navigation column on desktop.",
        "default": 220
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 8,
        "step": 1,
        "unit": "px",
        "label": "Corner radius",
        "info": "Atelier is designed for square (0) corners.",
        "default": 0
      }
    ]
  },
  {
    "name": "Product cards",
    "settings": [
      {
        "type": "checkbox",
        "id": "card_show_secondary_image",
        "label": "Show second image on hover",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "card_show_vendor",
        "label": "Show vendor",
        "default": false
      },
      {
        "type": "checkbox",
        "id": "card_quick_add",
        "label": "Show quick add button",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "card_show_rating",
        "label": "Show product rating",
        "info": "Requires a product rating app that uses the standard rating metafield.",
        "default": false
      },
      {
        "type": "range",
        "id": "low_stock_threshold",
        "min": 0,
        "max": 25,
        "step": 1,
        "label": "Low stock badge threshold",
        "info": "Show a low-stock badge at or below this quantity. Set 0 to hide.",
        "default": 6
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ],
        "default": "drawer"
      },
      {
        "type": "checkbox",
        "id": "cart_show_free_shipping_bar",
        "label": "Show free shipping progress bar",
        "default": true
      },
      {
        "type": "number",
        "id": "cart_free_shipping_threshold",
        "label": "Free shipping threshold",
        "info": "In your store currency, e.g. 150. Leave blank to hide the bar.",
        "default": 150
      },
      {
        "type": "checkbox",
        "id": "cart_show_note",
        "label": "Enable order notes",
        "default": true
      }
    ]
  },
  {
    "name": "Animations",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_scroll_animations",
        "label": "Reveal sections on scroll",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "enable_view_transitions",
        "label": "Animate page transitions",
        "info": "Subtle cross-fade between pages in supported browsers.",
        "default": true
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "header",
        "content": "Accounts"
      },
      { "type": "text", "id": "social_instagram_link", "label": "Instagram", "info": "https://instagram.com/shop" },
      { "type": "text", "id": "social_facebook_link", "label": "Facebook" },
      { "type": "text", "id": "social_pinterest_link", "label": "Pinterest" },
      { "type": "text", "id": "social_tiktok_link", "label": "TikTok" },
      { "type": "text", "id": "social_youtube_link", "label": "YouTube" }
    ]
  },
  {
    "name": "Branding",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 80,
        "max": 320,
        "step": 4,
        "unit": "px",
        "label": "Logo width",
        "default": 150
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "Will be scaled down to 32 x 32px."
      }
    ]
  }
]
