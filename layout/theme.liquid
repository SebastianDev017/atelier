<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <script>
      document.documentElement.classList.remove('no-js');
      document.documentElement.classList.add('js');
    </script>

    {% render 'css-variables' %}
    {%- comment -%} <body> carries data-* flags (smooth-scroll, custom-cursor, hover-swap) consumed by theme.js (STEP 4). {%- endcomment -%}

    {%- if settings.body_font.system? == false -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endif -%}

    {% if settings.favicon %}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {% endif %}

    {{ 'base.css' | asset_url | stylesheet_tag }}

    {% render 'meta-tags' %}

    {%- if settings.enable_view_transitions -%}
      <style>
        @view-transition { navigation: auto; }
        ::view-transition-old(root) { animation: 200ms ease both atelier-vt-out; }
        ::view-transition-new(root) { animation: 250ms ease both atelier-vt-in; }
        @keyframes atelier-vt-out { to { opacity: 0; } }
        @keyframes atelier-vt-in { from { opacity: 0; } }
        @media (prefers-reduced-motion: reduce) {
          ::view-transition-old(root),
          ::view-transition-new(root) { animation: none; }
        }
      </style>
    {%- endif -%}

    {{ content_for_header }}
  </head>

  <body
    class="template-{{ request.page_type | handle }}"
    data-scroll-animations="{{ settings.enable_scroll_animations }}"
    data-smooth-scroll="{{ settings.enable_smooth_scroll }}"
    data-custom-cursor="{{ settings.enable_custom_cursor }}"
    data-hover-swap="{{ settings.enable_hover_image_swap }}"
  >
    {% render 'loader' %}

    <a class="skip-link" href="#main-content">{{ 'general.skip_to_content' | t }}</a>

    <div class="site-layout">
      {% sections 'header-group' %}

      <div class="site-main">
        {% sections 'announcement-group' %}

        <main id="main-content" tabindex="-1">
          {{ content_for_layout }}
        </main>

        {% sections 'footer-group' %}
      </div>
    </div>

    {%- if settings.cart_type == 'drawer' -%}
      {% render 'cart-drawer' %}
    {%- endif -%}

    {%- comment -%} Render unless explicitly disabled: the setting is nil on a fresh/GitHub-synced theme (not in settings_data), and `{% if nil %}` would hide the cursor by default. `!= false` shows it by default while still honouring an explicit off. {%- endcomment -%}
    {%- if settings.enable_custom_cursor != false -%}{% render 'cursor' %}{%- endif -%}

    {% render 'scroll-top' %}

    <script src="{{ 'theme.js' | asset_url }}" defer></script>
    <script src="{{ 'cart.js' | asset_url }}" defer></script>
    <script src="{{ 'gsap.min.js' | asset_url }}" defer></script>
    <script src="{{ 'lenis.min.js' | asset_url }}" defer></script>
  </body>
</html>
