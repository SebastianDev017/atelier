{% layout none %}
<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <script>document.documentElement.classList.replace('no-js', 'js');</script>
    {% render 'css-variables' %}
    {%- unless settings.body_font.system? -%}
      <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
    {%- endunless -%}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    <title>{{ 'gift_card.title' | t }} · {{ shop.name }}</title>
  </head>

  <body class="template-gift-card color-scheme--cream">
    <main class="gift-card page-width page-width--narrow">
      <div class="gift-card__inner">
        <p class="eyebrow">{{ shop.name | escape }}</p>
        <h1 class="gift-card__heading h2">{{ 'gift_card.title' | t }}</h1>

        <div class="gift-card__amount h0">{{ gift_card.balance | money }}</div>

        {%- if gift_card.enabled == false or gift_card.expired -%}
          <p class="gift-card__expired badge badge--sale">{{ 'gift_card.expired' | t }}</p>
        {%- elsif gift_card.expires_on -%}
          <p class="caption">{{ 'gift_card.expires_on_html' | t: date: gift_card.expires_on | date: '%B %e, %Y' }}</p>
        {%- endif -%}

        <div class="gift-card__code-wrap">
          <p class="label">{{ 'gift_card.code_label' | t }}</p>
          <div class="gift-card__code" data-gift-code>{{ gift_card.code | format_code }}</div>
          <button type="button" class="btn btn--outline btn--small" data-copy-code data-copied-label="{{ 'gift_card.copied' | t | escape }}" data-value="{{ gift_card.code }}">
            {{ 'gift_card.copy_code' | t }}
          </button>
          <p class="caption">{{ 'gift_card.use_at_checkout' | t }}</p>
        </div>

        {%- if gift_card.pass_url -%}
          <a class="gift-card__wallet" href="{{ gift_card.pass_url }}">
            <img src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}" alt="{{ 'gift_card.add_to_apple_wallet' | t }}" width="200" height="60">
          </a>
        {%- endif -%}

        <a class="link-underline" href="{{ shop.url }}">{{ 'gift_card.shop_link' | t }}</a>
      </div>
    </main>

    <script>
      (function () {
        var btn = document.querySelector('[data-copy-code]');
        if (!btn || !navigator.clipboard) return;
        btn.addEventListener('click', function () {
          navigator.clipboard.writeText(btn.getAttribute('data-value')).then(function () {
            var original = btn.textContent;
            btn.textContent = btn.getAttribute('data-copied-label');
            setTimeout(function () { btn.textContent = original; }, 2000);
          });
        });
      })();
    </script>
  </body>
</html>

{% stylesheet %}
  .gift-card { min-height: 100svh; display: flex; align-items: center; justify-content: center; padding-block: var(--space-16); }
  .gift-card__inner { display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--space-4); }
  .gift-card__amount { font-family: var(--font-heading); margin-block: var(--space-2); }
  .gift-card__code-wrap { display: flex; flex-direction: column; align-items: center; gap: var(--space-3); margin-top: var(--space-4); }
  .gift-card__code { font-family: var(--font-heading); font-size: var(--text-2xl); letter-spacing: 0.1em; padding: var(--space-3) var(--space-5); border: 1px dashed var(--color-border-strong); }
  .gift-card__wallet { margin-top: var(--space-2); }
{% endstylesheet %}
