{%- liquid
  assign scheme = section.settings.color_scheme | default: 'invert'
  assign has_social = false
  if settings.social_instagram_link != blank or settings.social_facebook_link != blank or settings.social_pinterest_link != blank or settings.social_tiktok_link != blank or settings.social_youtube_link != blank
    assign has_social = true
  endif
-%}

<footer
  class="footer color-scheme--{{ scheme }}"
  style="padding-top: {{ section.settings.padding_top | default: 64 }}px; padding-bottom: {{ section.settings.padding_bottom | default: 64 }}px;"
>
  <div class="page-width">
    {%- if section.settings.show_wordmark -%}
      {%- assign wordmark = section.settings.wordmark_text | default: shop.name | upcase -%}
      <div
        class="footer-wordmark"
        aria-hidden="true"
        style="opacity: {{ section.settings.wordmark_opacity | divided_by: 100.0 }};"
      >{{ wordmark }}</div>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="footer__top">
        {%- for block in section.blocks -%}
          <div class="footer__block footer__block--{{ block.type }}" {{ block.shopify_attributes }} data-animate data-animate-delay="{{ forloop.index | modulo: 4 | plus: 1 }}">
            {%- case block.type -%}
              {%- when 'brand' -%}
                {%- if settings.logo != blank -%}
                  {%- liquid
                    assign brand_2x = block.settings.logo_width | times: 2
                    assign brand_alt = shop.name | escape
                    assign brand_sizes = block.settings.logo_width | append: 'px'
                    assign brand_style = '--logo-width: ' | append: block.settings.logo_width | append: 'px;'
                  -%}
                  {{ settings.logo | image_url: width: brand_2x | image_tag: loading: 'lazy', widths: '120, 240, 360', sizes: brand_sizes, alt: brand_alt, class: 'footer__logo', style: brand_style }}
                {%- else -%}
                  <span class="footer__brand-name">{{ shop.name | escape }}</span>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="footer__brand-text prose">{{ block.settings.text }}</div>
                {%- endif -%}
                {%- if has_social and block.settings.show_social -%}
                  {% render 'social-icons' %}
                {%- endif -%}

              {%- when 'menu' -%}
                {%- if block.settings.heading != blank -%}
                  <h2 class="footer__heading eyebrow">{{ block.settings.heading | escape }}</h2>
                {%- endif -%}
                {%- if block.settings.menu != blank -%}
                  <ul class="footer__menu">
                    {%- for link in block.settings.menu.links -%}
                      <li><a class="footer__link" href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title | escape }}</a></li>
                    {%- endfor -%}
                  </ul>
                {%- endif -%}

              {%- when 'text' -%}
                {%- if block.settings.heading != blank -%}
                  <h2 class="footer__heading eyebrow">{{ block.settings.heading | escape }}</h2>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="footer__text prose">{{ block.settings.text }}</div>
                {%- endif -%}

              {%- when 'newsletter' -%}
                {%- if block.settings.heading != blank -%}
                  <h2 class="footer__heading eyebrow">{{ block.settings.heading | escape }}</h2>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <div class="footer__text prose">{{ block.settings.text }}</div>
                {%- endif -%}
                {%- form 'customer', class: 'footer__newsletter' -%}
                  <input type="hidden" name="contact[tags]" value="newsletter">
                  <label class="visually-hidden" for="FooterEmail-{{ section.id }}">{{ 'newsletter.label' | t }}</label>
                  <div class="footer__newsletter-row">
                    <input
                      class="input"
                      type="email"
                      id="FooterEmail-{{ section.id }}"
                      name="contact[email]"
                      placeholder="{{ 'newsletter.label' | t }}"
                      autocomplete="email"
                      required
                    >
                    <button type="submit" class="btn" name="commit">{{ 'newsletter.submit' | t }}</button>
                  </div>
                  {%- if form.posted_successfully? -%}
                    <p class="form-status form-status--success" role="status">{{ 'newsletter.success' | t }}</p>
                  {%- elsif form.errors -%}
                    <p class="form-status form-status--error" role="alert">{{ form.errors | default_errors }}</p>
                  {%- endif -%}
                {%- endform -%}
            {%- endcase -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="footer__bottom">
      <div class="footer__bottom-left">
        <span class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name | escape }}</span>
        {%- if section.settings.show_policy_links -%}
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              <span class="footer__dot" aria-hidden="true">·</span>
              <a class="footer__bottom-link" href="{{ policy.url }}">{{ policy.title | escape }}</a>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </div>

      <div class="footer__bottom-right">
        {%- if section.settings.show_country_selector and localization.available_countries.size > 1 -%}
          {%- form 'localization', id: 'FooterCountryForm' -%}
            <div class="footer-localization">
              <select name="country_code" onchange="this.form.submit()" aria-label="{{ 'localization.country_label' | t }}">
                {%- for country in localization.available_countries -%}
                  <option value="{{ country.iso_code }}"{% if country.iso_code == localization.country.iso_code %} selected{% endif %}>{{ country.name }} ({{ country.currency.iso_code }})</option>
                {%- endfor -%}
              </select>
            </div>
          {%- endform -%}
        {%- endif -%}

        {%- if section.settings.show_language_selector and localization.available_languages.size > 1 -%}
          {%- form 'localization', id: 'FooterLanguageForm' -%}
            <div class="footer-localization">
              <select name="locale_code" onchange="this.form.submit()" aria-label="{{ 'localization.language_label' | t }}">
                {%- for language in localization.available_languages -%}
                  <option value="{{ language.iso_code }}"{% if language.iso_code == localization.language.iso_code %} selected{% endif %}>{{ language.endonym_name }}</option>
                {%- endfor -%}
              </select>
            </div>
          {%- endform -%}
        {%- endif -%}

        {%- if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 -%}
          <ul class="footer__payment" aria-label="Payment methods">
            {%- for type in shop.enabled_payment_types -%}
              <li>{{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}</li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer-wordmark {
    font-family: var(--font-heading);
    font-size: clamp(3rem, 9vw, 11rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    line-height: 1;
    opacity: 0.1;
    padding-bottom: clamp(2rem, 4vw, 4rem);
    overflow: hidden;
    white-space: nowrap;
    text-overflow: clip;
    color: currentColor;
  }
  .footer__top {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 14rem), 1fr));
    gap: var(--space-10) var(--space-8);
    padding-bottom: var(--space-12);
    border-bottom: 1px solid var(--color-border);
  }
  .footer__block { display: flex; flex-direction: column; gap: var(--space-4); }
  .footer__block--brand { gap: var(--space-5); }
  .footer__brand-name { font-family: var(--font-heading); font-size: var(--text-2xl); }
  .footer__logo { width: var(--logo-width, 150px); height: auto; }
  .footer__brand-text { font-size: var(--text-sm); color: var(--color-muted); max-width: 28ch; }
  .footer__heading { color: color-mix(in srgb, var(--color-text) 70%, transparent); }
  .footer__menu { display: flex; flex-direction: column; gap: var(--space-1); }
  .footer__link,
  .footer__text a { font-size: var(--text-sm); color: var(--color-text); opacity: 0.85; transition: opacity var(--duration-fast) var(--ease-editorial); }
  /* 44px tap target for footer links (gap reduced above to offset the added height). */
  .footer__link { display: inline-flex; align-items: center; min-height: 44px; }
  .footer__link:hover { opacity: 1; }
  .footer__bottom-link { display: inline-flex; align-items: center; min-height: 44px; }
  .footer__text { font-size: var(--text-sm); color: var(--color-muted); }

  .footer__newsletter-row { display: flex; gap: var(--space-2); flex-wrap: wrap; }
  .footer__newsletter-row .input { flex: 1 1 12rem; }

  .footer__bottom {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-top: var(--space-6);
  }
  .footer__bottom-left { display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-2); font-size: var(--text-xs); letter-spacing: var(--tracking-wide); text-transform: uppercase; color: color-mix(in srgb, var(--color-text) 70%, transparent); }
  .footer__dot { color: var(--color-text); opacity: 0.4; }
  .footer__bottom-link:hover { color: var(--color-text); }
  .footer__bottom-right { display: flex; align-items: center; gap: var(--space-5); flex-wrap: wrap; }
  .footer__payment { display: flex; align-items: center; gap: var(--space-2); flex-wrap: wrap; }
  .footer__payment-icon { width: 2.2rem; height: auto; }

  /* Native localization selectors (country / language) */
  .footer-localization { position: relative; display: inline-block; }
  .footer-localization::after {
    content: '';
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    width: 8px;
    height: 5px;
    background-color: currentColor;
    clip-path: polygon(0 0, 100% 0, 50% 100%);
    pointer-events: none;
    opacity: 0.6;
  }
  .footer-localization select {
    background: transparent;
    border: 1px solid currentColor;
    border-radius: 0;
    color: inherit;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.4rem 2.5rem 0.4rem 0.75rem;
    appearance: none;
    -webkit-appearance: none;
    opacity: 0.7;
    transition: opacity var(--duration-fast) var(--ease-editorial);
  }
  .footer-localization select:hover { opacity: 1; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "brand",
      "name": "t:sections.footer.blocks.brand.name",
      "limit": 1,
      "settings": [
        { "type": "richtext", "id": "text", "label": "t:sections.footer.blocks.brand.settings.text.label", "default": "<p>Considered objects for the modern home.</p>" },
        { "type": "range", "id": "logo_width", "min": 80, "max": 240, "step": 4, "unit": "px", "label": "t:sections.footer.blocks.brand.settings.logo_width.label", "default": 140 },
        { "type": "checkbox", "id": "show_social", "label": "t:sections.footer.blocks.brand.settings.show_social.label", "default": true }
      ]
    },
    {
      "type": "menu",
      "name": "t:sections.footer.blocks.menu.name",
      "settings": [
        { "type": "text", "id": "heading", "label": "t:sections.footer.blocks.menu.settings.heading.label", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "t:sections.footer.blocks.menu.settings.menu.label", "default": "footer" }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        { "type": "text", "id": "heading", "label": "t:sections.footer.blocks.text.settings.heading.label", "default": "About" },
        { "type": "richtext", "id": "text", "label": "t:sections.footer.blocks.text.settings.text.label", "default": "<p>Share your store’s story, shipping, or contact details here.</p>" }
      ]
    },
    {
      "type": "newsletter",
      "name": "t:sections.footer.blocks.newsletter.name",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "t:sections.footer.blocks.newsletter.settings.heading.label", "default": "Newsletter" },
        { "type": "richtext", "id": "text", "label": "t:sections.footer.blocks.newsletter.settings.text.label", "default": "<p>Subscribe for new arrivals and stories.</p>" }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__1.content"
    },
    {
      "type": "checkbox",
      "id": "show_wordmark",
      "label": "t:sections.footer.settings.show_wordmark.label",
      "default": false
    },
    {
      "type": "range",
      "id": "wordmark_opacity",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "%",
      "label": "t:sections.footer.settings.wordmark_opacity.label",
      "default": 10
    },
    {
      "type": "text",
      "id": "wordmark_text",
      "label": "t:sections.footer.settings.wordmark_text.label",
      "info": "t:sections.footer.settings.wordmark_text.info"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__2.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.padding_top.label",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.padding_bottom.label",
      "default": 64
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:sections.footer.settings.show_payment_icons.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_policy_links",
      "label": "t:sections.footer.settings.show_policy_links.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__3.content"
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "t:sections.footer.settings.show_country_selector.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_language_selector",
      "label": "t:sections.footer.settings.show_language_selector.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__4.content"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.footer.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.footer.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.footer.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.footer.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.footer.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.footer.settings.color_scheme.options__5.label" }
      ],
      "default": "invert"
    }
  ],
  "default": {
    "blocks": [
      { "type": "brand" },
      { "type": "menu" },
      { "type": "text" },
      { "type": "newsletter" }
    ]
  }
}
{% endschema %}
