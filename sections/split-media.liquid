{%- comment -%}
  Split media — asymmetric two-panel layout (image + content, ~45/55) side by
  side on desktop, stacked on mobile. media_position controls which side the image
  sits on via CSS order. Section padding is applied to the wrapper that spans
  BOTH panels so the media panel (which stacks first on mobile) also gets it.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'

  assign ratio_class = 'media--portrait'
  case section.settings.image_ratio
    when 'square'
      assign ratio_class = 'media--square'
    when 'landscape'
      assign ratio_class = 'media--landscape'
    when 'wide'
      assign ratio_class = 'media--wide'
  endcase

  assign media_class = 'split-media--image-right'
  if section.settings.media_position == 'left'
    assign media_class = 'split-media--image-left'
  endif

  assign img_alt = section.settings.image.alt | default: section.settings.heading | escape

  assign cta_class = 'btn btn--outline'
  case section.settings.cta_style
    when 'solid'
      assign cta_class = 'btn'
    when 'link'
      assign cta_class = 'link-underline'
  endcase

  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign heading_size = section.settings.heading_size | default: 'lg'
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="split-media color-scheme--{{ scheme }} {{ media_class }}">
  <div class="split-media__grid">
  <div class="split-media__panel split-media__panel--media" data-animate-left>
    <div class="media {{ ratio_class }}">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800, 1000, 1200, 1400',
            sizes: '(min-width: 750px) 50vw, 100vw',
            alt: img_alt
        }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder' }}
      {%- endif -%}
    </div>
  </div>

  <div class="split-media__panel split-media__panel--content" data-animate-right>
    <div class="split-media__inner">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <{{ heading_tag }} class="split-media__heading section-heading heading--{{ heading_size }} reveal-lines"><span class="line">{{ section.settings.heading | escape }}</span></{{ heading_tag }}>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="split-media__text prose">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
        <div class="split-media__cta">
          <a class="{{ cta_class }}" href="{{ section.settings.cta_url }}">
            {{- section.settings.cta_label | escape -}}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
  </div>
</div>

{% stylesheet %}
  .split-media {
    padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing));
  }
  /* Constrained grid wrapper: insets BOTH panels from the column edges so the
     image no longer touches the sidebar divider, while .split-media keeps the
     color-scheme background full-width. */
  .split-media__grid {
    display: grid;
    grid-template-columns: 1fr;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 3vw, 3rem);
  }
  .split-media__panel {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .split-media__panel--media .media {
    width: 100%;
  }
  .split-media__panel--media img {
    transition: transform var(--duration-slow) var(--ease-editorial);
  }
  .split-media__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding-block: var(--space-10);
    max-width: 52ch;
  }
  .split-media__heading {
    max-width: 20ch;
  }
  .split-media__text {
    color: var(--color-muted);
  }
  .split-media__cta {
    margin-top: var(--space-2);
  }

  @media (min-width: 750px) {
    .split-media__grid {
      grid-template-columns: 0.9fr 1.1fr;
      gap: clamp(2rem, 5vw, 5rem);
      align-items: stretch;
    }
    .split-media--image-left .split-media__panel--media { order: 0; }
    .split-media--image-left .split-media__panel--content { order: 1; }
    .split-media--image-right .split-media__panel--media { order: 1; }
    .split-media--image-right .split-media__panel--content { order: 0; }
    .split-media__inner {
      padding-block: var(--space-12);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.split-media.name",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.split-media.settings.image.label"
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "t:sections.split-media.settings.media_position.label",
      "options": [
        { "value": "left", "label": "t:sections.split-media.settings.media_position.options__1.label" },
        { "value": "right", "label": "t:sections.split-media.settings.media_position.options__2.label" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.split-media.settings.image_ratio.label",
      "options": [
        { "value": "portrait", "label": "t:sections.split-media.settings.image_ratio.options__1.label" },
        { "value": "square", "label": "t:sections.split-media.settings.image_ratio.options__2.label" },
        { "value": "landscape", "label": "t:sections.split-media.settings.image_ratio.options__3.label" },
        { "value": "wide", "label": "t:sections.split-media.settings.image_ratio.options__4.label" }
      ],
      "default": "portrait"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.split-media.settings.eyebrow.label",
      "default": "Our craft"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "t:sections.split-media.settings.heading.label",
      "default": "Two halves of one story"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.split-media.settings.heading_tag.label",
      "info": "t:sections.split-media.settings.heading_tag.info",
      "options": [
        { "value": "h1", "label": "t:sections.split-media.settings.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.split-media.settings.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.split-media.settings.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.split-media.settings.heading_tag.options__4.label" },
        { "value": "p", "label": "t:sections.split-media.settings.heading_tag.options__5.label" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.split-media.settings.heading_size.label",
      "info": "t:sections.split-media.settings.heading_size.info",
      "options": [
        { "value": "display", "label": "t:sections.split-media.settings.heading_size.options__1.label" },
        { "value": "xl", "label": "t:sections.split-media.settings.heading_size.options__2.label" },
        { "value": "lg", "label": "t:sections.split-media.settings.heading_size.options__3.label" },
        { "value": "md", "label": "t:sections.split-media.settings.heading_size.options__4.label" },
        { "value": "sm", "label": "t:sections.split-media.settings.heading_size.options__5.label" },
        { "value": "xs", "label": "t:sections.split-media.settings.heading_size.options__6.label" },
        { "value": "body", "label": "t:sections.split-media.settings.heading_size.options__7.label" }
      ],
      "default": "lg"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.split-media.settings.text.label",
      "default": "<p>Pair a considered image with a few honest words. Use this space to share the thinking behind a product, a process, or a place.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:sections.split-media.settings.cta_label.label",
      "default": "Discover more"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:sections.split-media.settings.cta_url.label"
    },
    {
      "type": "select",
      "id": "cta_style",
      "label": "t:sections.split-media.settings.cta_style.label",
      "options": [
        { "value": "solid", "label": "t:sections.split-media.settings.cta_style.options__1.label" },
        { "value": "outline", "label": "t:sections.split-media.settings.cta_style.options__2.label" },
        { "value": "link", "label": "t:sections.split-media.settings.cta_style.options__3.label" }
      ],
      "default": "outline"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.split-media.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.split-media.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.split-media.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.split-media.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.split-media.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.split-media.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.split-media.settings.padding_top.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.split-media.settings.padding_bottom.label",
      "default": 0
    }
  ],
  "presets": [
    { "name": "t:sections.split-media.presets.name" }
  ]
}
{% endschema %}
