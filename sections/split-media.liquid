{%- comment -%}
  Split media — asymmetric two-panel layout (image + content, ~45/55) side by
  side on desktop, stacked on mobile. media_position controls which side the image
  sits on via CSS order. Section padding is applied to the wrapper that spans
  BOTH panels so the media panel (which stacks first on mobile) also gets it.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'

  assign ratio_class = 'media--portrait'
  case section.settings.image_ratio
    when 'square'
      assign ratio_class = 'media--square'
    when 'landscape'
      assign ratio_class = 'media--landscape'
    when 'wide'
      assign ratio_class = 'media--wide'
  endcase

  assign media_class = 'split-media--image-right'
  if section.settings.media_position == 'left'
    assign media_class = 'split-media--image-left'
  endif

  assign img_alt = section.settings.image.alt | default: section.settings.heading | escape

  assign cta_class = 'btn btn--outline'
  case section.settings.cta_style
    when 'solid'
      assign cta_class = 'btn'
    when 'link'
      assign cta_class = 'link-underline'
  endcase

  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign heading_size = section.settings.heading_size | default: 'lg'
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="split-media color-scheme--{{ scheme }} {{ media_class }}">
  <div class="split-media__grid">
  <div class="split-media__panel split-media__panel--media" data-animate-left>
    <div class="media {{ ratio_class }}">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1400
          | image_tag:
            loading: 'lazy',
            widths: '400, 600, 800, 1000, 1200, 1400',
            sizes: '(min-width: 750px) 50vw, 100vw',
            alt: img_alt
        }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder' }}
      {%- endif -%}
    </div>
  </div>

  <div class="split-media__panel split-media__panel--content" data-animate-right>
    <div class="split-media__inner">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <{{ heading_tag }} class="split-media__heading section-heading heading--{{ heading_size }} reveal-lines"><span class="line">{{ section.settings.heading | escape }}</span></{{ heading_tag }}>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="split-media__text prose">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
        <div class="split-media__cta">
          <a class="{{ cta_class }}" href="{{ section.settings.cta_url }}">
            {{- section.settings.cta_label | escape -}}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
  </div>
</div>

{% stylesheet %}
  .split-media {
    padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing));
  }
  /* Constrained grid wrapper: insets BOTH panels from the column edges so the
     image no longer touches the sidebar divider, while .split-media keeps the
     color-scheme background full-width. */
  .split-media__grid {
    display: grid;
    grid-template-columns: 1fr;
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: clamp(1.5rem, 3vw, 3rem);
  }
  .split-media__panel {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .split-media__panel--media .media {
    width: 100%;
  }
  .split-media__panel--media img {
    transition: transform var(--duration-slow) var(--ease-editorial);
  }
  .split-media__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding-block: var(--space-10);
    max-width: 52ch;
  }
  .split-media__heading {
    max-width: 20ch;
  }
  .split-media__text {
    color: var(--color-muted);
  }
  .split-media__cta {
    margin-top: var(--space-2);
  }

  @media (min-width: 750px) {
    .split-media__grid {
      grid-template-columns: 0.9fr 1.1fr;
      gap: clamp(2rem, 5vw, 5rem);
      align-items: stretch;
    }
    .split-media--image-left .split-media__panel--media { order: 0; }
    .split-media--image-left .split-media__panel--content { order: 1; }
    .split-media--image-right .split-media__panel--media { order: 1; }
    .split-media--image-right .split-media__panel--content { order: 0; }
    .split-media__inner {
      padding-block: var(--space-12);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Split media",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "portrait", "label": "Portrait" },
        { "value": "square", "label": "Square" },
        { "value": "landscape", "label": "Landscape" },
        { "value": "wide", "label": "Wide" }
      ],
      "default": "portrait"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our craft"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Two halves of one story"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading element",
      "info": "Choose the HTML tag for SEO and accessibility",
      "options": [
        { "value": "h1", "label": "H1 — Main page title" },
        { "value": "h2", "label": "H2 — Section title (default)" },
        { "value": "h3", "label": "H3 — Subsection" },
        { "value": "h4", "label": "H4 — Minor heading" },
        { "value": "p", "label": "Paragraph — no heading" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "info": "Visual size, independent of the element",
      "options": [
        { "value": "display", "label": "Display — oversized editorial" },
        { "value": "xl", "label": "XL — hero scale" },
        { "value": "lg", "label": "Large — section title" },
        { "value": "md", "label": "Medium — standard" },
        { "value": "sm", "label": "Small — card heading" },
        { "value": "xs", "label": "Extra small — caption scale" },
        { "value": "body", "label": "Body — same as body text" }
      ],
      "default": "lg"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Pair a considered image with a few honest words. Use this space to share the thinking behind a product, a process, or a place.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Discover more"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "cta_style",
      "label": "Button style",
      "options": [
        { "value": "solid", "label": "Solid" },
        { "value": "outline", "label": "Outline" },
        { "value": "link", "label": "Link" }
      ],
      "default": "outline"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "cream", "label": "Cream" },
        { "value": "parchment", "label": "Parchment" },
        { "value": "linen", "label": "Linen" },
        { "value": "white", "label": "White" },
        { "value": "invert", "label": "Inverted" }
      ],
      "default": "cream"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "presets": [
    { "name": "Split media" }
  ]
}
{% endschema %}
