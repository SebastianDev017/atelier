{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign per_page = section.settings.products_per_page
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --grid-columns: {{ section.settings.columns_desktop }};
    --grid-columns-mobile: {{ section.settings.columns_mobile }};
  }
</style>

<div class="collection color-scheme--{{ scheme }}">
  <div class="page-width">
    {% render 'breadcrumbs', current: collection.title %}
    {%- if section.settings.show_title -%}
      <header class="collection__head" data-animate>
        <h2 class="collection__title h2">{{ collection.title | escape }}</h2>
        {%- if section.settings.show_description and collection.description != blank -%}
          <div class="collection__description prose">{{ collection.description }}</div>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- paginate collection.products by per_page -%}
      <div class="collection__toolbar">
        <p class="collection__count caption">{{ 'collections.product_count' | t: count: collection.products_count }}</p>
        <div class="collection__view-toggle" data-collection-view role="group" aria-label="{{ 'collections.view_as' | t }}">
          <button type="button" class="collection__view-btn" data-view-btn="grid" aria-label="{{ 'collections.view_grid' | t }}" aria-pressed="true">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><rect x="1.5" y="1.5" width="6" height="6"/><rect x="10.5" y="1.5" width="6" height="6"/><rect x="1.5" y="10.5" width="6" height="6"/><rect x="10.5" y="10.5" width="6" height="6"/></svg>
          </button>
          <button type="button" class="collection__view-btn" data-view-btn="list" aria-label="{{ 'collections.view_list' | t }}" aria-pressed="false">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true"><line x1="1.5" y1="3" x2="16.5" y2="3"/><line x1="1.5" y1="9" x2="16.5" y2="9"/><line x1="1.5" y1="15" x2="16.5" y2="15"/></svg>
          </button>
        </div>
      </div>

      <div class="collection__layout">
        {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
          <aside class="collection__sidebar">
            <details class="collection__facets" open>
              <summary class="collection__facets-toggle btn btn--outline btn--small">
                {% render 'icon', name: 'filter' %}
                <span>{{ 'collections.filter_and_sort' | t }}</span>
              </summary>
              {% render 'facets', results: collection, context: 'collection', enable_sorting: section.settings.enable_sorting %}
            </details>
          </aside>
        {%- endif -%}

        <div class="collection__results">
          {%- if collection.products.size > 0 -%}
            <div class="product-grid" data-product-grid data-view="{{ section.settings.view_default | default: 'grid' }}">
              {%- for product in collection.products -%}
                <div data-animate data-animate-delay="{{ forloop.index | modulo: 5 | plus: 1 }}" data-flip-id="card-{{ product.id }}">
                  {% render 'product-card', product: product, index: forloop.index, quick_add_style: section.settings.quick_add_style %}
                </div>
              {%- endfor -%}
            </div>
            {% render 'pagination', paginate: paginate %}
          {%- else -%}
            <div class="collection__empty">
              <p class="h4">{{ 'collections.empty_filters' | t }}</p>
              <a class="link-underline" href="{{ collection.url }}">{{ 'collections.clear_all' | t }}</a>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endpaginate -%}
  </div>
</div>

{% stylesheet %}
  .collection { padding-block: var(--pt, var(--space-12)) var(--pb, var(--space-24)); }
  .collection__head { max-width: 46rem; margin-bottom: var(--space-10); display: flex; flex-direction: column; gap: var(--space-4); }
  .collection__description { color: var(--color-muted); }
  .collection__toolbar { display: flex; align-items: center; justify-content: space-between; padding-bottom: var(--space-5); border-bottom: 1px solid var(--color-border); margin-bottom: var(--space-8); }
  .collection__empty { display: flex; flex-direction: column; align-items: center; gap: var(--space-4); text-align: center; padding-block: var(--space-20); }

  /* Grid / editorial-list view toggle */
  .collection__view-toggle { display: inline-flex; gap: 2px; }
  .collection__view-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--color-muted);
    border: 1px solid transparent;
    transition: color var(--duration-fast) var(--ease-editorial), border-color var(--duration-fast) var(--ease-editorial);
  }
  .collection__view-btn:hover { color: var(--color-text); }
  .collection__view-btn[aria-pressed="true"] { color: var(--color-text); border-color: var(--color-border); }

  /* Editorial list view — restyles the SAME product cards into rows so GSAP Flip
     can morph between the two layouts (collection-view.js). */
  .product-grid[data-view="list"] { display: flex; flex-direction: column; gap: 0; }
  .product-grid[data-view="list"] > * { width: 100%; }
  .product-grid[data-view="list"] .product-card {
    display: grid;
    grid-template-columns: clamp(110px, 22vw, 220px) 1fr;
    align-items: center;
    gap: var(--space-8);
    padding-block: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }
  .product-grid[data-view="list"] .product-card__info { display: flex; flex-direction: column; gap: var(--space-2); align-items: flex-start; }
  .product-grid[data-view="list"] .product-card__title { font-size: clamp(1.5rem, 3vw, 2.25rem); }
  .product-grid[data-view="list"] .product-card__overlay { display: none; }
  @media (max-width: 749px) {
    .product-grid[data-view="list"] .product-card { grid-template-columns: clamp(90px, 30vw, 140px) 1fr; gap: var(--space-5); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main-collection.name",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "show_title", "label": "t:sections.main-collection.settings.show_title.label", "info": "t:sections.main-collection.settings.show_title.info", "default": false },
    { "type": "checkbox", "id": "show_description", "label": "t:sections.main-collection.settings.show_description.label", "default": true },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 36,
      "step": 4,
      "label": "t:sections.main-collection.settings.products_per_page.label",
      "default": 16
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "t:sections.main-collection.settings.columns_desktop.label",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:sections.main-collection.settings.columns_mobile.label",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    { "type": "checkbox", "id": "enable_filtering", "label": "t:sections.main-collection.settings.enable_filtering.label", "info": "t:sections.main-collection.settings.enable_filtering.info", "default": true },
    { "type": "checkbox", "id": "enable_sorting", "label": "t:sections.main-collection.settings.enable_sorting.label", "default": true },
    {
      "type": "select",
      "id": "quick_add_style",
      "label": "t:sections.main-collection.settings.quick_add_style.label",
      "options": [
        { "value": "hover", "label": "t:sections.main-collection.settings.quick_add_style.options__1.label" },
        { "value": "always", "label": "t:sections.main-collection.settings.quick_add_style.options__2.label" }
      ],
      "default": "hover"
    },
    {
      "type": "select",
      "id": "view_default",
      "label": "t:sections.main-collection.settings.view_default.label",
      "options": [
        { "value": "grid", "label": "t:sections.main-collection.settings.view_default.options__1.label" },
        { "value": "list", "label": "t:sections.main-collection.settings.view_default.options__2.label" }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.main-collection.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.main-collection.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.main-collection.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.main-collection.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.main-collection.settings.color_scheme.options__4.label" }
      ],
      "default": "cream"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.main-collection.settings.padding_top.label", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.main-collection.settings.padding_bottom.label", "default": 96 }
  ]
}
{% endschema %}
