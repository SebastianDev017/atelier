{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="custom-liquid color-scheme--{{ scheme }}">
  <div class="page-width{% if section.settings.narrow %} page-width--narrow{% endif %}" data-animate>
    {{ section.settings.custom_liquid }}
  </div>
</div>

{% stylesheet %}
  .custom-liquid { padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing)); }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.custom-liquid.name",
  "tag": "section",
  "settings": [
    { "type": "liquid", "id": "custom_liquid", "label": "t:sections.custom-liquid.settings.custom_liquid.label", "info": "t:sections.custom-liquid.settings.custom_liquid.info" },
    { "type": "checkbox", "id": "narrow", "label": "t:sections.custom-liquid.settings.narrow.label", "default": false },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.custom-liquid.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.custom-liquid.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.custom-liquid.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.custom-liquid.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.custom-liquid.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.custom-liquid.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.custom-liquid.settings.padding_top.label", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.custom-liquid.settings.padding_bottom.label", "default": 48 }
  ],
  "presets": [
    { "name": "t:sections.custom-liquid.presets.name" }
  ]
}
{% endschema %}
