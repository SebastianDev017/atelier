{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="custom-liquid color-scheme--{{ scheme }}">
  <div class="page-width{% if section.settings.narrow %} page-width--narrow{% endif %}" data-animate>
    {{ section.settings.custom_liquid }}
  </div>
</div>

{% stylesheet %}
  .custom-liquid { padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing)); }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Liquid",
  "tag": "section",
  "settings": [
    { "type": "liquid", "id": "custom_liquid", "label": "Custom Liquid", "info": "Add app snippets or custom code." },
    { "type": "checkbox", "id": "narrow", "label": "Narrow width", "default": false },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "cream", "label": "Cream" },
        { "value": "parchment", "label": "Parchment" },
        { "value": "linen", "label": "Linen" },
        { "value": "white", "label": "White" },
        { "value": "invert", "label": "Inverted" }
      ],
      "default": "cream"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Top padding", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Bottom padding", "default": 48 }
  ],
  "presets": [
    { "name": "Custom Liquid" }
  ]
}
{% endschema %}
