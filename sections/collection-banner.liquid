{%- comment -%}
  Collection banner — sits above the product grid on collection pages.
  Reads the {{ collection }} object. With a collection image it becomes a
  full-bleed media banner with an overlay + inverted text; without one it
  falls back to a simple centered text banner painted by the color scheme.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'

  assign banner_title = collection.title | default: shop.name

  assign align_class = 'collection-banner--center'
  case section.settings.text_alignment
    when 'left'
      assign align_class = 'collection-banner--left'
    when 'right'
      assign align_class = 'collection-banner--right'
  endcase

  assign banner_height = '45svh'
  case section.settings.banner_height
    when 'small'
      assign banner_height = '30svh'
    when 'large'
      assign banner_height = '60svh'
  endcase

  assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0

  assign has_image = false
  if section.settings.show_collection_image and collection.image
    assign has_image = true
  endif

  assign image_alt = collection.image.alt | default: banner_title | escape

  assign heading_tag = section.settings.heading_tag | default: 'h1'
  assign heading_size = section.settings.heading_size | default: 'display'
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --banner-height: {{ banner_height }};
    --banner-overlay-color: {{ section.settings.overlay_color }};
    --banner-overlay-alpha: {{ overlay_alpha }};
  }
</style>

{%- if has_image -%}
  <div class="collection-banner collection-banner--media color-scheme--invert {{ align_class }}">
    <div class="collection-banner__media" data-animate-scale>
      {{
        collection.image
        | image_url: width: 2200
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '600, 900, 1200, 1600, 2000, 2200',
          sizes: '100vw',
          alt: image_alt,
          class: 'collection-banner__image'
      }}
      <span class="collection-banner__overlay" aria-hidden="true"></span>
    </div>
    <div class="collection-banner__inner page-width">
      <div class="collection-banner__content">
        <{{ heading_tag }} class="collection-banner__title section-heading heading--{{ heading_size }}" data-animate>{{ banner_title | escape }}</{{ heading_tag }}>
        {%- if section.settings.show_description and collection.description != blank -%}
          <div class="collection-banner__description prose" data-animate data-animate-delay="2">
            {{ collection.description }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- else -%}
  <div class="collection-banner collection-banner--plain color-scheme--{{ scheme }} {{ align_class }}">
    <div class="collection-banner__inner page-width">
      <div class="collection-banner__content">
        <{{ heading_tag }} class="collection-banner__title section-heading heading--{{ heading_size }}" data-animate>{{ banner_title | escape }}</{{ heading_tag }}>
        {%- if section.settings.show_description and collection.description != blank -%}
          <div class="collection-banner__description prose" data-animate data-animate-delay="2">
            {{ collection.description }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .collection-banner {
    padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing));
  }

  .collection-banner__inner {
    position: relative;
    z-index: var(--z-raised);
  }

  .collection-banner__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: 52rem;
  }

  .collection-banner__title {
    max-width: 20ch;
  }

  .collection-banner__description {
    max-width: 60ch;
    color: var(--color-muted);
  }

  /* Alignment modifiers */
  .collection-banner--center .collection-banner__content {
    align-items: center;
    text-align: center;
    margin-inline: auto;
  }
  .collection-banner--left .collection-banner__content {
    align-items: flex-start;
    text-align: left;
  }
  .collection-banner--right .collection-banner__content {
    align-items: flex-end;
    text-align: right;
    margin-inline: auto 0;
  }

  /* Media variant — full-bleed image with overlay + inverted text */
  .collection-banner--media {
    position: relative;
    display: flex;
    align-items: center;
    min-height: var(--banner-height);
    overflow: hidden;
  }
  .collection-banner--media .collection-banner__description {
    color: color-mix(in srgb, var(--color-text) 82%, transparent);
  }

  .collection-banner__media {
    position: absolute;
    inset: 0;
    z-index: var(--z-base);
  }
  .collection-banner__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .collection-banner__overlay {
    position: absolute;
    inset: 0;
    background-color: var(--banner-overlay-color);
    opacity: var(--banner-overlay-alpha);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.collection-banner.name",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.collection-banner.settings.heading_tag.label",
      "info": "t:sections.collection-banner.settings.heading_tag.info",
      "options": [
        { "value": "h1", "label": "t:sections.collection-banner.settings.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.collection-banner.settings.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.collection-banner.settings.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.collection-banner.settings.heading_tag.options__4.label" },
        { "value": "p", "label": "t:sections.collection-banner.settings.heading_tag.options__5.label" }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.collection-banner.settings.heading_size.label",
      "info": "t:sections.collection-banner.settings.heading_size.info",
      "options": [
        { "value": "display", "label": "t:sections.collection-banner.settings.heading_size.options__1.label" },
        { "value": "xl", "label": "t:sections.collection-banner.settings.heading_size.options__2.label" },
        { "value": "lg", "label": "t:sections.collection-banner.settings.heading_size.options__3.label" },
        { "value": "md", "label": "t:sections.collection-banner.settings.heading_size.options__4.label" },
        { "value": "sm", "label": "t:sections.collection-banner.settings.heading_size.options__5.label" },
        { "value": "xs", "label": "t:sections.collection-banner.settings.heading_size.options__6.label" },
        { "value": "body", "label": "t:sections.collection-banner.settings.heading_size.options__7.label" }
      ],
      "default": "display"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "label": "t:sections.collection-banner.settings.show_collection_image.label",
      "info": "t:sections.collection-banner.settings.show_collection_image.info",
      "default": true
    },
    {
      "type": "select",
      "id": "banner_height",
      "label": "t:sections.collection-banner.settings.banner_height.label",
      "info": "t:sections.collection-banner.settings.banner_height.info",
      "options": [
        { "value": "small", "label": "t:sections.collection-banner.settings.banner_height.options__1.label" },
        { "value": "medium", "label": "t:sections.collection-banner.settings.banner_height.options__2.label" },
        { "value": "large", "label": "t:sections.collection-banner.settings.banner_height.options__3.label" }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 70,
      "step": 5,
      "unit": "%",
      "label": "t:sections.collection-banner.settings.overlay_opacity.label",
      "info": "t:sections.collection-banner.settings.overlay_opacity.info",
      "default": 30
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:sections.collection-banner.settings.overlay_color.label",
      "default": "#0A0705"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "t:sections.collection-banner.settings.show_description.label",
      "default": true
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:sections.collection-banner.settings.text_alignment.label",
      "options": [
        { "value": "left", "label": "t:sections.collection-banner.settings.text_alignment.options__1.label" },
        { "value": "center", "label": "t:sections.collection-banner.settings.text_alignment.options__2.label" },
        { "value": "right", "label": "t:sections.collection-banner.settings.text_alignment.options__3.label" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.collection-banner.settings.color_scheme.label",
      "info": "t:sections.collection-banner.settings.color_scheme.info",
      "options": [
        { "value": "cream", "label": "t:sections.collection-banner.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.collection-banner.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.collection-banner.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.collection-banner.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.collection-banner.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.collection-banner.settings.padding_top.label",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.collection-banner.settings.padding_bottom.label",
      "default": 80
    }
  ],
  "presets": [
    { "name": "t:sections.collection-banner.presets.name" }
  ]
}
{% endschema %}
