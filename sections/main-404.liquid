{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign heading_tag = section.settings.heading_tag | default: 'h1'
  assign heading_size = section.settings.heading_size | default: 'display'
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="main-404 color-scheme--{{ scheme }}">
  <div class="main-404__inner page-width page-width--narrow">
    <{{ heading_tag }} class="section-heading heading--{{ heading_size }}" data-animate>
      {{- '404.title' | t -}}
    </{{ heading_tag }}>
    <p class="main-404__text lead" data-animate data-animate-delay="2">
      {{- '404.not_found' | t -}}
    </p>
    <div class="main-404__actions" data-animate data-animate-delay="3">
      <a class="btn" href="{{ routes.root_url }}">{{ '404.back_to_shopping' | t }}</a>
    </div>
  </div>
</div>

{% stylesheet %}
  .main-404 { padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing)); }
  .main-404__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    text-align: center;
  }
  .main-404__text { max-width: 52ch; color: var(--color-muted); }
  .main-404__actions { margin-top: var(--space-3); }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main-404.name",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.main-404.settings.heading_tag.label",
      "info": "t:sections.main-404.settings.heading_tag.info",
      "options": [
        { "value": "h1", "label": "t:sections.main-404.settings.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.main-404.settings.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.main-404.settings.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.main-404.settings.heading_tag.options__4.label" },
        { "value": "p", "label": "t:sections.main-404.settings.heading_tag.options__5.label" }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.main-404.settings.heading_size.label",
      "info": "t:sections.main-404.settings.heading_size.info",
      "options": [
        { "value": "display", "label": "t:sections.main-404.settings.heading_size.options__1.label" },
        { "value": "xl", "label": "t:sections.main-404.settings.heading_size.options__2.label" },
        { "value": "lg", "label": "t:sections.main-404.settings.heading_size.options__3.label" },
        { "value": "md", "label": "t:sections.main-404.settings.heading_size.options__4.label" },
        { "value": "sm", "label": "t:sections.main-404.settings.heading_size.options__5.label" },
        { "value": "xs", "label": "t:sections.main-404.settings.heading_size.options__6.label" },
        { "value": "body", "label": "t:sections.main-404.settings.heading_size.options__7.label" }
      ],
      "default": "display"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.main-404.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.main-404.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.main-404.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.main-404.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.main-404.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.main-404.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.main-404.settings.padding_top.label",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.main-404.settings.padding_bottom.label",
      "default": 120
    }
  ],
  "presets": [
    { "name": "t:sections.main-404.presets.name" }
  ]
}
{% endschema %}
