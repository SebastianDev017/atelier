{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign menu = section.settings.menu
-%}

{%- comment -%}
  Localization captured once and emitted at the position the merchant chooses
  (top: below the logo; bottom: below the sidebar icons). Native localization
  forms with submit buttons, enhanced by <localization-dropdown> for the
  open/close behaviour. A matching language/country selector also lives in the
  footer (sections/footer.liquid), so the picker is reachable from both places.

  Merchant setup — to offer additional languages:
    1. Shopify Admin → Settings → Languages → Add language (publish each one).
    2. Online Store → Themes → ⋯ → Edit default theme content to review
       translations (this theme ships en/es/fr/de/it locale files).
    3. Toggle "Show language selector" on in this section (and/or the footer).
  The selector renders only when the store has more than one published
  language, so it stays hidden until step 1 is done.
{%- endcomment -%}
{%- liquid
  assign country_form_id = 'HeaderCountryForm-' | append: section.id
  assign country_list_id = 'HeaderCountryList-' | append: section.id
  assign language_form_id = 'HeaderLanguageForm-' | append: section.id
  assign language_list_id = 'HeaderLanguageList-' | append: section.id
  comment
    Only treat a selector as renderable when it is enabled AND the store
    actually has more than one country / language to switch between — otherwise
    the wrapper would paint an empty bordered box with nothing to choose.
  endcomment
  assign loc_show_country = false
  if section.settings.show_country_selector and localization.available_countries.size > 1
    assign loc_show_country = true
  endif
  assign loc_show_language = false
  if section.settings.show_language_selector and localization.available_languages.size > 1
    assign loc_show_language = true
  endif
-%}
{%- capture localization_block -%}
  {%- if loc_show_country or loc_show_language -%}
    <localization-dropdown>
      <div class="sidebar-localization">
        {%- if loc_show_country -%}
          {%- form 'localization', id: country_form_id -%}
            <div class="localization-selector">
              <button type="button" class="localization-selector__btn" data-localization-trigger aria-haspopup="true" aria-expanded="false" aria-controls="{{ country_list_id }}">
                {{ localization.country.iso_code }}
                <svg class="icon icon--chevron-down" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
              </button>
              <ul id="{{ country_list_id }}" class="localization-selector__list" aria-label="{{ 'localization.country_label' | t }}" hidden>
                {%- for country in localization.available_countries -%}
                  <li>
                    <button type="submit" name="country_code" value="{{ country.iso_code }}" class="localization-selector__option{% if country.iso_code == localization.country.iso_code %} is-active{% endif %}"{% if country.iso_code == localization.country.iso_code %} aria-current="true"{% endif %}>
                      {{ country.name }} ({{ country.currency.iso_code }})
                    </button>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endform -%}
        {%- endif -%}

        {%- if loc_show_language -%}
          {%- form 'localization', id: language_form_id -%}
            <div class="localization-selector">
              <button type="button" class="localization-selector__btn" data-localization-trigger aria-haspopup="true" aria-expanded="false" aria-controls="{{ language_list_id }}">
                {{ localization.language.iso_code | upcase }}
                <svg class="icon icon--chevron-down" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
              </button>
              <ul id="{{ language_list_id }}" class="localization-selector__list" aria-label="{{ 'localization.language_label' | t }}" hidden>
                {%- for language in localization.available_languages -%}
                  <li>
                    <button type="submit" name="locale_code" value="{{ language.iso_code }}" class="localization-selector__option{% if language.iso_code == localization.language.iso_code %} is-active{% endif %}"{% if language.iso_code == localization.language.iso_code %} aria-current="true"{% endif %}>
                      {{ language.endonym_name }}
                    </button>
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endform -%}
        {%- endif -%}
      </div>
    </localization-dropdown>
  {%- endif -%}
{%- endcapture -%}

{%- comment -%} Sticky + full-height column rules live on the section wrapper (the real grid item of .site-layout), using the raw style-tag pattern every other section uses. {%- endcomment -%}
<style>
  #shopify-section-{{ section.id }} { grid-column: 1; }
  @media (min-width: 769px) {
    #shopify-section-{{ section.id }} {
      position: sticky;
      top: 0;
      height: 100svh;
      overflow-y: auto;
      overscroll-behavior: contain;
      /* position:sticky creates a stacking context; without a z-index it sits
         below .site-main (a later grid item), which would trap the fixed
         search takeover behind page content. Lift the whole header context
         above main content, but keep it below the cart overlay (--z-overlay
         200) so an open cart still dims the sidebar. */
      z-index: var(--z-header);
    }
  }
</style>

<header-component
  class="sidebar color-scheme--{{ scheme }}{% if section.settings.show_border %} sidebar--bordered{% endif %}"
>
  {%- comment -%}
    Mobile-only trigger. Lives outside the sliding panel and is fixed to the
    top-left so it stays put while the panel translates off-canvas.
  {%- endcomment -%}
  <button
    type="button"
    class="sidebar__toggle header__icon-btn"
    data-menu-toggle
    aria-expanded="false"
    aria-controls="SidebarPanel-{{ section.id }}"
    aria-label="{{ 'accessibility.open_menu' | t }}"
  >
    {% render 'icon', name: 'menu' %}
  </button>

  {%- comment -%}
    Mobile-only cart trigger, fixed to the top-RIGHT corner (mirrors the menu
    toggle top-left). Outside the sliding panel so it stays put while the panel
    translates off-canvas. Opens the cart drawer via the shared [data-cart-toggle]
    handler; the badge updates through [data-cart-count] like the in-drawer cart.
  {%- endcomment -%}
  <a
    class="sidebar__cart-toggle header__icon-btn"
    href="{{ routes.cart_url }}"
    data-cart-toggle
    aria-label="{{ 'general.cart' | t }}"
  >
    {% render 'icon', name: 'cart' %}
    <span class="sidebar__cart-count{% if cart.item_count == 0 %} is-empty{% endif %}" data-cart-count aria-hidden="true">{{ cart.item_count }}</span>
  </a>

  <div class="sidebar__panel" id="SidebarPanel-{{ section.id }}" data-menu-drawer>
    <div class="sidebar__head">
      {% render 'header-logo' %}
      <button type="button" class="sidebar__search-hint" data-search-palette-open aria-label="{{ 'search.title' | t }}">
        {% render 'icon', name: 'search' %}<kbd>/</kbd>
      </button>
      <button
        type="button"
        class="sidebar__close header__icon-btn"
        data-menu-close
        aria-label="{{ 'accessibility.close_menu' | t }}"
      >
        {% render 'icon', name: 'close' %}
      </button>
    </div>

    {%- if section.settings.localization_position == 'top' -%}{{ localization_block }}{%- endif -%}

    {%- if menu != blank -%}
      <nav class="sidebar__nav" aria-label="{{ 'general.menu' | t }}">
        <div class="sidebar__progress-track" aria-hidden="true"><div class="sidebar__progress-fill"></div></div>
        {% render 'header-menu', menu: menu, section_id: section.id %}
      </nav>
    {%- endif -%}

    <div class="sidebar__foot">
      <div class="sidebar__actions">
        {%- if section.settings.show_search -%}
          <button
            type="button"
            class="header__icon-btn"
            data-search-toggle
            aria-expanded="false"
            aria-controls="SearchModal-{{ section.id }}"
            aria-label="{{ 'general.search' | t }}"
          >
            {% render 'icon', name: 'search' %}
          </button>
        {%- endif -%}

        {%- if shop.customer_accounts_enabled and section.settings.show_account -%}
          <a
            class="header__icon-btn sidebar__account"
            href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
            aria-label="{{ 'general.account' | t }}"
          >
            {% render 'icon', name: 'account' %}
          </a>
        {%- endif -%}

        <a
          class="header__icon-btn sidebar__cart"
          href="{{ routes.cart_url }}"
          data-cart-toggle
          aria-label="{{ 'general.cart' | t }}"
        >
          {% render 'icon', name: 'cart' %}
          <span
            class="sidebar__cart-count{% if cart.item_count == 0 %} is-empty{% endif %}"
            data-cart-count
            aria-hidden="true"
          >{{ cart.item_count }}</span>
          <span class="visually-hidden" data-cart-count-text aria-live="polite">{{ 'cart.item_count' | t: count: cart.item_count }}</span>
        </a>
      </div>

      {%- unless section.settings.localization_position == 'top' -%}{{ localization_block }}{%- endunless -%}
    </div>
  </div>

  {%- comment -%} Search modal — slides down as a top sheet, mutually exclusive with the menu {%- endcomment -%}
  {%- if section.settings.show_search -%}
    <div class="sidebar__search" id="SearchModal-{{ section.id }}" data-search-modal>
      <div class="sidebar__search-inner">
        {% render 'predictive-search', id: section.id %}
        <button
          type="button"
          class="header__icon-btn sidebar__search-close"
          data-menu-close
          aria-label="{{ 'accessibility.close_search' | t }}"
        >
          {% render 'icon', name: 'close' %}
        </button>
      </div>
    </div>
  {%- endif -%}

  <div class="overlay sidebar__overlay" data-header-overlay tabindex="-1"></div>
</header-component>

{%- if section.settings.show_search -%}
  <script src="{{ 'search.js' | asset_url }}" defer></script>
{%- endif -%}

{% stylesheet %}
  /* ---------- Sidebar shell ---------- */
  .sidebar {
    display: block;
    min-height: 100%;
    background-color: var(--color-bg);
    color: var(--color-text);
  }

  .sidebar__panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    min-height: 100svh;
    padding: 20px var(--sidebar-pad, 28px);
    background-color: var(--color-bg);
  }

  .sidebar__head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .sidebar__search-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    transition: color var(--duration-fast) var(--ease-editorial);
  }
  .sidebar__search-hint svg { width: 16px; height: 16px; }
  .sidebar__search-hint kbd { border: 1px solid var(--color-border); padding: 0 5px; line-height: 1.4; }
  .sidebar__search-hint:hover { color: var(--color-text); }

  .sidebar__nav { flex: 1 1 auto; position: relative; padding-left: var(--space-4); }
  /* Real-time scroll-progress line down the nav (GSAP initScrollProgress). */
  .sidebar__progress-track {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--color-border);
  }
  .sidebar__progress-fill {
    position: absolute;
    inset: 0;
    background: var(--color-text);
    transform: scaleY(0);
    transform-origin: top center;
  }

  /* ---------- Sidebar index navigation ---------- */
  .sidebar-nav__list { display: flex; flex-direction: column; gap: var(--space-5); }
  .nav-link {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    color: var(--color-text);
    transition: color var(--duration-fast) var(--ease-editorial);
  }
  .nav-link:hover { color: var(--color-accent-local); }
  .nav-link::after {
    content: '';
    display: block;
    height: 1px;
    width: 0;
    background-color: currentColor;
    transition: width 0.6s cubic-bezier(0.25, 0.1, 0, 1);
  }
  .nav-link:hover::after,
  .nav-link[aria-current="page"]::after { width: 100%; }
  .nav-link__text {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1.2;
  }

  .sidebar-nav__sub {
    display: flex;
    flex-direction: column;
    margin-top: var(--space-1);
    padding-left: calc(1.7em + var(--space-3));
  }
  .sidebar-nav__sublink {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 2px;
    min-height: 32px;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-muted);
    transition: color var(--duration-fast) var(--ease-editorial);
  }
  /* Underline-on-hover, mirroring the main .nav-link animation. */
  .sidebar-nav__sublink::after {
    content: '';
    display: block;
    height: 1px;
    width: 0;
    background-color: currentColor;
    transition: width 0.5s cubic-bezier(0.25, 0.1, 0, 1);
  }
  .sidebar-nav__sublink:hover,
  .sidebar-nav__sublink[aria-current="page"] { color: var(--color-text); }
  .sidebar-nav__sublink:hover::after,
  .sidebar-nav__sublink[aria-current="page"]::after { width: 100%; }

  /* Level 3 — grandchild links nested under a level-2 link: deeper indent, smaller, fainter. */
  .sidebar-nav__sub--level-3 {
    margin-top: 2px;
    padding-left: var(--space-4);
  }
  .sidebar-nav__sublink--level-3 {
    font-size: var(--text-xs);
    opacity: 0.85;
  }

  .sidebar__foot {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding-top: var(--space-6);
  }
  .sidebar--bordered .sidebar__foot { border-top: 1px solid var(--color-border); }

  .sidebar__actions {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-inline-start: -10px;
  }

  /* ---------- Logo ---------- */
  .header__logo { display: inline-flex; align-items: center; line-height: 1; }
  .header__logo-text {
    font-family: var(--font-heading);
    font-weight: var(--font-heading-weight);
    font-size: var(--text-lg);
    letter-spacing: var(--tracking-wide);
    text-transform: var(--uppercase-headings);
  }
  .header__logo img { width: var(--logo-width, 150px); height: auto; }

  /* ---------- Cart count ---------- */
  .sidebar__cart { position: relative; }
  .sidebar__cart-count {
    position: absolute;
    top: 4px;
    right: 2px;
    min-width: 1.05rem;
    height: 1.05rem;
    padding: 0 0.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-text);
    color: var(--color-bg);
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 600;
    line-height: 1;
  }
  .sidebar__cart-count.is-empty { display: none; }

  /* ---------- Localization selectors ---------- */
  .sidebar-localization {
    padding: 1rem 0;
    border-top: 1px solid var(--color-border, #E5DDD0);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .localization-selector { position: relative; }
  .localization-selector__btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted, #A0826D);
    background: none;
    border: none;
    padding: 0;
    cursor: none;
    transition: color 0.2s ease;
  }
  .localization-selector__btn:hover { color: var(--color-text, #2C1810); }
  .localization-selector__btn .icon { width: 12px; height: 12px; }
  .localization-selector__list {
    position: absolute;
    bottom: calc(100% + 0.5rem);
    left: 0;
    background-color: var(--color-bg, #FAF7F2);
    border: 1px solid var(--color-border, #E5DDD0);
    min-width: 160px;
    padding: 0.5rem 0;
    z-index: 100;
  }
  .localization-selector__list[hidden] { display: none; }
  .localization-selector__option {
    display: block;
    width: 100%;
    padding: 0.4rem 0.875rem;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--color-text, #2C1810);
    background: none;
    border: none;
    text-align: left;
    cursor: none;
    transition: background-color 0.15s ease;
  }
  .localization-selector__option:hover { background-color: var(--color-bg-secondary, #F0EAE0); }
  .localization-selector__option.is-active { font-weight: 600; }

  /* ---------- Mobile trigger + close (hidden on desktop) ---------- */
  .sidebar__toggle,
  .sidebar__cart-toggle,
  .sidebar__close { display: none; }

  /* ---------- Search full-screen takeover ----------
     Sits above the sidebar and everything else (but below the custom cursor
     at z 99997 so the cursor stays visible). Opaque ground, centred input. */
  .sidebar__search {
    position: fixed;
    inset: 0;
    z-index: 9990;
    background-color: var(--color-bg, #FAF7F2);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 6rem;
    padding-inline: var(--page-margin, 1.5rem);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-0.5rem);
    transition: opacity var(--duration-base) var(--ease-editorial),
                transform var(--duration-base) var(--ease-editorial),
                visibility var(--duration-base);
  }
  .sidebar.header--search-open .sidebar__search { opacity: 1; visibility: visible; transform: translateY(0); }
  .sidebar__search-inner {
    width: min(640px, 100%);
    max-width: 640px;
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }
  .sidebar__search-inner predictive-search { flex: 1; }
  /* Editorial search field: large serif input on the open canvas. */
  .sidebar__search .search__input {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    padding-block: var(--space-4);
  }
  .sidebar__search-close {
    position: absolute;
    top: 2rem;
    right: var(--page-margin, 1.5rem);
  }

  /* ---------- Overlay ---------- */
  .sidebar__overlay { z-index: var(--z-overlay); }
  .sidebar.header--menu-open .sidebar__overlay,
  .sidebar.header--search-open .sidebar__overlay { opacity: 1; visibility: visible; }

  /* ---------- Desktop divider ----------
     The sticky and full-height rules are applied to the section wrapper
     element in the style block at the top of this file, so they sit on the
     real grid column. .sidebar fills that column (min-height:100%), so its
     right border spans the full height. */
  @media (min-width: 769px) {
    .sidebar--bordered { border-right: 1px solid var(--color-border); }

    /* Center the whole nav block (its left line + left-aligned items) as one
       unit by shrinking it to its content width and centering it in the panel.
       Keep it vertically compact (flex:0) so the block and its line stop
       stretching down into the empty space below the last item. Item text
       stays left-aligned; logo, language selector, dividers and the bottom
       icon row are untouched. */
    .sidebar__nav { flex: 0 0 auto; align-self: center; }
    .sidebar-nav__sub { padding-left: 0; }
  }

  /* ---------- Mobile: off-canvas drawer ---------- */
  @media (max-width: 768px) {
    .sidebar { display: contents; }

    .sidebar__toggle {
      display: inline-flex;
      position: fixed;
      top: var(--space-3);
      left: var(--space-3);
      z-index: var(--z-header);
      /* Use the scheme-resolved tokens (which carry fallbacks) so the button
         keeps a solid background even when the brand color settings are nil. */
      background-color: var(--color-bg);
      color: var(--color-text);
      box-shadow: 0 0 0 1px var(--color-border);
    }
    /* Cart trigger mirrors the menu toggle, pinned to the opposite (right) corner. */
    .sidebar__cart-toggle {
      display: inline-flex;
      position: fixed;
      top: var(--space-3);
      right: var(--space-3);
      z-index: var(--z-header);
      background-color: var(--color-bg);
      color: var(--color-text);
      box-shadow: 0 0 0 1px var(--color-border);
    }
    .sidebar__close { display: inline-flex; }

    .sidebar__panel {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      /* Full-screen drawer on mobile with a solid scheme background. */
      width: 100%;
      z-index: var(--z-drawer);
      overflow-y: auto;
      transform: translateX(-100%);
      transition: transform var(--duration-base) var(--ease-editorial);
    }
    .sidebar.header--menu-open .sidebar__panel { transform: translateX(0); }

    /* Meet the 44px touch-target minimum in the off-canvas drawer */
    .nav-link,
    .sidebar-nav__sublink { min-height: 44px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.header.name",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:sections.header.settings.menu.label",
      "default": "main-menu",
      "info": "t:sections.header.settings.menu.info"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "t:sections.header.settings.show_search.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "t:sections.header.settings.show_account.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "t:sections.header.settings.show_border.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__1.content"
    },
    {
      "type": "checkbox",
      "id": "show_country_selector",
      "label": "t:sections.header.settings.show_country_selector.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_language_selector",
      "label": "t:sections.header.settings.show_language_selector.label",
      "default": true
    },
    {
      "type": "select",
      "id": "localization_position",
      "label": "t:sections.header.settings.localization_position.label",
      "options": [
        { "value": "bottom", "label": "t:sections.header.settings.localization_position.options__1.label" },
        { "value": "top", "label": "t:sections.header.settings.localization_position.options__2.label" }
      ],
      "default": "bottom"
    },
    {
      "type": "header",
      "content": "t:sections.header.settings.header__2.content"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.header.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.header.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.header.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.header.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.header.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.header.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    }
  ]
}
{% endschema %}
