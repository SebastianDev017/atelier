{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign limit = section.settings.products_to_show
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --grid-columns: {{ section.settings.columns_desktop }};
    --grid-columns-mobile: 2;
  }
</style>

<product-recommendations
  class="recommendations color-scheme--{{ scheme }}"
  data-section-id="{{ section.id }}"
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ limit }}&intent=related"
>
  {%- if recommendations.performed and recommendations.products_count > 0 -%}
    <div class="page-width">
      <div class="section-header section-header--center">
        <h2 class="h3" data-animate>{{ section.settings.heading | escape }}</h2>
      </div>
      <div class="product-grid">
        {%- for product in recommendations.products limit: limit -%}
          <div data-animate data-animate-delay="{{ forloop.index | modulo: 5 | plus: 1 }}">
            {% render 'product-card', product: product, quick_add_style: section.settings.quick_add_style %}
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</product-recommendations>

{% stylesheet %}
  .recommendations { padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing)); }
  .recommendations:empty { display: none; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product-recommendations.name",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "t:sections.product-recommendations.settings.heading.label", "default": "You may also like" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 8, "step": 1, "label": "t:sections.product-recommendations.settings.products_to_show.label", "default": 4 },
    {
      "type": "select",
      "id": "quick_add_style",
      "label": "t:sections.product-recommendations.settings.quick_add_style.label",
      "options": [
        { "value": "hover", "label": "t:sections.product-recommendations.settings.quick_add_style.options__1.label" },
        { "value": "always", "label": "t:sections.product-recommendations.settings.quick_add_style.options__2.label" }
      ],
      "default": "hover"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "t:sections.product-recommendations.settings.columns_desktop.label",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.product-recommendations.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.product-recommendations.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.product-recommendations.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.product-recommendations.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.product-recommendations.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.product-recommendations.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.product-recommendations.settings.padding_top.label", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.product-recommendations.settings.padding_bottom.label", "default": 80 }
  ]
}
{% endschema %}
