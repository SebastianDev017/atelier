<div class="password color-scheme--cream">
  <div class="password__inner page-width page-width--narrow">
    <div class="password__brand" data-animate>
      {% render 'header-logo' %}
    </div>

    <h1 class="password__title h1" data-animate data-animate-delay="2">
      {{ section.settings.heading | default: shop.name | escape }}
    </h1>

    {%- if section.settings.subheading != blank -%}
      <p class="password__subheading lead" data-animate data-animate-delay="3">{{ section.settings.subheading | escape }}</p>
    {%- elsif shop.password_message != blank -%}
      <div class="password__message prose" data-animate data-animate-delay="3">{{ shop.password_message }}</div>
    {%- endif -%}

    <div class="password__form" data-animate data-animate-delay="4">
      {%- form 'storefront_password' -%}
        {%- if form.errors -%}
          <p class="form-status form-status--error" role="alert">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <label class="visually-hidden" for="password-input">{{ 'password.password_label' | t }}</label>
        <div class="password__row">
          <input
            class="input"
            type="password"
            name="password"
            id="password-input"
            placeholder="{{ 'password.password_placeholder' | t }}"
            autocomplete="current-password"
            required
          >
          <button type="submit" class="btn">{{ 'password.enter' | t }}</button>
        </div>
      {%- endform -%}
    </div>

    <p class="password__owner caption" data-animate data-animate-delay="5">
      {{ 'password.powered_by' | t }} {{ powered_by_link }}
    </p>
  </div>
</div>

{% stylesheet %}
  .password { min-height: 100svh; display: flex; align-items: center; justify-content: center; padding-block: var(--space-16); }
  .password__inner { display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--space-5); }
  .password__title { margin-top: var(--space-4); }
  .password__subheading,
  .password__message { color: var(--color-muted); max-width: 44ch; }
  .password__form { width: 100%; max-width: 28rem; margin-top: var(--space-4); }
  .password__row { display: flex; gap: var(--space-2); }
  .password__row .input { flex: 1; }
  .password__owner { margin-top: var(--space-6); }
{% endstylesheet %}

{% schema %}
{
  "name": "Password",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Opening soon" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Sign up to be the first to know when we launch." }
  ]
}
{% endschema %}
