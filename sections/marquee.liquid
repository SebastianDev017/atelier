{%- comment -%}
  Scrolling text marquee — pure-CSS infinite horizontal scroll.
  Mirrors rich-text.liquid: inline <style> carries instance values only,
  a color-scheme--* wrapper paints the background, {% stylesheet %} holds
  all component CSS (no Liquid), and motion is disabled for
  prefers-reduced-motion. The text is repeated for a seamless -50% loop;
  duplicate copies are aria-hidden so it is read once.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'invert'
  assign marquee_text = section.settings.text | escape

  assign marquee_direction = 'normal'
  if section.settings.direction == 'right'
    assign marquee_direction = 'reverse'
  endif

  assign marquee_size = 'var(--text-2xl)'
  case section.settings.size
    when 'sm'
      assign marquee_size = 'var(--text-lg)'
    when 'lg'
      assign marquee_size = 'var(--text-4xl)'
  endcase
-%}

{%- if section.settings.text != blank -%}
  <style>
    #shopify-section-{{ section.id }} {
      --pt: {{ section.settings.padding_top }}px;
      --pb: {{ section.settings.padding_bottom }}px;
      --marquee-speed: {{ section.settings.speed }}s;
      --marquee-direction: {{ marquee_direction }};
      --marquee-size: {{ marquee_size }};
    }
  </style>

  <div class="marquee section--full-bleed color-scheme--{{ scheme }}">
    <div class="marquee__clip">
      <div class="marquee__track">
        <span class="marquee__item">{{ marquee_text }}</span>
        <span class="marquee__item" aria-hidden="true">{{ marquee_text }}</span>
        <span class="marquee__item" aria-hidden="true">{{ marquee_text }}</span>
        <span class="marquee__item" aria-hidden="true">{{ marquee_text }}</span>
      </div>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .marquee {
    padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing));
  }
  .marquee__clip {
    overflow: hidden;
  }
  .marquee__track {
    display: flex;
    width: max-content;
    animation: marquee-scroll var(--marquee-speed) linear infinite;
    animation-direction: var(--marquee-direction);
  }
  .marquee__track:hover {
    animation-play-state: paused;
  }
  .marquee__item {
    flex: 0 0 auto;
    padding-inline: var(--space-6);
    font-family: var(--font-heading);
    font-style: italic;
    font-weight: 300;
    /* Honor the schema 'size' control (sm/md/lg -> --marquee-size set inline). */
    font-size: var(--marquee-size, clamp(1rem, 2.5vw, 1.5rem));
    line-height: var(--leading-tight);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  @keyframes marquee-scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .marquee__track {
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.marquee.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "t:sections.marquee.settings.text.label",
      "default": "Considered Objects · Artisan Crafted · Made to Last · Objects for the Modern Home ·"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "t:sections.marquee.settings.speed.label",
      "info": "t:sections.marquee.settings.speed.info",
      "default": 30
    },
    {
      "type": "select",
      "id": "direction",
      "label": "t:sections.marquee.settings.direction.label",
      "options": [
        { "value": "left", "label": "t:sections.marquee.settings.direction.options__1.label" },
        { "value": "right", "label": "t:sections.marquee.settings.direction.options__2.label" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "size",
      "label": "t:sections.marquee.settings.size.label",
      "options": [
        { "value": "sm", "label": "t:sections.marquee.settings.size.options__1.label" },
        { "value": "md", "label": "t:sections.marquee.settings.size.options__2.label" },
        { "value": "lg", "label": "t:sections.marquee.settings.size.options__3.label" }
      ],
      "default": "md"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.marquee.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.marquee.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.marquee.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.marquee.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.marquee.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.marquee.settings.color_scheme.options__5.label" }
      ],
      "default": "invert"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.marquee.settings.padding_top.label",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.marquee.settings.padding_bottom.label",
      "default": 48
    }
  ],
  "presets": [
    { "name": "t:sections.marquee.presets.name" }
  ]
}
{% endschema %}
