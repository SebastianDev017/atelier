{%- comment -%}
  Featured product — a full buy box (55% media / 45% sticky content) with a bundle
  upsell beneath the buttons. Self-contained interactivity lives in
  assets/featured-product.js (variant switching + thumbnail swap) rather than
  product.js, because product.js's price fetch is keyed to the page URL's product
  and would not reflect a section-picked product's variant. Per-variant price HTML
  is pre-rendered server-side so switching is correct + instant.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign fp = section.settings.product
  assign fp_variant = fp.selected_or_first_available_variant
  assign form_id = 'FeaturedProductForm-' | append: section.id
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="featured-product color-scheme--{{ scheme }}" data-featured-product>
  <div class="page-width">
    {%- if fp == blank -%}
      {%- if request.design_mode -%}<p class="featured-product__empty">{{ 'products.featured_empty' | t }}</p>{%- endif -%}
    {%- else -%}
      <div class="featured-product__grid">
        {%- comment -%} ---- Media (55%) ---- {%- endcomment -%}
        <div class="featured-product__media">
          <div class="fp__main" data-reveal>
            {%- if fp.featured_media -%}
              <img class="fp__main-img" data-fp-main-img
                src="{{ fp.featured_media | image_url: width: 1200 }}"
                srcset="{{ fp.featured_media | image_url: width: 600 }} 600w, {{ fp.featured_media | image_url: width: 1200 }} 1200w, {{ fp.featured_media | image_url: width: 1600 }} 1600w"
                sizes="(min-width: 750px) 55vw, 100vw"
                alt="{{ fp.featured_media.alt | default: fp.title | escape }}" width="1200" height="1500" loading="lazy">
            {%- else -%}
              <span class="fp__main-img placeholder">{{ 'product-1' | placeholder_svg_tag: 'placeholder' }}</span>
            {%- endif -%}
          </div>
          {%- if fp.media.size > 1 -%}
            <div class="fp__thumbs">
              {%- for media in fp.media limit: 4 -%}
                <button type="button" class="fp__thumb{% if forloop.first %} is-active{% endif %}" data-fp-thumb="{{ media | image_url: width: 1200 }}" aria-label="{{ fp.title | escape }} — {{ forloop.index }}">
                  <img src="{{ media | image_url: width: 200 }}" alt="" width="80" height="100" loading="lazy">
                </button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>

        {%- comment -%} ---- Content (45%, sticky) ---- {%- endcomment -%}
        <div class="featured-product__content">
          {%- if section.settings.heading != blank -%}
            <span class="fp__eyebrow eyebrow">{{ section.settings.heading | escape }}</span>
          {%- endif -%}
          {%- if section.settings.show_vendor and fp.vendor != blank -%}
            <span class="fp__vendor">{{ fp.vendor | escape }}</span>
          {%- endif -%}
          <h2 class="fp__title" data-split>{{ fp.title | escape }}</h2>

          <div class="fp__price" data-fp-price>{% render 'price', product: fp, variant: fp_variant, class: 'price--large' %}</div>

          {%- if fp.description != blank -%}
            <p class="fp__desc">{{ fp.description | strip_html | truncate: 200 }}</p>
          {%- endif -%}

          {%- comment -%} Variant pills (outside the form so they aren't submitted). {%- endcomment -%}
          {%- unless fp.has_only_default_variant -%}
            <div class="fp__variants">
              {%- for option in fp.options_with_values -%}
                <fieldset class="fp__option" data-fp-option-group data-fp-option-position="{{ option.position }}">
                  <legend class="fp__option-label">
                    <span>{{ option.name | escape }}</span>
                    <span class="fp__option-selected" data-fp-option-selected>{{ option.selected_value | escape }}</span>
                  </legend>
                  <div class="fp__option-values">
                    {%- for value in option.values -%}
                      {%- liquid
                        assign value_available = false
                        for v in fp.variants
                          if v.available and v.options contains value
                            assign value_available = true
                            break
                          endif
                        endfor
                      -%}
                      <label class="fp__pill{% unless value_available %} fp__pill--soldout{% endunless %}">
                        <input type="radio" name="fp-option-{{ option.position }}" value="{{ value | escape }}" data-fp-option {% if option.selected_value == value %}checked{% endif %}>
                        <span>{{ value | escape }}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                </fieldset>
              {%- endfor -%}
            </div>
          {%- endunless -%}

          <product-form class="fp__form" data-product-form>
            {%- form 'product', fp, id: form_id, novalidate: 'novalidate', class: 'product-form' -%}
              <input type="hidden" name="id" value="{{ fp_variant.id }}" data-fp-variant-id {% unless fp_variant.available %}disabled{% endunless %}>

              <div class="fp__quantity">
                <label class="label" for="fp-qty-{{ section.id }}">{{ 'products.quantity' | t }}</label>
                <quantity-input class="quantity">
                  <button type="button" class="quantity__button" data-quantity-action="decrease" aria-label="{{ 'accessibility.decrease_quantity' | t }}">{% render 'icon', name: 'minus' %}</button>
                  <input class="quantity__input" id="fp-qty-{{ section.id }}" type="number" name="quantity" value="1" min="1" inputmode="numeric">
                  <button type="button" class="quantity__button" data-quantity-action="increase" aria-label="{{ 'accessibility.increase_quantity' | t }}">{% render 'icon', name: 'plus' %}</button>
                </quantity-input>
              </div>

              <div class="fp__buy" data-buy-button>
                <button type="submit" name="add" class="btn btn--full btn--large" data-fp-add data-add-text="{{ 'products.add_to_cart' | t | escape }}" data-sold-text="{{ 'products.sold_out' | t | escape }}" {% unless fp_variant.available %}disabled{% endunless %}>
                  <span data-fp-add-label>{%- if fp_variant.available -%}{{ 'products.add_to_cart' | t }}{%- else -%}{{ 'products.sold_out' | t }}{%- endif -%}</span>
                </button>
                {%- if fp.available -%}{{ form | payment_button }}{%- endif -%}
              </div>

              <div class="product-form__error" role="alert" data-form-error hidden></div>
            {%- endform -%}
          </product-form>

          {%- if section.settings.show_trust_badges -%}
            <ul class="fp__trust">
              <li class="fp__trust-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="1" y="5" width="13" height="11" rx="1"/><path d="M14 9h4l3 3v4h-7z"/><circle cx="6" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>
                <span>{{ 'products.trust.shipping' | t }}</span>
              </li>
              <li class="fp__trust-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M3 12a9 9 0 1 1 3 6.7"/><path d="M3 20v-5h5"/></svg>
                <span>{{ 'products.trust.returns' | t }}</span>
              </li>
              <li class="fp__trust-item">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="4" y="10" width="16" height="11" rx="1"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
                <span>{{ 'products.trust.secure' | t }}</span>
              </li>
            </ul>
          {%- endif -%}

          {%- comment -%} ---- Bundle upsell ---- {%- endcomment -%}
          {%- if section.settings.show_bundle -%}
            <div class="featured-product__bundle">
              <p class="featured-product__bundle-heading">{{ section.settings.bundle_heading | default: 'Complete your purchase' | escape }}</p>
              <div class="featured-product__bundle-list">
                {%- assign shown = ',' -%}
                {%- assign bcount = 0 -%}
                {%- for collection in fp.collections -%}
                  {%- for p in collection.products -%}
                    {%- if bcount >= 3 -%}{%- break -%}{%- endif -%}
                    {%- assign hk = p.handle | prepend: ',' | append: ',' -%}
                    {%- unless p.handle == fp.handle or shown contains hk -%}
                      {%- assign shown = shown | append: p.handle | append: ',' -%}
                      {%- assign bcount = bcount | plus: 1 -%}
                      {%- render 'bundle-item', product: p, layout: 'row' -%}
                    {%- endunless -%}
                  {%- endfor -%}
                  {%- if bcount >= 3 -%}{%- break -%}{%- endif -%}
                {%- endfor -%}
                {%- if bcount < 3 -%}
                  {%- for p in collections.all.products -%}
                    {%- if bcount >= 3 -%}{%- break -%}{%- endif -%}
                    {%- assign hk = p.handle | prepend: ',' | append: ',' -%}
                    {%- unless p.handle == fp.handle or shown contains hk -%}
                      {%- assign shown = shown | append: p.handle | append: ',' -%}
                      {%- assign bcount = bcount | plus: 1 -%}
                      {%- render 'bundle-item', product: p, layout: 'row' -%}
                    {%- endunless -%}
                  {%- endfor -%}
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%} Per-variant data for featured-product.js: pre-rendered price HTML + variant image. {%- endcomment -%}
      <script type="application/json" data-fp-variants>
        [
          {%- for v in fp.variants -%}
            {%- capture vprice -%}{% render 'price', product: fp, variant: v, class: 'price--large' %}{%- endcapture -%}
            {
              "id": {{ v.id }},
              "available": {{ v.available }},
              "options": {{ v.options | json }},
              "price_html": {{ vprice | json }}{% if v.image %},
              "image": {{ v.image | image_url: width: 1200 | json }}{% endif %}
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        ]
      </script>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .featured-product { padding-block: var(--pt, var(--space-24)) var(--pb, var(--space-24)); }
  .featured-product__empty { text-align: center; color: var(--color-muted); padding-block: var(--space-16); }
  .featured-product__grid { display: grid; grid-template-columns: 55% 45%; gap: var(--space-12); align-items: start; }

  .fp__main { overflow: hidden; aspect-ratio: 3 / 4; background: var(--color-media); }
  .fp__main-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .fp__thumbs { display: flex; gap: var(--space-3); margin-top: var(--space-3); }
  .fp__thumb { width: 72px; aspect-ratio: 4 / 5; padding: 0; border: 1px solid transparent; background: var(--color-media); cursor: pointer; overflow: hidden; transition: border-color var(--duration-fast) var(--ease-editorial); }
  .fp__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .fp__thumb.is-active { border-color: var(--color-text); }

  .featured-product__content { position: sticky; top: var(--space-8); display: flex; flex-direction: column; gap: var(--space-4); padding-block: var(--space-4); }
  .fp__eyebrow { color: var(--color-muted); }
  .fp__vendor { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-muted); }
  .fp__title { margin: 0; font-size: clamp(2rem, 4vw, 3.25rem); font-weight: 300; line-height: 1.04; }
  .fp__price { font-size: var(--text-lg); }
  .fp__desc { color: var(--color-muted); max-width: 48ch; }

  .fp__variants { display: flex; flex-direction: column; gap: var(--space-4); }
  .fp__option { border: 0; margin: 0; padding: 0; min-width: 0; }
  .fp__option-label { display: flex; gap: var(--space-2); font-size: var(--text-sm); margin-bottom: var(--space-2); padding: 0; }
  .fp__option-selected { color: var(--color-muted); }
  .fp__option-values { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .fp__pill { position: relative; cursor: pointer; }
  .fp__pill input { position: absolute; opacity: 0; inset: 0; margin: 0; cursor: pointer; }
  .fp__pill span { display: inline-flex; align-items: center; justify-content: center; min-width: 2.75rem; padding: 0.5rem 0.9rem; border: 1px solid var(--color-border); font-size: var(--text-sm); transition: border-color var(--duration-fast) var(--ease-editorial), background var(--duration-fast) var(--ease-editorial), color var(--duration-fast) var(--ease-editorial); }
  .fp__pill input:checked + span { background: var(--color-text); border-color: var(--color-text); color: var(--color-bg); }
  .fp__pill input:focus-visible + span { outline: 2px solid var(--color-accent); outline-offset: 2px; }
  .fp__pill--soldout span { text-decoration: line-through; opacity: 0.4; }

  .fp__quantity { display: flex; flex-direction: column; gap: var(--space-2); }
  .fp__buy { display: flex; flex-direction: column; gap: var(--space-3); }
  .product-form__error { color: #c0392b; font-size: var(--text-sm); }
  .product-form__error[hidden] { display: none; }

  .fp__trust { list-style: none; margin: 0; padding: var(--space-3) 0 0; display: flex; flex-wrap: wrap; gap: var(--space-5); }
  .fp__trust-item { display: inline-flex; align-items: center; gap: var(--space-2); font-size: var(--text-xs); color: var(--color-muted); }
  .fp__trust-item svg { flex-shrink: 0; }

  .featured-product__bundle { margin-top: var(--space-6); padding-top: var(--space-6); border-top: 1px solid var(--color-border); }
  .featured-product__bundle-heading { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-muted); margin: 0 0 var(--space-3); }
  .featured-product__bundle-list { display: flex; flex-direction: column; }
  .featured-product__bundle-list .bundle__item--row:last-child { border-bottom: 0; }

  @media (max-width: 749px) {
    .featured-product__grid { grid-template-columns: 1fr; gap: var(--space-6); }
    .featured-product__content { position: relative; top: 0; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.featured-product.name",
  "tag": "section",
  "settings": [
    { "type": "product", "id": "product", "label": "t:sections.featured-product.settings.product.label" },
    { "type": "text", "id": "heading", "label": "t:sections.featured-product.settings.heading.label" },
    { "type": "checkbox", "id": "show_vendor", "label": "t:sections.featured-product.settings.show_vendor.label", "default": true },
    { "type": "checkbox", "id": "show_trust_badges", "label": "t:sections.featured-product.settings.show_trust_badges.label", "default": true },
    { "type": "header", "content": "t:sections.featured-product.settings.header__bundle.content" },
    { "type": "checkbox", "id": "show_bundle", "label": "t:sections.featured-product.settings.show_bundle.label", "default": true },
    { "type": "text", "id": "bundle_heading", "label": "t:sections.featured-product.settings.bundle_heading.label", "default": "Complete your purchase" },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.featured-product.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.featured-product.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.featured-product.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.featured-product.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.featured-product.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.featured-product.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "t:sections.featured-product.settings.padding_top.label", "default": 96 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "t:sections.featured-product.settings.padding_bottom.label", "default": 96 }
  ],
  "presets": [
    { "name": "t:sections.featured-product.name" }
  ]
}
{% endschema %}
