{%- comment -%}
  Related products — prioritises the current product's own collection (distinct
  from sections/product-recommendations.liquid, which uses Shopify's related-
  products API). When the collection has fewer products than requested, the
  <collection-recommendations> element (assets/collection-recs.js) tops it up from
  the native recommendations endpoint, rendered through THIS section's
  `recommendations.performed` branch so the extra cards are full product cards.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign want = section.settings.products_count | default: 4
-%}

{%- if recommendations.performed -%}
  {%- comment -%} Section-Rendering fallback fetch — emit only the cards. {%- endcomment -%}
  {%- for p in recommendations.products -%}
    <div data-fade-up data-rec-card="{{ p.handle }}">{% render 'product-card', product: p, quick_add_style: section.settings.quick_add_style %}</div>
  {%- endfor -%}
{%- else -%}
  <style>
    #shopify-section-{{ section.id }} {
      --pt: {{ section.settings.padding_top }}px;
      --pb: {{ section.settings.padding_bottom }}px;
      --rec-columns: {{ section.settings.columns_desktop }};
    }
  </style>

  <div class="related color-scheme--{{ scheme }}">
    <div class="page-width">
      <h2 class="related__heading section-heading" data-split>{{ section.settings.heading | escape }}</h2>

      {%- assign source = product.collections.first -%}
      <collection-recommendations
        data-want="{{ want }}"
        {%- if section.settings.fallback_to_recommendations -%}
          data-fallback-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ want }}&intent=related"
        {%- endif -%}
      >
        <div class="product-grid related__grid" data-rec-grid>
          {%- assign have = 0 -%}
          {%- if source -%}
            {%- for p in source.products -%}
              {%- if have >= want -%}{%- break -%}{%- endif -%}
              {%- unless p.id == product.id -%}
                {%- assign have = have | plus: 1 -%}
                <div data-fade-up data-rec-card="{{ p.handle }}">{% render 'product-card', product: p, quick_add_style: section.settings.quick_add_style %}</div>
              {%- endunless -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
      </collection-recommendations>
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .related { padding-block: var(--pt, var(--space-20)) var(--pb, var(--space-20)); }
  .related__heading { margin: 0 0 var(--space-8); }
  .related__grid {
    display: grid;
    grid-template-columns: repeat(var(--rec-columns, 4), minmax(0, 1fr));
    gap: var(--space-6) var(--space-4);
  }
  @media (max-width: 749px) {
    .related__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.related-products.name",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "t:sections.related-products.settings.heading.label", "default": "From the same collection" },
    { "type": "range", "id": "products_count", "min": 4, "max": 8, "step": 1, "label": "t:sections.related-products.settings.products_count.label", "default": 4 },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "t:sections.related-products.settings.columns_desktop.label",
      "options": [
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    { "type": "checkbox", "id": "fallback_to_recommendations", "label": "t:sections.related-products.settings.fallback_to_recommendations.label", "info": "t:sections.related-products.settings.fallback_to_recommendations.info", "default": true },
    {
      "type": "select",
      "id": "quick_add_style",
      "label": "t:sections.related-products.settings.quick_add_style.label",
      "options": [
        { "value": "hover", "label": "t:sections.related-products.settings.quick_add_style.options__1.label" },
        { "value": "always", "label": "t:sections.related-products.settings.quick_add_style.options__2.label" }
      ],
      "default": "hover"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.related-products.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.related-products.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.related-products.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.related-products.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.related-products.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.related-products.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "t:sections.related-products.settings.padding_top.label", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "t:sections.related-products.settings.padding_bottom.label", "default": 80 }
  ],
  "presets": [
    { "name": "t:sections.related-products.name" }
  ]
}
{% endschema %}
