{%- comment -%}
  Native product reviews — no app. Reviews are merchant-managed Shopify
  metaobjects, so all data is server-rendered and Theme-Store compliant.

  SETUP (one-time, in Shopify admin):
  1. Settings → Custom data → Metaobjects → Add definition "Product review"
     (type handle: product_review) with fields:
       - author        (single line text)
       - rating        (integer, 1–5)
       - body          (multi-line text)
       - product       (product reference)
       - created_date  (date)
       - verified      (true/false)
  2. Settings → Custom data → Products → Add a metafield "reviews"
     (namespace.key: custom.reviews) of type "List of metaobjects → Product review".
  3. On each product, add the relevant review metaobjects to custom.reviews.

  The "Write a review" form posts to Shopify's native /contact endpoint, tagged
  for the merchant to moderate and publish as a metaobject — the only
  app-free, Theme-Store-compliant way to collect customer reviews.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign reviews = product.metafields.custom.reviews.value
  assign review_count = 0
  if reviews
    assign review_count = reviews.size
  endif
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="reviews color-scheme--{{ scheme }}" id="reviews">
  <div class="page-width">
    {%- if review_count > 0 -%}
      {%- liquid
        # Metaobject fields are accessed via .value (bare access returns a drop).
        assign rating_total = 0
        assign valid_count = 0
        assign c5 = 0
        assign c4 = 0
        assign c3 = 0
        assign c2 = 0
        assign c1 = 0
        for review in reviews
          assign rv = review.rating.value | plus: 0
          case rv
            when 5
              assign c5 = c5 | plus: 1
            when 4
              assign c4 = c4 | plus: 1
            when 3
              assign c3 = c3 | plus: 1
            when 2
              assign c2 = c2 | plus: 1
            when 1
              assign c1 = c1 | plus: 1
            else
              continue
          endcase
          assign rating_total = rating_total | plus: rv
          assign valid_count = valid_count | plus: 1
        endfor
        assign average = 0
        if valid_count > 0
          assign average = rating_total | times: 1.0 | divided_by: valid_count | round: 1
        endif
      -%}

      <header class="reviews__header">
        <h2 class="reviews__title section-heading" data-split>{{ 'products.reviews.title' | t }}</h2>
        <div class="reviews__summary">
          <span class="reviews__average">{{ average }}</span>
          {% render 'stars', rating: average %}
          <span class="reviews__count">{{ 'products.reviews.count' | t: count: review_count }}</span>
        </div>
      </header>

      {%- if section.settings.show_summary_bars -%}
        <div class="reviews__bars">
          {%- assign levels = '5,4,3,2,1' | split: ',' -%}
          {%- for level in levels -%}
            {%- liquid
              case level
                when '5'
                  assign lc = c5
                when '4'
                  assign lc = c4
                when '3'
                  assign lc = c3
                when '2'
                  assign lc = c2
                else
                  assign lc = c1
              endcase
              assign pct = 0
              if valid_count > 0
                assign pct = lc | times: 100.0 | divided_by: valid_count | round
              endif
            -%}
            <div class="reviews__bar">
              <span class="reviews__bar-label">{{ level }}★</span>
              <span class="reviews__bar-track"><span class="reviews__bar-fill" style="width: {{ pct }}%"></span></span>
              <span class="reviews__bar-count">{{ lc }}</span>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <ul class="reviews__list">
        {%- for review in reviews limit: section.settings.reviews_per_page -%}
          <li class="review">
            <div class="review__top">
              {% render 'stars', rating: review.rating.value %}
              <span class="review__author">{{ review.author.value }}</span>
              {%- if review.verified.value -%}<span class="review__verified">{{ 'products.reviews.verified' | t }}</span>{%- endif -%}
              {%- if review.created_date.value -%}<span class="review__date">{{ review.created_date.value | date: '%B %Y' }}</span>{%- endif -%}
            </div>
            {%- if review.body.value != blank -%}<p class="review__body">{{ review.body.value }}</p>{%- endif -%}
            <div class="review__helpful" data-review-helpful="{{ product.id }}-{{ review.system.id | default: forloop.index }}">
              <span class="review__helpful-label">{{ 'products.reviews.helpful' | t }}</span>
              <button type="button" class="review__helpful-btn" data-helpful="yes">{{ 'products.reviews.helpful_yes' | t }}</button>
              <button type="button" class="review__helpful-btn" data-helpful="no">{{ 'products.reviews.helpful_no' | t }}</button>
              <span class="review__helpful-thanks">{{ 'products.reviews.helpful_thanks' | t }}</span>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <header class="reviews__header reviews__header--empty">
        <h2 class="reviews__title section-heading" data-split>{{ 'products.reviews.title' | t }}</h2>
        <p class="reviews__empty">{{ 'products.reviews.empty' | t }}</p>
      </header>
    {%- endif -%}

    {%- if section.settings.show_write_form -%}
      <details class="reviews__write">
        <summary class="btn btn--outline reviews__write-toggle">{{ 'products.reviews.write' | t }}</summary>
        <div class="reviews__write-body">
          {%- form 'contact', id: 'ReviewForm', class: 'reviews__form' -%}
            {%- if form.posted_successfully? -%}
              <p class="reviews__form-success">{{ 'products.reviews.success' | t }}</p>
            {%- endif -%}
            <input type="hidden" name="contact[tags]" value="product-review">
            <input type="hidden" name="contact[product]" value="{{ product.title | escape }}">

            <div class="reviews__field">
              <label class="label" for="ReviewName-{{ section.id }}">{{ 'products.reviews.name' | t }}</label>
              <input class="input" type="text" id="ReviewName-{{ section.id }}" name="contact[name]" required>
            </div>
            <div class="reviews__field">
              <label class="label" for="ReviewEmail-{{ section.id }}">{{ 'products.reviews.email' | t }}</label>
              <input class="input" type="email" id="ReviewEmail-{{ section.id }}" name="contact[email]" required>
              <span class="caption">{{ 'products.reviews.email_help' | t }}</span>
            </div>
            <div class="reviews__field">
              <span class="label">{{ 'products.reviews.your_rating' | t }}</span>
              <fieldset class="reviews__rating-picker">
                <legend class="visually-hidden">{{ 'products.reviews.your_rating' | t }}</legend>
                {%- for i in (1..5) reversed -%}
                  <input type="radio" name="contact[rating]" value="{{ i }}" id="ReviewStar-{{ i }}-{{ section.id }}"{% if i == 5 %} required{% endif %}>
                  <label for="ReviewStar-{{ i }}-{{ section.id }}" aria-label="{{ i }}">{% render 'icon', name: 'star' %}</label>
                {%- endfor -%}
              </fieldset>
            </div>
            <div class="reviews__field">
              <label class="label" for="ReviewBody-{{ section.id }}">{{ 'products.reviews.review_body' | t }}</label>
              <textarea class="textarea" id="ReviewBody-{{ section.id }}" name="contact[body]" rows="4" required></textarea>
            </div>
            <button type="submit" class="btn btn--full">{{ 'products.reviews.submit' | t }}</button>
            <p class="caption reviews__moderated">{{ 'products.reviews.moderated' | t }}</p>
          {%- endform -%}
        </div>
      </details>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .reviews { padding-block: var(--pt, var(--space-20)) var(--pb, var(--space-20)); }
  .reviews__header { display: flex; align-items: baseline; justify-content: space-between; flex-wrap: wrap; gap: var(--space-4); margin-bottom: var(--space-8); }
  .reviews__title { margin: 0; }
  .reviews__summary { display: flex; align-items: center; gap: var(--space-3); }
  .reviews__average { font-family: var(--font-heading); font-size: var(--text-2xl); }
  .reviews__count { color: var(--color-muted); font-size: var(--text-sm); }
  .stars { display: inline-flex; gap: 2px; color: var(--color-text); }
  .stars svg { width: 16px; height: 16px; }

  .reviews__bars { display: flex; flex-direction: column; gap: var(--space-2); max-width: 28rem; margin-bottom: var(--space-10); }
  .reviews__bar { display: grid; grid-template-columns: 2.5rem 1fr 2rem; align-items: center; gap: var(--space-3); font-size: var(--text-sm); }
  .reviews__bar-track { height: 6px; background: var(--color-subtle); overflow: hidden; }
  .reviews__bar-fill { display: block; height: 100%; background: var(--color-text); }
  .reviews__bar-count { color: var(--color-muted); text-align: right; }

  .reviews__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--space-8); }
  .review { border-top: 1px solid var(--color-border); padding-top: var(--space-6); display: flex; flex-direction: column; gap: var(--space-3); }
  .review__top { display: flex; align-items: center; flex-wrap: wrap; gap: var(--space-3); }
  .review__author { font-weight: 500; }
  .review__verified { font-family: var(--font-mono); font-size: var(--text-xs); letter-spacing: 0.04em; text-transform: uppercase; color: var(--color-accent); }
  .review__date { color: var(--color-muted); font-size: var(--text-sm); margin-left: auto; }
  .review__body { margin: 0; color: var(--color-text); max-width: 60ch; }
  .review__helpful { display: flex; align-items: center; gap: var(--space-3); font-size: var(--text-sm); }
  .review__helpful-label { color: var(--color-muted); }
  .review__helpful-btn { background: none; border: 1px solid var(--color-border); padding: 0.25rem 0.75rem; cursor: pointer; font-size: var(--text-xs); transition: border-color var(--duration-fast) var(--ease-editorial); }
  .review__helpful-btn:hover { border-color: var(--color-text); }
  .review__helpful-thanks { display: none; color: var(--color-muted); }
  .review__helpful.is-voted .review__helpful-btn { opacity: 0.4; }
  .review__helpful.is-voted .review__helpful-thanks { display: inline; }

  .reviews__empty { color: var(--color-muted); }
  .reviews__header--empty { flex-direction: column; align-items: flex-start; }

  .reviews__write { margin-top: var(--space-10); }
  .reviews__write-toggle { display: inline-flex; }
  .reviews__write-body { margin-top: var(--space-6); max-width: 32rem; }
  .reviews__form { display: flex; flex-direction: column; gap: var(--space-4); }
  .reviews__field { display: flex; flex-direction: column; gap: var(--space-2); }
  .reviews__form-success { color: var(--color-accent); }
  .reviews__moderated { color: var(--color-muted); }

  /* Interactive star picker — reverse-row so :checked fills preceding stars. */
  .reviews__rating-picker { display: inline-flex; flex-direction: row-reverse; justify-content: flex-end; border: 0; margin: 0; padding: 0; gap: 2px; }
  .reviews__rating-picker input { position: absolute; opacity: 0; width: 0; height: 0; }
  .reviews__rating-picker label { cursor: pointer; color: var(--color-border); display: inline-flex; }
  .reviews__rating-picker label svg { width: 22px; height: 22px; }
  .reviews__rating-picker label:hover,
  .reviews__rating-picker label:hover ~ label,
  .reviews__rating-picker input:checked ~ label { color: var(--color-text); }
  .reviews__rating-picker input:focus-visible + label { outline: 2px solid var(--color-accent); outline-offset: 2px; }

  @media (max-width: 749px) {
    .reviews__header { flex-direction: column; align-items: flex-start; }
    .review__date { margin-left: 0; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product-reviews.name",
  "tag": "section",
  "settings": [
    { "type": "paragraph", "content": "t:sections.product-reviews.settings.paragraph__setup.content" },
    { "type": "checkbox", "id": "show_summary_bars", "label": "t:sections.product-reviews.settings.show_summary_bars.label", "default": true },
    { "type": "checkbox", "id": "show_write_form", "label": "t:sections.product-reviews.settings.show_write_form.label", "default": true },
    { "type": "range", "id": "reviews_per_page", "min": 3, "max": 12, "step": 1, "label": "t:sections.product-reviews.settings.reviews_per_page.label", "default": 6 },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.product-reviews.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.product-reviews.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.product-reviews.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.product-reviews.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.product-reviews.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.product-reviews.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "t:sections.product-reviews.settings.padding_top.label", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 4, "unit": "px", "label": "t:sections.product-reviews.settings.padding_bottom.label", "default": 80 }
  ],
  "presets": [
    { "name": "t:sections.product-reviews.name" }
  ]
}
{% endschema %}
