{%- comment -%}
  Editorial hero — full-bleed banner with overlay, entrance animation on
  page load (CSS @keyframes, reduced-motion guarded), and up to two CTAs.
  Mirrors rich-text.liquid: inline <style> carries instance values only,
  a color-scheme--* class paints the no-image fallback, {% stylesheet %}
  holds all component CSS with NO Liquid.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'

  assign image = section.settings.image
  assign image_mobile = section.settings.image_mobile
  assign heading = section.settings.heading
  assign hero_alt = image.alt | default: heading | escape

  assign overlay = section.settings.overlay_opacity | divided_by: 100.0

  assign heading_size = section.settings.heading_size | default: 'display'

  assign heading_tag = section.settings.heading_tag | default: 'h1'

  assign cta_class = 'btn'
  case section.settings.cta_style
    when 'outline'
      assign cta_class = 'btn btn--outline'
    when 'link'
      assign cta_class = 'link-underline'
  endcase

  assign show_primary = false
  if section.settings.cta_label != blank and section.settings.cta_url != blank
    assign show_primary = true
  endif

  assign show_secondary = false
  if section.settings.cta_secondary_label != blank and section.settings.cta_secondary_url != blank
    assign show_secondary = true
  endif
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --hero-height: {{ section.settings.image_height }};
    --hero-overlay: {{ overlay }};
    --hero-overlay-color: {{ section.settings.overlay_color }};
  }
</style>

<div
  class="hero section--full-bleed color-scheme--{{ scheme }} hero--pos-{{ section.settings.text_position }} hero--align-{{ section.settings.text_align }}{% if image == blank %} hero--no-image{% endif %}"
>
  {%- if section.settings.show_edition_number -%}
    <span class="edition-number" aria-hidden="true">001</span>
  {%- endif -%}
  <div class="hero__media">
    {%- if image != blank -%}
      {%- liquid
        assign desktop_class = 'hero__image'
        if image_mobile != blank
          assign desktop_class = 'hero__image hero__image--desktop'
        endif
      -%}
      {{
        image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 2000, 2400',
          sizes: '100vw',
          alt: hero_alt,
          class: desktop_class
      }}
      {%- if image_mobile != blank -%}
        {{
          image_mobile
          | image_url: width: 1100
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '450, 750, 1100',
            sizes: '100vw',
            alt: hero_alt,
            class: 'hero__image hero__image--mobile'
        }}
      {%- endif -%}
    {%- endif -%}
  </div>

  {%- if image != blank -%}
    <div class="hero__overlay" aria-hidden="true"></div>
  {%- endif -%}

  <div class="hero__inner page-width">
    <div class="hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="hero__eyebrow eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if heading != blank -%}
        <{{ heading_tag }} class="hero__heading section-heading heading--{{ heading_size }}">
          {{- heading | escape | newline_to_br -}}
        </{{ heading_tag }}>
      {%- endif -%}

      {%- if section.settings.subtext != blank -%}
        <div class="hero__subtext lead">{{ section.settings.subtext }}</div>
      {%- endif -%}

      {%- if show_primary or show_secondary -%}
        <div class="hero__actions">
          {%- if show_primary -%}
            <a class="hero__cta {{ cta_class }}" href="{{ section.settings.cta_url }}">
              {{- section.settings.cta_label | escape -}}
            </a>
          {%- endif -%}
          {%- if show_secondary -%}
            <a class="hero__cta link-underline" href="{{ section.settings.cta_secondary_url }}">
              {{- section.settings.cta_secondary_label | escape -}}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if section.settings.trust_line != blank -%}
        <p class="hero__trust caption">{{ section.settings.trust_line | escape }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .hero {
    position: relative;
    display: flex;
    width: 100%;
    min-height: var(--hero-height, 90svh);
    padding-block: var(--pt, 0) var(--pb, 0);
    overflow: hidden;
  }
  /* No-image editorial hero: clean cream ground, full-height, oversized type */
  .hero--no-image,
  .hero--no-image .hero__media { background-color: var(--color-bg); }
  .hero--no-image { min-height: 90svh; }
  .hero--no-image .hero__content { max-width: none; }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: var(--z-base);
    background-color: var(--color-subtle);
  }
  .hero__image,
  .hero__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .hero__placeholder {
    color: color-mix(in srgb, var(--color-text) 12%, transparent);
  }
  .hero__placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Two-image swap: desktop default, mobile under 750px */
  .hero__image--mobile { display: none; }
  @media (max-width: 749px) {
    .hero__image--desktop { display: none; }
    .hero__image--mobile { display: block; }
  }

  .hero__overlay {
    position: absolute;
    inset: 0;
    z-index: var(--z-raised);
    background-color: var(--hero-overlay-color);
    opacity: var(--hero-overlay, 0.3);
  }

  .hero__inner {
    position: relative;
    z-index: var(--z-sticky);
    display: flex;
    width: 100%;
  }

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    max-width: 46rem;
    color: var(--color-overlay-text);
  }

  /* Vertical position (via flex on .hero__inner) */
  .hero--pos-top .hero__inner { align-items: flex-start; }
  .hero--pos-center .hero__inner { align-items: center; }
  .hero--pos-bottom .hero__inner { align-items: flex-end; }

  /* Horizontal alignment */
  .hero--align-left .hero__content { text-align: left; align-items: flex-start; }
  .hero--align-center .hero__content { text-align: center; align-items: center; margin-inline: auto; }
  .hero--align-right .hero__content { text-align: right; align-items: flex-end; margin-inline-start: auto; }

  .hero__eyebrow { color: var(--color-overlay-text); opacity: 0.85; }
  .hero__heading {
    color: var(--color-overlay-text);
    max-width: none;
    font-weight: 300;
  }
  /* Hero keeps its signature oversized scale for the default 'display' size;
     any other chosen size falls back to the standard heading scale. */
  .hero__heading.heading--display {
    font-size: clamp(4rem, 10vw, 13rem);
    line-height: 0.92;
    letter-spacing: -0.03em;
  }
  .hero__subtext {
    max-width: 52ch;
    color: var(--color-overlay-text);
    opacity: 0.9;
  }
  .hero--align-center .hero__heading,
  .hero--align-center .hero__subtext { margin-inline: auto; }

  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    margin-top: var(--space-2);
  }
  .hero--align-center .hero__actions { justify-content: center; }
  .hero--align-right .hero__actions { justify-content: flex-end; }

  .hero__trust {
    margin-top: var(--space-1);
    color: var(--color-overlay-text);
    opacity: 0.8;
    letter-spacing: var(--tracking-wide);
  }
  .hero--no-image .hero__trust { color: var(--color-muted); opacity: 1; }

  /* Buttons sit on imagery — keep them in the overlay-text palette */
  .hero__cta.btn {
    background-color: var(--color-overlay-text);
    border-color: var(--color-overlay-text);
    color: var(--color-foreground);
  }
  .hero__cta.btn:hover {
    background-color: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-overlay-text);
  }
  .hero__cta.btn--outline {
    background-color: transparent;
    border-color: var(--color-overlay-text);
    color: var(--color-overlay-text);
  }
  .hero__cta.btn--outline:hover {
    background-color: var(--color-overlay-text);
    border-color: var(--color-overlay-text);
    color: var(--color-text);
  }
  .hero__cta.link-underline { color: var(--color-overlay-text); }

  /* No-image fallback: paint text from the color scheme so light schemes stay legible */
  .hero--no-image .hero__content,
  .hero--no-image .hero__eyebrow,
  .hero--no-image .hero__heading,
  .hero--no-image .hero__subtext { color: var(--color-text); }
  .hero--no-image .hero__eyebrow { color: var(--color-muted); }
  .hero--no-image .hero__cta.btn { background-color: var(--color-text); border-color: var(--color-text); color: var(--color-bg); }
  .hero--no-image .hero__cta.btn:hover { background-color: var(--color-accent-local); border-color: var(--color-accent-local); color: var(--color-bg); }
  .hero--no-image .hero__cta.btn--outline { background-color: transparent; border-color: var(--color-border-strong); color: var(--color-text); }
  .hero--no-image .hero__cta.btn--outline:hover { background-color: var(--color-text); border-color: var(--color-text); color: var(--color-bg); }
  .hero--no-image .hero__cta.link-underline { color: var(--color-text); }

  /* Entrance animation on page load */
  .hero__eyebrow,
  .hero__heading,
  .hero__subtext,
  .hero__actions,
  .hero__trust {
    animation: hero-rise var(--duration-slower) var(--ease-out) both;
  }
  .hero__eyebrow { animation-delay: 200ms; }
  .hero__heading { animation-delay: 400ms; }
  .hero__subtext { animation-delay: 700ms; }
  .hero__actions { animation-delay: 900ms; }
  .hero__trust { animation-delay: 1050ms; }

  @keyframes hero-rise {
    from { opacity: 0; transform: translateY(1.5rem); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__eyebrow,
    .hero__heading,
    .hero__subtext,
    .hero__actions,
    .hero__trust {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.hero.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.hero.settings.header__1.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.hero.settings.image.label"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:sections.hero.settings.image_mobile.label",
      "info": "t:sections.hero.settings.image_mobile.info"
    },
    {
      "type": "select",
      "id": "image_height",
      "label": "t:sections.hero.settings.image_height.label",
      "options": [
        { "value": "50svh", "label": "t:sections.hero.settings.image_height.options__1.label" },
        { "value": "70svh", "label": "t:sections.hero.settings.image_height.options__2.label" },
        { "value": "90svh", "label": "t:sections.hero.settings.image_height.options__3.label" },
        { "value": "100svh", "label": "t:sections.hero.settings.image_height.options__4.label" }
      ],
      "default": "70svh"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "t:sections.hero.settings.overlay_opacity.label",
      "default": 30
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:sections.hero.settings.overlay_color.label",
      "default": "#0A0705"
    },
    {
      "type": "header",
      "content": "t:sections.hero.settings.header__2.content"
    },
    {
      "type": "select",
      "id": "text_position",
      "label": "t:sections.hero.settings.text_position.label",
      "options": [
        { "value": "top", "label": "t:sections.hero.settings.text_position.options__1.label" },
        { "value": "center", "label": "t:sections.hero.settings.text_position.options__2.label" },
        { "value": "bottom", "label": "t:sections.hero.settings.text_position.options__3.label" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "t:sections.hero.settings.text_align.label",
      "options": [
        { "value": "left", "label": "t:sections.hero.settings.text_align.options__1.label" },
        { "value": "center", "label": "t:sections.hero.settings.text_align.options__2.label" },
        { "value": "right", "label": "t:sections.hero.settings.text_align.options__3.label" }
      ],
      "default": "center"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.hero.settings.eyebrow.label"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "t:sections.hero.settings.heading.label",
      "default": "Considered\nobjects for the\nmodern home"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.hero.settings.heading_tag.label",
      "info": "t:sections.hero.settings.heading_tag.info",
      "options": [
        { "value": "h1", "label": "t:sections.hero.settings.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.hero.settings.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.hero.settings.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.hero.settings.heading_tag.options__4.label" },
        { "value": "p", "label": "t:sections.hero.settings.heading_tag.options__5.label" }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.hero.settings.heading_size.label",
      "info": "t:sections.hero.settings.heading_size.info",
      "options": [
        { "value": "display", "label": "t:sections.hero.settings.heading_size.options__1.label" },
        { "value": "xl", "label": "t:sections.hero.settings.heading_size.options__2.label" },
        { "value": "lg", "label": "t:sections.hero.settings.heading_size.options__3.label" },
        { "value": "md", "label": "t:sections.hero.settings.heading_size.options__4.label" },
        { "value": "sm", "label": "t:sections.hero.settings.heading_size.options__5.label" },
        { "value": "xs", "label": "t:sections.hero.settings.heading_size.options__6.label" },
        { "value": "body", "label": "t:sections.hero.settings.heading_size.options__7.label" }
      ],
      "default": "display"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "t:sections.hero.settings.subtext.label"
    },
    {
      "type": "text",
      "id": "trust_line",
      "label": "t:sections.hero.settings.trust_line.label",
      "info": "t:sections.hero.settings.trust_line.info",
      "default": "4.9 ★ · 2,000+ reviews · Free shipping over $150"
    },
    {
      "type": "header",
      "content": "t:sections.hero.settings.header__3.content"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:sections.hero.settings.cta_label.label",
      "default": "Shop the collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:sections.hero.settings.cta_url.label"
    },
    {
      "type": "select",
      "id": "cta_style",
      "label": "t:sections.hero.settings.cta_style.label",
      "options": [
        { "value": "solid", "label": "t:sections.hero.settings.cta_style.options__1.label" },
        { "value": "outline", "label": "t:sections.hero.settings.cta_style.options__2.label" },
        { "value": "link", "label": "t:sections.hero.settings.cta_style.options__3.label" }
      ],
      "default": "solid"
    },
    {
      "type": "header",
      "content": "t:sections.hero.settings.header__4.content"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "t:sections.hero.settings.cta_secondary_label.label"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "t:sections.hero.settings.cta_secondary_url.label"
    },
    {
      "type": "header",
      "content": "t:sections.hero.settings.header__5.content"
    },
    {
      "type": "checkbox",
      "id": "show_edition_number",
      "label": "t:sections.hero.settings.show_edition_number.label",
      "default": true
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.hero.settings.color_scheme.label",
      "info": "t:sections.hero.settings.color_scheme.info",
      "options": [
        { "value": "cream", "label": "t:sections.hero.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.hero.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.hero.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.hero.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.hero.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.hero.settings.padding_top.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.hero.settings.padding_bottom.label",
      "default": 0
    }
  ],
  "presets": [
    { "name": "t:sections.hero.presets.name" }
  ]
}
{% endschema %}
