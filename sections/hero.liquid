{%- comment -%}
  Editorial hero — split (40% content / 60% media) or full-bleed overlay,
  configurable via the `layout` setting. Media supports image or autoplay
  muted-loop video, with GSAP parallax + clip-path reveal. The headline uses
  data-split for the GSAP SplitText line reveal; the entrance timeline lives in
  assets/gsap-animations.js (initHero). Reduced-motion: GSAP is gated off there,
  so everything stays visible.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign layout = section.settings.layout | default: 'fullbleed'
  assign image = section.settings.image
  assign image_mobile = section.settings.image_mobile
  assign video_url = section.settings.video_url
  assign heading = section.settings.heading
  assign hero_alt = image.alt | default: heading | escape
  assign overlay = section.settings.overlay_opacity | divided_by: 100.0
  assign heading_size = section.settings.heading_size | default: 'display'
  assign heading_tag = section.settings.heading_tag | default: 'h1'
  assign has_media = false
  if image != blank or video_url != blank
    assign has_media = true
  endif

  assign cta_class = 'btn'
  case section.settings.cta_style
    when 'outline'
      assign cta_class = 'btn btn--outline'
    when 'link'
      assign cta_class = 'link-underline'
  endcase

  assign show_primary = false
  if section.settings.cta_label != blank and section.settings.cta_url != blank
    assign show_primary = true
  endif
  assign show_secondary = false
  if section.settings.cta_secondary_label != blank and section.settings.cta_secondary_url != blank
    assign show_secondary = true
  endif
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --hero-overlay: {{ overlay }};
    --hero-overlay-color: {{ section.settings.overlay_color }};
  }
</style>

{%- capture hero_media -%}
  <div class="hero__media" data-parallax="-8" data-reveal>
    {%- if video_url != blank -%}
      <video class="hero__video" autoplay muted loop playsinline preload="metadata"
        {% if image != blank %}poster="{{ image | image_url: width: 1500 }}"{% endif %}>
        <source src="{{ video_url }}">
      </video>
    {%- elsif image != blank -%}
      {%- assign desktop_class = 'hero__image' -%}
      {%- if image_mobile != blank -%}{%- assign desktop_class = 'hero__image hero__image--desktop' -%}{%- endif -%}
      {{ image | image_url: width: 2400 | image_tag:
        loading: 'eager', fetchpriority: 'high',
        widths: '750, 1100, 1500, 2000, 2400',
        sizes: '100vw', alt: hero_alt, class: desktop_class }}
      {%- if image_mobile != blank -%}
        {{ image_mobile | image_url: width: 1100 | image_tag:
          loading: 'eager', fetchpriority: 'high',
          widths: '450, 750, 1100', sizes: '100vw', alt: hero_alt,
          class: 'hero__image hero__image--mobile' }}
      {%- endif -%}
    {%- endif -%}
  </div>
{%- endcapture -%}

{%- capture hero_content -%}
  <div class="hero__content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="hero__tag eyebrow">{{ section.settings.eyebrow | escape }}</span>
    {%- endif -%}

    {%- if heading != blank -%}
      <{{ heading_tag }} class="hero__heading section-heading heading--{{ heading_size }}" data-split>
        {{- heading | escape | newline_to_br -}}
      </{{ heading_tag }}>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <div class="hero__subtext lead">{{ section.settings.subtext }}</div>
    {%- endif -%}

    {%- if show_primary or show_secondary -%}
      <div class="hero__actions">
        {%- if show_primary -%}
          <a class="hero__cta {{ cta_class }}" href="{{ section.settings.cta_url }}">{{ section.settings.cta_label | escape }}</a>
        {%- endif -%}
        {%- if show_secondary -%}
          <a class="hero__cta link-underline" href="{{ section.settings.cta_secondary_url }}">{{ section.settings.cta_secondary_label | escape }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_trust_bar and section.settings.trust_line != blank -%}
      <p class="hero__trust caption">{{ section.settings.trust_line | escape }}</p>
    {%- endif -%}
  </div>
{%- endcapture -%}

<section
  class="hero hero--{{ layout }} section--full-bleed color-scheme--{{ scheme }} hero--align-{{ section.settings.text_align }}{% unless has_media %} hero--no-image{% endunless %}"
  data-hero
>
  {%- if section.settings.show_edition_number -%}
    <span class="edition-number" aria-hidden="true">001</span>
  {%- endif -%}

  {%- if layout == 'split' -%}
    <div class="hero__inner hero__inner--split page-width hero--pos-{{ section.settings.text_position }}">
      {{ hero_content }}
      {{ hero_media }}
    </div>
  {%- else -%}
    {{ hero_media }}
    {%- if has_media -%}<div class="hero__overlay" aria-hidden="true"></div>{%- endif -%}
    <div class="hero__inner page-width hero--pos-{{ section.settings.text_position }}">
      {{ hero_content }}
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .hero {
    position: relative;
    display: flex;
    width: 100%;
    min-height: 100dvh;
    padding-block: var(--pt, 0) var(--pb, 0);
    overflow: hidden;
  }
  .hero--no-image { background-color: var(--color-bg); }

  /* ---- Full-bleed layout ----
     The media is buffered 12% above and below the section (inset: -12% 0) and the
     section keeps overflow:hidden, so the GSAP parallax drift (data-parallax="-8")
     can never uncover the section edge — this is what eliminates the gray gap at
     the hero bottom. Background is --color-bg (not the gray --color-subtle) as a
     final safety net so any sub-pixel seam blends instead of reading as a band. */
  .hero--fullbleed .hero__media { position: absolute; inset: -12% 0; z-index: var(--z-base); background-color: var(--color-bg); }
  .hero--fullbleed .hero__overlay {
    position: absolute; inset: 0; z-index: var(--z-raised);
    background-color: var(--hero-overlay-color); opacity: var(--hero-overlay, 0.3); pointer-events: none;
  }
  .hero--fullbleed .hero__inner { position: relative; z-index: var(--z-sticky); display: flex; width: 100%; }
  .hero--fullbleed .hero__content { color: var(--color-overlay-text); }

  /* ---- Split layout: 40% content | 60% media ---- */
  .hero__inner--split {
    display: grid;
    grid-template-columns: 40% 60%;
    align-items: center;
    gap: clamp(2rem, 5vw, 5rem);
    width: 100%;
  }
  .hero--split .hero__media {
    position: relative;
    align-self: stretch;
    min-height: 60vh;
    border-radius: var(--image-radius, 0);
    overflow: hidden;
    background-color: var(--color-subtle);
  }
  @media (max-width: 749px) {
    .hero__inner--split { grid-template-columns: 1fr; }
    .hero--split .hero__media { min-height: 50vh; order: -1; }
  }

  /* ---- Media ---- */
  .hero__image, .hero__video {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .hero--split .hero__media .hero__image,
  .hero--split .hero__media .hero__video { position: absolute; inset: 0; }
  .hero__image--mobile { display: none; }
  @media (max-width: 749px) {
    .hero__image--desktop { display: none; }
    .hero__image--mobile { display: block; }
  }

  /* ---- Content ---- */
  .hero__content { display: flex; flex-direction: column; gap: var(--space-5); max-width: 46rem; }
  .hero--pos-top { align-items: flex-start; }
  .hero--pos-center { align-items: center; }
  .hero--pos-bottom { align-items: flex-end; }
  .hero--align-left .hero__content { text-align: left; align-items: flex-start; }
  .hero--align-center .hero__content { text-align: center; align-items: center; margin-inline: auto; }
  .hero--align-right .hero__content { text-align: right; align-items: flex-end; margin-inline-start: auto; }

  .hero__tag { display: block; }
  .hero__heading { max-width: none; font-weight: 300; }
  .hero__heading.heading--display { font-size: clamp(4rem, 10vw, 13rem); line-height: 0.92; letter-spacing: -0.03em; }
  .hero__subtext { max-width: 52ch; opacity: 0.9; }
  .hero--fullbleed .hero__tag,
  .hero--fullbleed .hero__heading,
  .hero--fullbleed .hero__subtext,
  .hero--fullbleed .hero__trust { color: var(--color-overlay-text); }

  .hero__actions { display: flex; flex-wrap: wrap; gap: var(--space-4); align-items: center; margin-top: var(--space-2); }
  .hero--align-center .hero__actions { justify-content: center; }
  .hero--align-right .hero__actions { justify-content: flex-end; }
  .hero__trust { margin-top: var(--space-1); opacity: 0.8; letter-spacing: var(--tracking-wide); }

  /* Buttons over imagery (full-bleed) keep the overlay-text palette */
  .hero--fullbleed .hero__cta.btn { background-color: var(--color-overlay-text); border-color: var(--color-overlay-text); color: var(--color-foreground); }
  .hero--fullbleed .hero__cta.btn:hover { background-color: var(--color-accent); border-color: var(--color-accent); color: var(--color-overlay-text); }
  .hero--fullbleed .hero__cta.btn--outline { background-color: transparent; border-color: var(--color-overlay-text); color: var(--color-overlay-text); }
  .hero--fullbleed .hero__cta.btn--outline:hover { background-color: var(--color-overlay-text); border-color: var(--color-overlay-text); color: var(--color-text); }
  .hero--fullbleed .hero__cta.link-underline { color: var(--color-overlay-text); }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.hero.name",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.hero.settings.layout.label",
      "options": [
        { "value": "fullbleed", "label": "t:sections.hero.settings.layout.options__1.label" },
        { "value": "split", "label": "t:sections.hero.settings.layout.options__2.label" }
      ],
      "default": "fullbleed"
    },
    { "type": "header", "content": "t:sections.hero.settings.header__1.content" },
    { "type": "image_picker", "id": "image", "label": "t:sections.hero.settings.image.label" },
    { "type": "image_picker", "id": "image_mobile", "label": "t:sections.hero.settings.image_mobile.label", "info": "t:sections.hero.settings.image_mobile.info" },
    { "type": "url", "id": "video_url", "label": "t:sections.hero.settings.video_url.label", "info": "t:sections.hero.settings.video_url.info" },
    {
      "type": "range", "id": "overlay_opacity", "min": 0, "max": 60, "step": 5, "unit": "%",
      "label": "t:sections.hero.settings.overlay_opacity.label", "default": 30
    },
    { "type": "color", "id": "overlay_color", "label": "t:sections.hero.settings.overlay_color.label", "default": "#0A0705" },
    { "type": "header", "content": "t:sections.hero.settings.header__2.content" },
    {
      "type": "select", "id": "text_position", "label": "t:sections.hero.settings.text_position.label",
      "options": [
        { "value": "top", "label": "t:sections.hero.settings.text_position.options__1.label" },
        { "value": "center", "label": "t:sections.hero.settings.text_position.options__2.label" },
        { "value": "bottom", "label": "t:sections.hero.settings.text_position.options__3.label" }
      ], "default": "center"
    },
    {
      "type": "select", "id": "text_align", "label": "t:sections.hero.settings.text_align.label",
      "options": [
        { "value": "left", "label": "t:sections.hero.settings.text_align.options__1.label" },
        { "value": "center", "label": "t:sections.hero.settings.text_align.options__2.label" },
        { "value": "right", "label": "t:sections.hero.settings.text_align.options__3.label" }
      ], "default": "center"
    },
    { "type": "text", "id": "eyebrow", "label": "t:sections.hero.settings.eyebrow.label" },
    { "type": "textarea", "id": "heading", "label": "t:sections.hero.settings.heading.label", "default": "Considered\nobjects for the\nmodern home" },
    {
      "type": "select", "id": "heading_tag", "label": "t:sections.hero.settings.heading_tag.label", "info": "t:sections.hero.settings.heading_tag.info",
      "options": [
        { "value": "h1", "label": "t:sections.hero.settings.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.hero.settings.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.hero.settings.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.hero.settings.heading_tag.options__4.label" },
        { "value": "p", "label": "t:sections.hero.settings.heading_tag.options__5.label" }
      ], "default": "h1"
    },
    {
      "type": "select", "id": "heading_size", "label": "t:sections.hero.settings.heading_size.label", "info": "t:sections.hero.settings.heading_size.info",
      "options": [
        { "value": "display", "label": "t:sections.hero.settings.heading_size.options__1.label" },
        { "value": "xl", "label": "t:sections.hero.settings.heading_size.options__2.label" },
        { "value": "lg", "label": "t:sections.hero.settings.heading_size.options__3.label" },
        { "value": "md", "label": "t:sections.hero.settings.heading_size.options__4.label" },
        { "value": "sm", "label": "t:sections.hero.settings.heading_size.options__5.label" },
        { "value": "xs", "label": "t:sections.hero.settings.heading_size.options__6.label" },
        { "value": "body", "label": "t:sections.hero.settings.heading_size.options__7.label" }
      ], "default": "display"
    },
    { "type": "richtext", "id": "subtext", "label": "t:sections.hero.settings.subtext.label" },
    { "type": "header", "content": "t:sections.hero.settings.header__trust.content" },
    { "type": "checkbox", "id": "show_trust_bar", "label": "t:sections.hero.settings.show_trust_bar.label", "default": true },
    { "type": "text", "id": "trust_line", "label": "t:sections.hero.settings.trust_line.label", "info": "t:sections.hero.settings.trust_line.info", "default": "4.9 ★ · 2,000+ reviews · Free shipping over $150" },
    { "type": "header", "content": "t:sections.hero.settings.header__3.content" },
    { "type": "text", "id": "cta_label", "label": "t:sections.hero.settings.cta_label.label", "default": "Shop the collection" },
    { "type": "url", "id": "cta_url", "label": "t:sections.hero.settings.cta_url.label" },
    {
      "type": "select", "id": "cta_style", "label": "t:sections.hero.settings.cta_style.label",
      "options": [
        { "value": "solid", "label": "t:sections.hero.settings.cta_style.options__1.label" },
        { "value": "outline", "label": "t:sections.hero.settings.cta_style.options__2.label" },
        { "value": "link", "label": "t:sections.hero.settings.cta_style.options__3.label" }
      ], "default": "solid"
    },
    { "type": "header", "content": "t:sections.hero.settings.header__4.content" },
    { "type": "text", "id": "cta_secondary_label", "label": "t:sections.hero.settings.cta_secondary_label.label" },
    { "type": "url", "id": "cta_secondary_url", "label": "t:sections.hero.settings.cta_secondary_url.label" },
    { "type": "header", "content": "t:sections.hero.settings.header__5.content" },
    { "type": "checkbox", "id": "show_edition_number", "label": "t:sections.hero.settings.show_edition_number.label", "default": true },
    {
      "type": "select", "id": "color_scheme", "label": "t:sections.hero.settings.color_scheme.label", "info": "t:sections.hero.settings.color_scheme.info",
      "options": [
        { "value": "cream", "label": "t:sections.hero.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.hero.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.hero.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.hero.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.hero.settings.color_scheme.options__5.label" }
      ], "default": "cream"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.hero.settings.padding_top.label", "default": 0 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.hero.settings.padding_bottom.label", "default": 0 }
  ],
  "presets": [
    { "name": "t:sections.hero.presets.name" }
  ]
}
{% endschema %}
