{%- comment -%}
  Editorial statement — a single large serif manifesto, centered in a narrow
  column, no heading. Mirrors the theme pattern: inline <style> carries only
  per-instance values, a color-scheme--* wrapper paints the background, and
  {% stylesheet %} holds component CSS with no Liquid.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="editorial-statement color-scheme--{{ scheme }}">
  <div class="editorial-statement__inner page-width">
    {%- if section.settings.statement != blank -%}
      <div class="editorial-statement__text">{{ section.settings.statement }}</div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .editorial-statement {
    padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing));
  }
  .editorial-statement__inner {
    display: flex;
    justify-content: center;
  }
  .editorial-statement__text {
    max-width: 880px;
    text-align: center;
    font-family: var(--font-heading);
    font-weight: 300;
    /* Monumental manifesto tier — uses the real display token, not a one-off clamp. */
    font-size: calc(var(--text-4xl) * var(--heading-scale));
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    color: var(--color-heading, #2C1810);
  }
  .editorial-statement__text p { margin: 0; }
  .editorial-statement__text p + p { margin-top: var(--space-5); }
  .editorial-statement__text em { font-style: italic; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.editorial-statement.name",
  "tag": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "statement",
      "label": "t:sections.editorial-statement.settings.statement.label",
      "default": "<p>We believe good objects should be useful, honest, and quietly beautiful.</p>"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.editorial-statement.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.editorial-statement.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.editorial-statement.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.editorial-statement.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.editorial-statement.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.editorial-statement.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.editorial-statement.settings.padding_top.label",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.editorial-statement.settings.padding_bottom.label",
      "default": 120
    }
  ],
  "presets": [
    { "name": "t:sections.editorial-statement.presets.name" }
  ]
}
{% endschema %}
