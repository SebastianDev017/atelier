{%- comment -%}
  GOLD-STANDARD SECTION — mirror this structure in every other section:
  - inline <style> on #shopify-section-{{ section.id }} carries instance
    values (padding + any per-instance vars) only.
  - a color-scheme--* wrapper class paints the background.
  - {% stylesheet %} holds ALL component CSS, contains NO Liquid, and
    references only base.css tokens + classes defined in this file.
  - data-animate / data-animate-delay drive the (global) scroll reveal.
  - every block's outer element carries {{ block.shopify_attributes }}.
  - schema uses plain-English labels and ends with a "presets" array.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign width_class = 'page-width--narrow'
  case section.settings.content_width
    when 'medium'
      assign width_class = ''
    when 'wide'
      assign width_class = 'page-width--wide'
  endcase
  assign align_class = ''
  if section.settings.text_alignment == 'left'
    assign align_class = 'rich-text--left'
  endif
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="rich-text color-scheme--{{ scheme }} {{ align_class }}">
  <span class="edition-number" aria-hidden="true">004</span>
  <div class="rich-text__inner page-width {{ width_class }}">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'eyebrow' -%}
          <p class="rich-text__eyebrow eyebrow" data-animate data-animate-delay="1" {{ block.shopify_attributes }}>
            {{- block.settings.text | escape -}}
          </p>
        {%- when 'heading' -%}
          <{{ block.settings.heading_tag }} class="rich-text__heading section-heading heading--{{ block.settings.heading_size | default: 'lg' }} reveal-lines" {{ block.shopify_attributes }}><span class="line">{{- block.settings.heading | escape -}}</span></{{ block.settings.heading_tag }}>
        {%- when 'text' -%}
          <div class="rich-text__text prose" data-animate data-animate-delay="3" {{ block.shopify_attributes }}>
            {{ block.settings.text }}
          </div>
        {%- when 'button' -%}
          {%- if block.settings.label != blank and block.settings.url != blank -%}
            {%- assign btn_class = 'btn' -%}
            {%- if block.settings.style == 'outline' -%}{%- assign btn_class = 'btn btn--outline' -%}{%- endif -%}
            {%- if block.settings.style == 'link' -%}{%- assign btn_class = 'link-underline' -%}{%- endif -%}
            <div class="rich-text__buttons" data-animate data-animate-delay="4" {{ block.shopify_attributes }}>
              <a class="{{ btn_class }}" href="{{ block.settings.url }}">{{ block.settings.label | escape }}</a>
            </div>
          {%- endif -%}
      {%- endcase -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .rich-text { position: relative; padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing)); }
  .rich-text__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    text-align: center;
    align-items: center;
  }
  .rich-text--left .rich-text__inner { text-align: left; align-items: flex-start; }
  .rich-text__heading { max-width: 20ch; }
  .rich-text__text { max-width: 60ch; color: var(--color-muted); }
  .rich-text__buttons { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-top: var(--space-3); }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.rich-text.name",
  "tag": "section",
  "blocks": [
    {
      "type": "eyebrow",
      "name": "t:sections.rich-text.blocks.eyebrow.name",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "label": "t:sections.rich-text.blocks.eyebrow.settings.text.label", "default": "Our story" }
      ]
    },
    {
      "type": "heading",
      "name": "t:sections.rich-text.blocks.heading.name",
      "limit": 1,
      "settings": [
        { "type": "textarea", "id": "heading", "label": "t:sections.rich-text.blocks.heading.settings.heading.label", "default": "Considered objects, made to last" },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "t:sections.rich-text.blocks.heading.settings.heading_tag.label",
          "info": "t:sections.rich-text.blocks.heading.settings.heading_tag.info",
          "options": [
            { "value": "h1", "label": "t:sections.rich-text.blocks.heading.settings.heading_tag.options__1.label" },
            { "value": "h2", "label": "t:sections.rich-text.blocks.heading.settings.heading_tag.options__2.label" },
            { "value": "h3", "label": "t:sections.rich-text.blocks.heading.settings.heading_tag.options__3.label" },
            { "value": "h4", "label": "t:sections.rich-text.blocks.heading.settings.heading_tag.options__4.label" },
            { "value": "p", "label": "t:sections.rich-text.blocks.heading.settings.heading_tag.options__5.label" }
          ],
          "default": "h2"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "t:sections.rich-text.blocks.heading.settings.heading_size.label",
          "info": "t:sections.rich-text.blocks.heading.settings.heading_size.info",
          "options": [
            { "value": "display", "label": "t:sections.rich-text.blocks.heading.settings.heading_size.options__1.label" },
            { "value": "xl", "label": "t:sections.rich-text.blocks.heading.settings.heading_size.options__2.label" },
            { "value": "lg", "label": "t:sections.rich-text.blocks.heading.settings.heading_size.options__3.label" },
            { "value": "md", "label": "t:sections.rich-text.blocks.heading.settings.heading_size.options__4.label" },
            { "value": "sm", "label": "t:sections.rich-text.blocks.heading.settings.heading_size.options__5.label" },
            { "value": "xs", "label": "t:sections.rich-text.blocks.heading.settings.heading_size.options__6.label" },
            { "value": "body", "label": "t:sections.rich-text.blocks.heading.settings.heading_size.options__7.label" }
          ],
          "default": "lg"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.rich-text.blocks.text.name",
      "limit": 1,
      "settings": [
        { "type": "richtext", "id": "text", "label": "t:sections.rich-text.blocks.text.settings.text.label", "default": "<p>Use this space to share what makes your store different. Keep it short, warm, and human.</p>" }
      ]
    },
    {
      "type": "button",
      "name": "t:sections.rich-text.blocks.button.name",
      "settings": [
        { "type": "text", "id": "label", "label": "t:sections.rich-text.blocks.button.settings.label.label", "default": "Shop the collection" },
        { "type": "url", "id": "url", "label": "t:sections.rich-text.blocks.button.settings.url.label" },
        {
          "type": "select",
          "id": "style",
          "label": "t:sections.rich-text.blocks.button.settings.style.label",
          "options": [
            { "value": "solid", "label": "t:sections.rich-text.blocks.button.settings.style.options__1.label" },
            { "value": "outline", "label": "t:sections.rich-text.blocks.button.settings.style.options__2.label" },
            { "value": "link", "label": "t:sections.rich-text.blocks.button.settings.style.options__3.label" }
          ],
          "default": "solid"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "content_width",
      "label": "t:sections.rich-text.settings.content_width.label",
      "options": [
        { "value": "narrow", "label": "t:sections.rich-text.settings.content_width.options__1.label" },
        { "value": "medium", "label": "t:sections.rich-text.settings.content_width.options__2.label" },
        { "value": "wide", "label": "t:sections.rich-text.settings.content_width.options__3.label" }
      ],
      "default": "narrow"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "t:sections.rich-text.settings.text_alignment.label",
      "options": [
        { "value": "center", "label": "t:sections.rich-text.settings.text_alignment.options__1.label" },
        { "value": "left", "label": "t:sections.rich-text.settings.text_alignment.options__2.label" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.rich-text.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.rich-text.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.rich-text.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.rich-text.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.rich-text.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.rich-text.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.rich-text.settings.padding_top.label",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.rich-text.settings.padding_bottom.label",
      "default": 80
    }
  ],
  "presets": [
    { "name": "t:sections.rich-text.presets.name" }
  ]
}
{% endschema %}
