{%- comment -%}
  Contact form — heading + subtext over a {% form 'contact' %}.
  Mirrors rich-text.liquid: inline <style> carries instance values only,
  color-scheme--* wrapper paints the background, {% stylesheet %} holds all
  component CSS (no Liquid), data-animate drives the global scroll reveal.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign heading = section.settings.heading | escape
  assign label_name = section.settings.label_name | default: 'Name' | escape
  assign label_email = section.settings.label_email | default: 'Email' | escape
  assign label_phone = section.settings.label_phone | default: 'Phone' | escape
  assign label_message = section.settings.label_message | default: 'Message' | escape
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="contact-form color-scheme--{{ scheme }}">
  <div class="contact-form__inner page-width page-width--narrow">
    {%- if heading != blank or section.settings.subtext != blank -%}
      <div class="section-header section-header--center" data-animate>
        {%- if heading != blank -%}
          <h2 class="contact-form__heading h2">{{ heading }}</h2>
        {%- endif -%}
        {%- if section.settings.subtext != blank -%}
          <div class="contact-form__subtext prose">{{ section.settings.subtext }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- form 'contact', class: 'contact-form__form', data-animate: '' -%}
      {%- if form.posted_successfully? -%}
        <p class="form-status form-status--success" role="status">
          {{- section.settings.success_message | default: 'Thanks for reaching out. We will reply soon.' | escape -}}
        </p>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="form-status form-status--error contact-form__errors" role="alert">
          <ul class="contact-form__error-list">
            {%- for field in form.errors -%}
              <li>{{ form.errors.messages[field] | escape }}</li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="contact-form__fields">
        <div class="field">
          <label class="field__label" for="ContactName-{{ section.id }}">{{ label_name }}</label>
          <input
            class="input"
            type="text"
            id="ContactName-{{ section.id }}"
            name="contact[Name]"
            autocomplete="name"
            value="{{ form.name }}"
          >
        </div>

        <div class="field">
          <label class="field__label" for="ContactEmail-{{ section.id }}">{{ label_email }}</label>
          <input
            class="input"
            type="email"
            id="ContactEmail-{{ section.id }}"
            name="contact[email]"
            autocomplete="email"
            required
            value="{{ form.email }}"
          >
        </div>

        <div class="field">
          <label class="field__label" for="ContactPhone-{{ section.id }}">{{ label_phone }}</label>
          <input
            class="input"
            type="tel"
            id="ContactPhone-{{ section.id }}"
            name="contact[Phone]"
            autocomplete="tel"
            value="{{ form.phone }}"
          >
        </div>

        <div class="field">
          <label class="field__label" for="ContactMessage-{{ section.id }}">{{ label_message }}</label>
          <textarea
            class="textarea"
            id="ContactMessage-{{ section.id }}"
            name="contact[Body]"
            required
          >{{- form.body -}}</textarea>
        </div>
      </div>

      <div class="contact-form__actions">
        <button type="submit" class="btn btn--large">{{ 'contact.send' | t }}</button>
      </div>
    {%- endform -%}
  </div>
</div>

{% stylesheet %}
  .contact-form { padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing)); }
  .contact-form__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }
  .contact-form__heading { max-width: 24ch; }
  .contact-form__subtext { max-width: 60ch; color: var(--color-muted); }
  .contact-form__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .contact-form__fields {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .contact-form__errors { margin-top: 0; }
  .contact-form__error-list {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .contact-form__actions { display: flex; }
  @media (min-width: 750px) {
    .contact-form__actions { justify-content: flex-start; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.contact-form.name",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.contact-form.settings.heading.label",
      "default": "Get in touch"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "t:sections.contact-form.settings.subtext.label",
      "default": "<p>Questions, custom requests, or wholesale enquiries — send us a note and we'll get back to you.</p>"
    },
    {
      "type": "header",
      "content": "t:sections.contact-form.settings.header__1.content"
    },
    {
      "type": "text",
      "id": "label_name",
      "label": "t:sections.contact-form.settings.label_name.label",
      "default": "Name"
    },
    {
      "type": "text",
      "id": "label_email",
      "label": "t:sections.contact-form.settings.label_email.label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "label_phone",
      "label": "t:sections.contact-form.settings.label_phone.label",
      "default": "Phone"
    },
    {
      "type": "text",
      "id": "label_message",
      "label": "t:sections.contact-form.settings.label_message.label",
      "default": "Message"
    },
    {
      "type": "header",
      "content": "t:sections.contact-form.settings.header__2.content"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "t:sections.contact-form.settings.success_message.label",
      "default": "Thanks for reaching out. We'll reply soon."
    },
    {
      "type": "header",
      "content": "t:sections.contact-form.settings.header__3.content"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.contact-form.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.contact-form.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.contact-form.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.contact-form.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.contact-form.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.contact-form.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.contact-form.settings.padding_top.label",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.contact-form.settings.padding_bottom.label",
      "default": 96
    }
  ],
  "presets": [
    { "name": "t:sections.contact-form.presets.name" }
  ]
}
{% endschema %}
