{%- comment -%}
  Image with text — editorial 42/58 split (content is the wider column).
  Never a 50/50 split. layout=image-right flips column order via CSS order.
  Mirrors rich-text.liquid: inline <style> carries instance vars only,
  color-scheme--* wrapper paints the background, {% stylesheet %} holds all
  component CSS with NO Liquid, data-animate drives the global scroll reveal.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign ratio = section.settings.image_ratio | default: 'portrait'
  assign image = section.settings.image

  assign layout_class = 'image-with-text--image-left'
  if section.settings.layout == 'image-right'
    assign layout_class = 'image-with-text--image-right'
  endif

  assign cta_class = 'btn'
  case section.settings.cta_style
    when 'outline'
      assign cta_class = 'btn btn--outline'
    when 'link'
      assign cta_class = 'link-underline'
  endcase

  assign img_alt = image.alt | default: section.settings.title | escape

  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign heading_size = section.settings.heading_size | default: 'lg'
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="image-with-text color-scheme--{{ scheme }} {{ layout_class }}">
  <span class="edition-number" aria-hidden="true">003</span>
  <div class="image-with-text__inner page-width">
    <div class="image-with-text__media-col">
      <div class="media media--{{ ratio }} image-with-text__media" data-animate-scale>
        {%- if image != blank -%}
          {{ image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '375, 550, 750, 900, 1200', sizes: '(min-width: 750px) 42vw, 100vw', alt: img_alt }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder' }}
        {%- endif -%}
      </div>
    </div>

    <div class="image-with-text__content-col">
      <div class="image-with-text__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="image-with-text__eyebrow eyebrow" data-animate data-animate-delay="1">
            {{- section.settings.eyebrow | escape -}}
          </p>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <{{ heading_tag }} class="image-with-text__title section-heading heading--{{ heading_size }} reveal-lines"><span class="line">{{- section.settings.title | escape -}}</span></{{ heading_tag }}>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="image-with-text__text prose" data-animate data-animate-delay="3">
            {{ section.settings.text }}
          </div>
        {%- endif -%}

        {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
          <div class="image-with-text__cta" data-animate data-animate-delay="4">
            <a class="{{ cta_class }}" href="{{ section.settings.cta_url }}">
              {{- section.settings.cta_label | escape -}}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .image-with-text {
    position: relative;
    padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing));
  }
  .image-with-text__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }
  .image-with-text__media {
    width: 100%;
  }
  .image-with-text__media img {
    transition: transform var(--duration-slow) var(--ease-editorial);
  }
  .image-with-text__media:hover img {
    transform: scale(1.03);
  }
  .image-with-text__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .image-with-text__title {
    max-width: 22ch;
  }
  .image-with-text__text {
    max-width: 56ch;
    color: var(--color-muted);
  }
  .image-with-text__cta {
    margin-top: var(--space-2);
  }

  @media (min-width: 750px) {
    .image-with-text__inner {
      grid-template-columns: 0.85fr 1.15fr;
      gap: var(--space-12);
    }
    .image-with-text--image-left .image-with-text__media-col { order: 1; }
    .image-with-text--image-left .image-with-text__content-col { order: 2; }
    .image-with-text--image-right .image-with-text__media-col { order: 2; }
    .image-with-text--image-right .image-with-text__content-col { order: 1; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.image-with-text.name",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "t:sections.image-with-text.settings.image.label" },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.image-with-text.settings.image_ratio.label",
      "options": [
        { "value": "portrait", "label": "t:sections.image-with-text.settings.image_ratio.options__1.label" },
        { "value": "square", "label": "t:sections.image-with-text.settings.image_ratio.options__2.label" },
        { "value": "landscape", "label": "t:sections.image-with-text.settings.image_ratio.options__3.label" },
        { "value": "wide", "label": "t:sections.image-with-text.settings.image_ratio.options__4.label" }
      ],
      "default": "portrait"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.image-with-text.settings.layout.label",
      "options": [
        { "value": "image-left", "label": "t:sections.image-with-text.settings.layout.options__1.label" },
        { "value": "image-right", "label": "t:sections.image-with-text.settings.layout.options__2.label" }
      ],
      "default": "image-left"
    },
    { "type": "text", "id": "eyebrow", "label": "t:sections.image-with-text.settings.eyebrow.label" },
    { "type": "textarea", "id": "title", "label": "t:sections.image-with-text.settings.title.label", "default": "Crafted with intention" },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.image-with-text.settings.heading_tag.label",
      "info": "t:sections.image-with-text.settings.heading_tag.info",
      "options": [
        { "value": "h1", "label": "t:sections.image-with-text.settings.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.image-with-text.settings.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.image-with-text.settings.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.image-with-text.settings.heading_tag.options__4.label" },
        { "value": "p", "label": "t:sections.image-with-text.settings.heading_tag.options__5.label" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.image-with-text.settings.heading_size.label",
      "info": "t:sections.image-with-text.settings.heading_size.info",
      "options": [
        { "value": "display", "label": "t:sections.image-with-text.settings.heading_size.options__1.label" },
        { "value": "xl", "label": "t:sections.image-with-text.settings.heading_size.options__2.label" },
        { "value": "lg", "label": "t:sections.image-with-text.settings.heading_size.options__3.label" },
        { "value": "md", "label": "t:sections.image-with-text.settings.heading_size.options__4.label" },
        { "value": "sm", "label": "t:sections.image-with-text.settings.heading_size.options__5.label" },
        { "value": "xs", "label": "t:sections.image-with-text.settings.heading_size.options__6.label" },
        { "value": "body", "label": "t:sections.image-with-text.settings.heading_size.options__7.label" }
      ],
      "default": "lg"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.image-with-text.settings.text.label",
      "default": "<p>Every piece begins with a considered material and an honest process. Share the story behind your work in a sentence or two.</p>"
    },
    { "type": "text", "id": "cta_label", "label": "t:sections.image-with-text.settings.cta_label.label" },
    { "type": "url", "id": "cta_url", "label": "t:sections.image-with-text.settings.cta_url.label" },
    {
      "type": "select",
      "id": "cta_style",
      "label": "t:sections.image-with-text.settings.cta_style.label",
      "options": [
        { "value": "solid", "label": "t:sections.image-with-text.settings.cta_style.options__1.label" },
        { "value": "outline", "label": "t:sections.image-with-text.settings.cta_style.options__2.label" },
        { "value": "link", "label": "t:sections.image-with-text.settings.cta_style.options__3.label" }
      ],
      "default": "solid"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.image-with-text.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.image-with-text.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.image-with-text.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.image-with-text.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.image-with-text.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.image-with-text.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.image-with-text.settings.padding_top.label", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.image-with-text.settings.padding_bottom.label", "default": 80 }
  ],
  "presets": [
    { "name": "t:sections.image-with-text.presets.name" }
  ]
}
{% endschema %}
