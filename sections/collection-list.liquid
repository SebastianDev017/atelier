{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign heading_size = section.settings.heading_size | default: 'lg'
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --grid-columns: {{ section.settings.columns_desktop }};
    --grid-columns-mobile: {{ section.settings.columns_mobile }};
  }
</style>

<div class="collection-list color-scheme--{{ scheme }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-header{% if section.settings.heading_alignment == 'center' %} section-header--center{% endif %}">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow" data-animate>{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <{{ heading_tag }} class="section-heading heading--{{ heading_size }}" data-animate data-animate-delay="2">{{ section.settings.heading | escape }}</{{ heading_tag }}>
      </div>
    {%- endif -%}

    <div class="product-grid">
      {%- for block in section.blocks -%}
        {%- assign collection = block.settings.collection -%}
        <a
          class="collection-card"
          href="{{ collection.url | default: '#' }}"
          {{ block.shopify_attributes }}
          data-animate-scale
          data-animate-delay="{{ forloop.index | modulo: 5 | plus: 1 }}"
        >
          <span class="media media--{{ section.settings.image_ratio }} collection-card__media">
            {%- if collection.featured_image -%}
              {{ collection.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '300, 450, 600, 800', sizes: '(min-width: 990px) 30vw, 50vw', alt: collection.title | escape }}
            {%- elsif collection.products.first.featured_image -%}
              {{ collection.products.first.featured_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '300, 450, 600, 800', sizes: '(min-width: 990px) 30vw, 50vw', alt: '' }}
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag: 'placeholder' }}
            {%- endif -%}
          </span>
          <span class="collection-card__info">
            <span class="collection-card__title h5">{{ collection.title | default: 'Collection' | escape }}</span>
            {%- if section.settings.show_product_count and collection != blank -%}
              <span class="caption">{{ 'collections.product_count' | t: count: collection.products_count }}</span>
            {%- endif -%}
          </span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .collection-list { padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing)); }
  .collection-card { display: flex; flex-direction: column; gap: var(--space-3); }
  .collection-card__media { overflow: hidden; }
  .collection-card__media img { transition: transform var(--duration-slower) var(--ease-editorial); width: 100%; height: 100%; object-fit: cover; }
  .collection-card:hover .collection-card__media img { transform: scale(1.04); }
  .collection-card__info { display: flex; flex-direction: column; gap: 2px; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.collection-list.name",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "t:sections.collection-list.settings.eyebrow.label" },
    { "type": "text", "id": "heading", "label": "t:sections.collection-list.settings.heading.label", "default": "Shop by collection" },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.collection-list.settings.heading_tag.label",
      "info": "t:sections.collection-list.settings.heading_tag.info",
      "options": [
        { "value": "h1", "label": "t:sections.collection-list.settings.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.collection-list.settings.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.collection-list.settings.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.collection-list.settings.heading_tag.options__4.label" },
        { "value": "p", "label": "t:sections.collection-list.settings.heading_tag.options__5.label" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.collection-list.settings.heading_size.label",
      "info": "t:sections.collection-list.settings.heading_size.info",
      "options": [
        { "value": "display", "label": "t:sections.collection-list.settings.heading_size.options__1.label" },
        { "value": "xl", "label": "t:sections.collection-list.settings.heading_size.options__2.label" },
        { "value": "lg", "label": "t:sections.collection-list.settings.heading_size.options__3.label" },
        { "value": "md", "label": "t:sections.collection-list.settings.heading_size.options__4.label" },
        { "value": "sm", "label": "t:sections.collection-list.settings.heading_size.options__5.label" },
        { "value": "xs", "label": "t:sections.collection-list.settings.heading_size.options__6.label" },
        { "value": "body", "label": "t:sections.collection-list.settings.heading_size.options__7.label" }
      ],
      "default": "lg"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:sections.collection-list.settings.heading_alignment.label",
      "options": [
        { "value": "left", "label": "t:sections.collection-list.settings.heading_alignment.options__1.label" },
        { "value": "center", "label": "t:sections.collection-list.settings.heading_alignment.options__2.label" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.collection-list.settings.image_ratio.label",
      "options": [
        { "value": "square", "label": "t:sections.collection-list.settings.image_ratio.options__1.label" },
        { "value": "portrait", "label": "t:sections.collection-list.settings.image_ratio.options__2.label" },
        { "value": "landscape", "label": "t:sections.collection-list.settings.image_ratio.options__3.label" }
      ],
      "default": "portrait"
    },
    { "type": "checkbox", "id": "show_product_count", "label": "t:sections.collection-list.settings.show_product_count.label", "default": false },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "t:sections.collection-list.settings.columns_desktop.label",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:sections.collection-list.settings.columns_mobile.label",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.collection-list.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.collection-list.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.collection-list.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.collection-list.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.collection-list.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.collection-list.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.collection-list.settings.padding_top.label", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.collection-list.settings.padding_bottom.label", "default": 80 }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "t:sections.collection-list.blocks.collection.name",
      "settings": [
        { "type": "collection", "id": "collection", "label": "t:sections.collection-list.blocks.collection.settings.collection.label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection-list.presets.name",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
