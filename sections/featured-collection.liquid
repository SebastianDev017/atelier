{%- comment -%}
  Featured collection grid. Renders a section header plus a responsive
  product grid sourced from the chosen collection. Falls back to onboarding
  placeholders so the editor preview looks complete before a collection is set.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign collection = section.settings.collection
  assign limit = section.settings.products_to_show

  assign has_products = false
  if collection != blank and collection.products_count > 0
    assign has_products = true
  endif

  assign view_all_class = 'link-underline'
  case section.settings.view_all_style
    when 'solid'
      assign view_all_class = 'btn'
    when 'outline'
      assign view_all_class = 'btn btn--outline'
  endcase

  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign heading_size = section.settings.heading_size | default: 'lg'
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --grid-columns: {{ section.settings.columns_desktop }};
    --grid-columns-mobile: {{ section.settings.columns_mobile }};
  }
</style>

<div class="featured-collection color-scheme--{{ scheme }}">
  <span class="edition-number" aria-hidden="true">002</span>
  <div class="featured-collection__inner page-width">
    {%- if section.settings.eyebrow != blank or section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="section-header section-header--center">
        {%- if section.settings.eyebrow != blank -%}
          <p class="eyebrow" data-animate>{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <{{ heading_tag }} class="section-heading heading--{{ heading_size }}" data-animate>{{ section.settings.title | escape }}</{{ heading_tag }}>
        {%- endif -%}
        {%- if section.settings.subtitle != blank -%}
          <p class="caption" data-animate data-animate-delay="2">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if has_products -%}
      <div class="product-grid">
        {%- for product in collection.products limit: limit -%}
          <div data-animate data-animate-delay="{{ forloop.index | modulo: 5 | plus: 1 }}">
            {% render 'product-card', product: product, show_vendor: section.settings.show_vendor, heading_tag: 'h3', quick_add_style: section.settings.quick_add_style %}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="product-grid">
        {%- for i in (1..limit) -%}
          <div data-animate data-animate-delay="{{ forloop.index | modulo: 5 | plus: 1 }}">
            <div class="featured-collection__placeholder">
              <span class="media media--product placeholder">
                {{- 'product-1' | placeholder_svg_tag: 'placeholder' -}}
              </span>
              <div class="featured-collection__placeholder-info">
                <span class="featured-collection__placeholder-line"></span>
                <span class="featured-collection__placeholder-line featured-collection__placeholder-line--short"></span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_view_all and has_products and collection.url != blank and section.settings.view_all_label != blank -%}
      <div class="featured-collection__view-all" data-animate>
        <a class="{{ view_all_class }}" href="{{ collection.url }}">
          {{- section.settings.view_all_label | escape -}}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .featured-collection {
    position: relative;
    padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing));
  }
  .featured-collection__inner {
    display: flex;
    flex-direction: column;
  }
  .featured-collection__view-all {
    display: flex;
    justify-content: center;
    margin-top: var(--space-10);
  }
  .featured-collection__placeholder {
    display: flex;
    flex-direction: column;
  }
  .featured-collection__placeholder-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }
  .featured-collection__placeholder-line {
    display: block;
    height: var(--text-base);
    width: 70%;
    background-color: var(--color-border);
  }
  .featured-collection__placeholder-line--short {
    width: 35%;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.featured-collection.name",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.featured-collection.settings.eyebrow.label",
      "info": "t:sections.featured-collection.settings.eyebrow.info"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.featured-collection.settings.title.label",
      "default": "Featured"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.featured-collection.settings.heading_tag.label",
      "info": "t:sections.featured-collection.settings.heading_tag.info",
      "options": [
        { "value": "h1", "label": "t:sections.featured-collection.settings.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.featured-collection.settings.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.featured-collection.settings.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.featured-collection.settings.heading_tag.options__4.label" },
        { "value": "p", "label": "t:sections.featured-collection.settings.heading_tag.options__5.label" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.featured-collection.settings.heading_size.label",
      "info": "t:sections.featured-collection.settings.heading_size.info",
      "options": [
        { "value": "display", "label": "t:sections.featured-collection.settings.heading_size.options__1.label" },
        { "value": "xl", "label": "t:sections.featured-collection.settings.heading_size.options__2.label" },
        { "value": "lg", "label": "t:sections.featured-collection.settings.heading_size.options__3.label" },
        { "value": "md", "label": "t:sections.featured-collection.settings.heading_size.options__4.label" },
        { "value": "sm", "label": "t:sections.featured-collection.settings.heading_size.options__5.label" },
        { "value": "xs", "label": "t:sections.featured-collection.settings.heading_size.options__6.label" },
        { "value": "body", "label": "t:sections.featured-collection.settings.heading_size.options__7.label" }
      ],
      "default": "lg"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.featured-collection.settings.subtitle.label"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured-collection.settings.collection.label"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "t:sections.featured-collection.settings.products_to_show.label",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "t:sections.featured-collection.settings.columns_desktop.label",
      "options": [
        { "value": "2", "label": "t:sections.featured-collection.settings.columns_desktop.options__1.label" },
        { "value": "3", "label": "t:sections.featured-collection.settings.columns_desktop.options__2.label" },
        { "value": "4", "label": "t:sections.featured-collection.settings.columns_desktop.options__3.label" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:sections.featured-collection.settings.columns_mobile.label",
      "options": [
        { "value": "1", "label": "t:sections.featured-collection.settings.columns_mobile.options__1.label" },
        { "value": "2", "label": "t:sections.featured-collection.settings.columns_mobile.options__2.label" }
      ],
      "default": "2"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.featured-collection.settings.show_vendor.label",
      "default": false
    },
    {
      "type": "select",
      "id": "quick_add_style",
      "label": "t:sections.featured-collection.settings.quick_add_style.label",
      "options": [
        { "value": "hover", "label": "t:sections.featured-collection.settings.quick_add_style.options__1.label" },
        { "value": "always", "label": "t:sections.featured-collection.settings.quick_add_style.options__2.label" }
      ],
      "default": "hover"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "t:sections.featured-collection.settings.show_view_all.label",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "t:sections.featured-collection.settings.view_all_label.label",
      "default": "View all"
    },
    {
      "type": "select",
      "id": "view_all_style",
      "label": "t:sections.featured-collection.settings.view_all_style.label",
      "options": [
        { "value": "solid", "label": "t:sections.featured-collection.settings.view_all_style.options__1.label" },
        { "value": "outline", "label": "t:sections.featured-collection.settings.view_all_style.options__2.label" },
        { "value": "link", "label": "t:sections.featured-collection.settings.view_all_style.options__3.label" }
      ],
      "default": "link"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.featured-collection.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.featured-collection.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.featured-collection.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.featured-collection.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.featured-collection.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.featured-collection.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.featured-collection.settings.padding_top.label",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.featured-collection.settings.padding_bottom.label",
      "default": 80
    }
  ],
  "presets": [
    { "name": "t:sections.featured-collection.presets.name" }
  ]
}
{% endschema %}
