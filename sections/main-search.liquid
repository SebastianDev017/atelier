{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign per_page = section.settings.products_per_page
  assign heading_tag = section.settings.heading_tag | default: 'h1'
  assign heading_size = section.settings.heading_size | default: 'lg'
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --grid-columns: {{ section.settings.columns_desktop }};
    --grid-columns-mobile: 2;
  }
</style>

<div class="search-page color-scheme--{{ scheme }}">
  <div class="page-width">
    <header class="search-page__head" data-animate>
      <{{ heading_tag }} class="search-page__title section-heading heading--{{ heading_size }}">{{ 'search.title' | t }}</{{ heading_tag }}>
      <div class="search-page__search">{% render 'predictive-search', id: 'main' %}</div>
    </header>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p class="search-page__count caption" data-animate>{{ 'search.results_with_count' | t: count: search.results_count, terms: search.terms }}</p>

        {%- paginate search.results by per_page -%}
          <div class="collection__layout">
            {%- if search.filters.size > 0 -%}
              <aside class="collection__sidebar">
                <details class="collection__facets" open>
                  <summary class="collection__facets-toggle btn btn--outline btn--small">
                    {% render 'icon', name: 'filter' %}
                    <span>{{ 'collections.filter_and_sort' | t }}</span>
                  </summary>
                  {% render 'facets', results: search, context: 'search', enable_sorting: false %}
                </details>
              </aside>
            {%- endif -%}

            <div class="collection__results">
              <div class="product-grid" data-product-grid>
                {%- for item in search.results -%}
                  <div data-animate data-animate-delay="{{ forloop.index | modulo: 5 | plus: 1 }}">
                    {%- case item.object_type -%}
                      {%- when 'product' -%}
                        {% render 'product-card', product: item, index: forloop.index, quick_add_style: section.settings.quick_add_style %}
                      {%- when 'article' -%}
                        <a class="search-result" href="{{ item.url }}">
                          <span class="media media--landscape">
                            {%- if item.image -%}
                              {{ item.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300, 450, 600', sizes: '(min-width: 750px) 25vw, 50vw', alt: item.image.alt | default: item.title | escape }}
                            {%- else -%}
                              {{ 'image' | placeholder_svg_tag: 'placeholder' }}
                            {%- endif -%}
                          </span>
                          <span class="search-result__type eyebrow">{{ 'search.articles' | t }}</span>
                          <span class="search-result__title">{{ item.title | escape }}</span>
                        </a>
                      {%- when 'page' -%}
                        <a class="search-result search-result--text" href="{{ item.url }}">
                          <span class="search-result__type eyebrow">{{ 'search.pages' | t }}</span>
                          <span class="search-result__title h5">{{ item.title | escape }}</span>
                        </a>
                    {%- endcase -%}
                  </div>
                {%- endfor -%}
              </div>
              {% render 'pagination', paginate: paginate %}
            </div>
          </div>
        {%- endpaginate -%}
      {%- else -%}
        <div class="search-page__empty" data-animate>
          <p class="lead">{{ 'search.no_results_html' | t: terms: search.terms }}</p>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .search-page { padding-block: var(--pt, var(--space-12)) var(--pb, var(--space-24)); }
  .search-page__head { max-width: 40rem; margin-bottom: var(--space-10); display: flex; flex-direction: column; gap: var(--space-5); }
  .search-page__count { padding-bottom: var(--space-6); border-bottom: 1px solid var(--color-border); margin-bottom: var(--space-8); }
  .search-page__empty { padding-block: var(--space-16); }
  .search-result { display: flex; flex-direction: column; gap: var(--space-2); }
  .search-result .media { margin-bottom: var(--space-2); }
  .search-result__type { color: var(--color-muted); }
  .search-result--text { padding: var(--space-6); border: 1px solid var(--color-border); min-height: 9rem; justify-content: center; }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.main-search.name",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.main-search.settings.heading_tag.label",
      "info": "t:sections.main-search.settings.heading_tag.info",
      "options": [
        { "value": "h1", "label": "t:sections.main-search.settings.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.main-search.settings.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.main-search.settings.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.main-search.settings.heading_tag.options__4.label" },
        { "value": "p", "label": "t:sections.main-search.settings.heading_tag.options__5.label" }
      ],
      "default": "h1"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.main-search.settings.heading_size.label",
      "info": "t:sections.main-search.settings.heading_size.info",
      "options": [
        { "value": "display", "label": "t:sections.main-search.settings.heading_size.options__1.label" },
        { "value": "xl", "label": "t:sections.main-search.settings.heading_size.options__2.label" },
        { "value": "lg", "label": "t:sections.main-search.settings.heading_size.options__3.label" },
        { "value": "md", "label": "t:sections.main-search.settings.heading_size.options__4.label" },
        { "value": "sm", "label": "t:sections.main-search.settings.heading_size.options__5.label" },
        { "value": "xs", "label": "t:sections.main-search.settings.heading_size.options__6.label" },
        { "value": "body", "label": "t:sections.main-search.settings.heading_size.options__7.label" }
      ],
      "default": "lg"
    },
    { "type": "range", "id": "products_per_page", "min": 8, "max": 36, "step": 4, "label": "t:sections.main-search.settings.products_per_page.label", "default": 16 },
    {
      "type": "select",
      "id": "quick_add_style",
      "label": "t:sections.main-search.settings.quick_add_style.label",
      "options": [
        { "value": "hover", "label": "t:sections.main-search.settings.quick_add_style.options__1.label" },
        { "value": "always", "label": "t:sections.main-search.settings.quick_add_style.options__2.label" }
      ],
      "default": "hover"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "t:sections.main-search.settings.columns_desktop.label",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.main-search.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.main-search.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.main-search.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.main-search.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.main-search.settings.color_scheme.options__4.label" }
      ],
      "default": "cream"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.main-search.settings.padding_top.label", "default": 48 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.main-search.settings.padding_bottom.label", "default": 96 }
  ]
}
{% endschema %}
