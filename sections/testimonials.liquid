{%- comment -%}
  Testimonials carousel. Crossfade slides, accessible controls, optional
  imagery. Mirrors rich-text.liquid: inline <style> carries instance values
  only, color-scheme--* wrapper paints the background, {% stylesheet %} holds
  all component CSS with NO Liquid, blocks carry {{ block.shopify_attributes }},
  scroll reveal via data-animate, schema ends with a "presets" array.
{%- endcomment -%}
{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'
  assign autoplay = section.settings.autoplay
  assign show_images = section.settings.show_images
  assign block_count = section.blocks.size
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
  }
</style>

<div class="testimonials color-scheme--{{ scheme }}">
  <div class="testimonials__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="testimonials__heading h3" data-animate>{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if block_count > 0 -%}
      <testimonial-carousel
        class="testimonials__carousel"
        data-autoplay="{{ autoplay }}"
        data-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
        role="region"
        aria-label="{{ section.settings.heading | default: 'Testimonials' | escape }}"
        aria-roledescription="carousel"
        tabindex="0"
        data-animate
        data-animate-delay="1"
      >
        <div class="testimonials__track" data-track>
          {%- for block in section.blocks -%}
            {%- liquid
              assign is_active = false
              if forloop.first
                assign is_active = true
              endif
              assign has_image = false
              if show_images and block.settings.image != blank
                assign has_image = true
              endif
            -%}
            <div
              class="testimonials__slide{% if is_active %} is-active{% endif %}"
              data-slide
              {% unless is_active %}aria-hidden="true"{% endunless %}
              {{ block.shopify_attributes }}
            >
              {%- if show_images -%}
                {%- if has_image -%}
                  {%- liquid
                    assign img = block.settings.image
                    assign img_alt = img.alt | default: block.settings.author | escape
                  -%}
                  <div class="testimonials__media media media--square">
                    {{
                      img
                      | image_url: width: 320
                      | image_tag:
                        loading: 'lazy',
                        widths: '160, 240, 320, 480',
                        sizes: '120px',
                        alt: img_alt
                    }}
                  </div>
                {%- else -%}
                  <div class="testimonials__media media media--square">
                    {{ 'collection-1' | placeholder_svg_tag: 'placeholder' }}
                  </div>
                {%- endif -%}
              {%- endif -%}

              <figure class="testimonials__figure">
                <blockquote class="testimonials__quote h4">{{ block.settings.quote | escape }}</blockquote>
                {%- if block.settings.author != blank or block.settings.role != blank -%}
                  <figcaption class="testimonials__attribution">
                    {%- if block.settings.author != blank -%}
                      <span class="testimonials__author label">{{ block.settings.author | escape }}</span>
                    {%- endif -%}
                    {%- if block.settings.role != blank -%}
                      <span class="testimonials__role caption">{{ block.settings.role | escape }}</span>
                    {%- endif -%}
                  </figcaption>
                {%- endif -%}
              </figure>
            </div>
          {%- endfor -%}
        </div>

        {%- if block_count > 1 -%}
          <div class="testimonials__controls">
            <button type="button" class="testimonials__arrow" data-prev aria-label="{{ 'accessibility.previous' | t }}">
              {%- render 'icon', name: 'arrow-left' -%}
            </button>

            <div class="testimonials__dots" role="group" aria-label="Choose testimonial" data-dots>
              {%- for block in section.blocks -%}
                <button
                  type="button"
                  class="testimonials__dot{% if forloop.first %} is-active{% endif %}"
                  data-dot
                  data-index="{{ forloop.index0 }}"
                  aria-label="{{ block.settings.author | default: section.settings.heading | default: 'Testimonials' | escape }}"
                  {% if forloop.first %}aria-current="true"{% endif %}
                ></button>
              {%- endfor -%}
            </div>

            <button type="button" class="testimonials__arrow" data-next aria-label="{{ 'accessibility.next' | t }}">
              {%- render 'icon', name: 'arrow-right' -%}
            </button>

            {%- if autoplay -%}
              <button
                type="button"
                class="testimonials__toggle"
                data-toggle
                aria-label="{{ section.settings.pause_label | default: 'Pause testimonials' | escape }}"
                aria-pressed="false"
              >
                <span class="testimonials__toggle-icon" data-toggle-play>{%- render 'icon', name: 'chevron-right' -%}</span>
              </button>
            {%- endif -%}
          </div>
        {%- endif -%}
      </testimonial-carousel>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .testimonials {
    padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing));
  }
  .testimonials__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-10);
    text-align: center;
  }
  .testimonials__heading {
    max-width: 24ch;
  }
  .testimonials__carousel {
    display: block;
    width: 100%;
    max-width: 52rem;
    outline: none;
  }
  .testimonials__track {
    position: relative;
    display: grid;
  }
  .testimonials__slide {
    grid-area: 1 / 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-6);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity var(--duration-slow) var(--ease-editorial),
                visibility var(--duration-slow) var(--ease-editorial);
  }
  .testimonials__slide.is-active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }
  .testimonials__media {
    width: var(--space-24);
    height: var(--space-24);
    flex: none;
    border-radius: var(--radius-none);
  }
  .testimonials__figure {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-5);
    margin: 0;
  }
  .testimonials__quote {
    max-width: 32ch;
    font-style: italic;
    line-height: var(--leading-snug);
    color: var(--color-text);
  }
  .testimonials__attribution {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }
  .testimonials__author {
    color: var(--color-text);
  }
  .testimonials__role {
    color: var(--color-muted);
  }
  .testimonials__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    margin-top: var(--space-10);
  }
  .testimonials__arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-text);
    transition: color var(--duration-fast) var(--ease-editorial),
                opacity var(--duration-fast) var(--ease-editorial);
  }
  .testimonials__arrow:hover {
    color: var(--color-accent-local);
  }
  .testimonials__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-1);
  }
  .testimonials__dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    background: transparent;
  }
  .testimonials__dot::before {
    content: "";
    display: block;
    width: var(--space-2);
    height: var(--space-2);
    border-radius: var(--radius-none);
    background-color: var(--color-border-strong);
    transition: background-color var(--duration-fast) var(--ease-editorial),
                transform var(--duration-fast) var(--ease-editorial);
  }
  .testimonials__dot:hover::before {
    background-color: var(--color-text);
  }
  .testimonials__dot.is-active::before {
    background-color: var(--color-text);
    transform: scale(1.4);
  }
  .testimonials__toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-text);
    transition: color var(--duration-fast) var(--ease-editorial);
  }
  .testimonials__toggle:hover {
    color: var(--color-accent-local);
  }
  .testimonials__toggle .icon {
    width: var(--space-4);
    height: var(--space-4);
  }
  .testimonials__toggle[aria-pressed="true"] .testimonials__toggle-icon {
    opacity: 0.55;
  }
{% endstylesheet %}

{% javascript %}
  class TestimonialCarousel extends HTMLElement {
    connectedCallback() {
      this.slides = Array.from(this.querySelectorAll('[data-slide]'));
      this.dots = Array.from(this.querySelectorAll('[data-dot]'));
      this.prevButton = this.querySelector('[data-prev]');
      this.nextButton = this.querySelector('[data-next]');
      this.toggleButton = this.querySelector('[data-toggle]');
      this.current = 0;
      this.interval = null;
      this.paused = false;
      this.touchStartX = 0;

      this.wantsAutoplay = this.dataset.autoplay === 'true';
      this.speed = parseInt(this.dataset.speed, 10) || 5000;

      this.reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      this.designMode = Boolean(window.Shopify && window.Shopify.designMode);

      this.onPrev = this.prev.bind(this);
      this.onNext = this.next.bind(this);
      this.onDotClick = this.handleDotClick.bind(this);
      this.onKeydown = this.handleKeydown.bind(this);
      this.onTouchStart = this.handleTouchStart.bind(this);
      this.onTouchEnd = this.handleTouchEnd.bind(this);
      this.onToggle = this.handleToggle.bind(this);
      this.onEnter = this.handleEnter.bind(this);
      this.onLeave = this.handleLeave.bind(this);

      if (this.prevButton) this.prevButton.addEventListener('click', this.onPrev);
      if (this.nextButton) this.nextButton.addEventListener('click', this.onNext);
      this.dots.forEach((dot) => dot.addEventListener('click', this.onDotClick));
      this.addEventListener('keydown', this.onKeydown);
      this.addEventListener('touchstart', this.onTouchStart, { passive: true });
      this.addEventListener('touchend', this.onTouchEnd, { passive: true });

      if (this.toggleButton) {
        this.toggleButton.addEventListener('click', this.onToggle);
      }

      if (this.canAutoplay()) {
        this.addEventListener('mouseenter', this.onEnter);
        this.addEventListener('mouseleave', this.onLeave);
        this.addEventListener('focusin', this.onEnter);
        this.addEventListener('focusout', this.onLeave);
        this.startAutoplay();
      }
    }

    disconnectedCallback() {
      this.stopAutoplay();
      if (this.prevButton) this.prevButton.removeEventListener('click', this.onPrev);
      if (this.nextButton) this.nextButton.removeEventListener('click', this.onNext);
      this.dots.forEach((dot) => dot.removeEventListener('click', this.onDotClick));
      this.removeEventListener('keydown', this.onKeydown);
      this.removeEventListener('touchstart', this.onTouchStart);
      this.removeEventListener('touchend', this.onTouchEnd);
      if (this.toggleButton) this.toggleButton.removeEventListener('click', this.onToggle);
      this.removeEventListener('mouseenter', this.onEnter);
      this.removeEventListener('mouseleave', this.onLeave);
      this.removeEventListener('focusin', this.onEnter);
      this.removeEventListener('focusout', this.onLeave);
    }

    canAutoplay() {
      return this.wantsAutoplay && this.slides.length > 1 && !this.designMode && !this.reducedMotion;
    }

    goTo(index) {
      const count = this.slides.length;
      if (count === 0) return;
      const next = (index + count) % count;
      this.current = next;

      this.slides.forEach((slide, i) => {
        const active = i === next;
        slide.classList.toggle('is-active', active);
        if (active) {
          slide.removeAttribute('aria-hidden');
        } else {
          slide.setAttribute('aria-hidden', 'true');
        }
      });

      this.dots.forEach((dot, i) => {
        const active = i === next;
        dot.classList.toggle('is-active', active);
        if (active) {
          dot.setAttribute('aria-current', 'true');
        } else {
          dot.removeAttribute('aria-current');
        }
      });
    }

    next() {
      this.goTo(this.current + 1);
    }

    prev() {
      this.goTo(this.current - 1);
    }

    handleDotClick(event) {
      const index = parseInt(event.currentTarget.dataset.index, 10);
      if (!Number.isNaN(index)) this.goTo(index);
    }

    handleKeydown(event) {
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        this.prev();
      } else if (event.key === 'ArrowRight') {
        event.preventDefault();
        this.next();
      }
    }

    handleTouchStart(event) {
      this.touchStartX = event.changedTouches[0].clientX;
    }

    handleTouchEnd(event) {
      const delta = event.changedTouches[0].clientX - this.touchStartX;
      if (Math.abs(delta) > 40) {
        if (delta < 0) {
          this.next();
        } else {
          this.prev();
        }
      }
    }

    handleToggle() {
      this.paused = !this.paused;
      if (this.paused) {
        this.stopAutoplay();
        this.toggleButton.setAttribute('aria-pressed', 'true');
      } else {
        this.startAutoplay();
        this.toggleButton.setAttribute('aria-pressed', 'false');
      }
    }

    handleEnter() {
      this.stopAutoplay();
    }

    handleLeave() {
      if (!this.paused) this.startAutoplay();
    }

    startAutoplay() {
      if (this.paused) return;
      if (!this.canAutoplay() || this.interval) return;
      this.interval = window.setInterval(() => this.next(), this.speed);
    }

    stopAutoplay() {
      if (this.interval) {
        window.clearInterval(this.interval);
        this.interval = null;
      }
    }

    scrollToBlock(block) {
      const target = block && (block.querySelector ? block.querySelector('[data-slide]') : null);
      const slide = target || block;
      const index = this.slides.indexOf(slide);
      if (index !== -1) {
        this.stopAutoplay();
        this.goTo(index);
      }
    }
  }

  if (!customElements.get('testimonial-carousel')) {
    customElements.define('testimonial-carousel', TestimonialCarousel);
  }
{% endjavascript %}

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What people say"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 8,
      "step": 1,
      "unit": "s",
      "label": "Seconds between slides",
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "show_images",
      "label": "Show images",
      "default": true
    },
    {
      "type": "text",
      "id": "pause_label",
      "label": "Pause button label",
      "info": "Accessible label for the play and pause toggle.",
      "default": "Pause testimonials"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "cream", "label": "Cream" },
        { "value": "parchment", "label": "Parchment" },
        { "value": "linen", "label": "Linen" },
        { "value": "white", "label": "White" },
        { "value": "invert", "label": "Inverted" }
      ],
      "default": "cream"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "A beautifully considered piece that anchors the whole room."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Customer name"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Role or location"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
