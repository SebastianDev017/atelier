{%- liquid
  assign scheme = section.settings.color_scheme | default: 'cream'

  assign cols = 3
  case section.settings.layout
    when 'grid-2col'
      assign cols = 2
    when 'grid-3col'
      assign cols = 3
    when 'grid-4col'
      assign cols = 4
  endcase

  assign ratio = section.settings.image_ratio | default: 'square'
  assign show_captions = section.settings.show_captions
  assign caption_below = false
  if section.settings.caption_position == 'below'
    assign caption_below = true
  endif

  assign desktop_vw = 100 | divided_by: cols
  assign sizes = '(min-width: 990px) ' | append: desktop_vw | append: 'vw, (min-width: 750px) 33vw, 50vw'
  assign heading_tag = section.settings.heading_tag | default: 'h2'
  assign heading_size = section.settings.heading_size | default: 'lg'
-%}

<style>
  #shopify-section-{{ section.id }} {
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --gallery-columns: {{ cols }};
    --gallery-scrim: color-mix(in srgb, var(--color-black) 55%, transparent);
  }
</style>

<div class="gallery color-scheme--{{ scheme }}">
  <div class="gallery__inner page-width">
    {%- if section.settings.heading != blank -%}
      <{{ heading_tag }} class="gallery__heading section-heading heading--{{ heading_size }}" data-animate>{{ section.settings.heading | escape }}</{{ heading_tag }}>
    {%- endif -%}

    <div class="gallery__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign image = block.settings.image
          assign caption = block.settings.caption
          assign url = block.settings.url
          assign img_alt = caption | default: section.settings.heading | escape
          assign delay = forloop.index | modulo: 5 | plus: 1
        -%}
        <div
          class="gallery__item"
          data-animate-scale
          data-animate-delay="{{ delay }}"
          {{ block.shopify_attributes }}
        >
          <figure class="gallery__figure">
            {%- if url != blank -%}
              <a class="gallery__link" href="{{ url }}">
            {%- endif -%}

            <span class="media media--{{ ratio }} gallery__media">
              {%- if image != blank -%}
                {{
                  image
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    widths: '300, 450, 600, 800, 1000, 1200',
                    sizes: sizes,
                    alt: img_alt,
                    class: 'gallery__image'
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder gallery__placeholder' }}
              {%- endif -%}

              {%- if show_captions and caption_below == false and caption != blank -%}
                <span class="gallery__overlay" aria-hidden="true">
                  <span class="gallery__overlay-text caption">{{ caption | escape }}</span>
                </span>
              {%- endif -%}
            </span>

            {%- if url != blank -%}
              </a>
            {%- endif -%}

            {%- if show_captions and caption != blank -%}
              {%- if caption_below -%}
                <figcaption class="gallery__caption caption">{{ caption | escape }}</figcaption>
              {%- else -%}
                <figcaption class="visually-hidden">{{ caption | escape }}</figcaption>
              {%- endif -%}
            {%- endif -%}
          </figure>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .gallery { padding-block: var(--pt, var(--section-spacing)) var(--pb, var(--section-spacing)); }
  .gallery__inner { display: flex; flex-direction: column; gap: var(--space-10); }
  .gallery__heading { max-width: 30ch; }

  .gallery__grid {
    display: grid;
    grid-template-columns: repeat(var(--gallery-columns, 3), minmax(0, 1fr));
    gap: var(--grid-gutter);
  }

  .gallery__item { display: block; }
  .gallery__figure { display: flex; flex-direction: column; gap: var(--space-3); margin: 0; }
  .gallery__link { display: block; }

  .gallery__media { overflow: hidden; }
  .gallery__image,
  .gallery__placeholder {
    transition: transform var(--duration-slower) var(--ease-editorial);
  }
  .gallery__link:hover .gallery__image,
  .gallery__item:hover .gallery__image,
  .gallery__link:focus-visible .gallery__image,
  .gallery__item:hover .gallery__placeholder {
    transform: scale(1.05);
  }

  .gallery__overlay {
    position: absolute;
    inset: 0;
    z-index: var(--z-raised);
    display: flex;
    align-items: flex-end;
    padding: var(--space-4);
    background: linear-gradient(to top, var(--gallery-scrim), transparent 60%);
    opacity: 0;
    transition: opacity var(--duration-slow) var(--ease-editorial);
  }
  .gallery__item:hover .gallery__overlay,
  .gallery__link:focus-visible .gallery__overlay { opacity: 1; }

  .gallery__overlay-text { color: var(--color-overlay-text); }

  .gallery__caption { color: var(--color-muted); }

  @media (max-width: 749px) {
    .gallery__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.gallery.name",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "t:sections.gallery.settings.heading.label", "default": "Gallery" },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "t:sections.gallery.settings.heading_tag.label",
      "info": "t:sections.gallery.settings.heading_tag.info",
      "options": [
        { "value": "h1", "label": "t:sections.gallery.settings.heading_tag.options__1.label" },
        { "value": "h2", "label": "t:sections.gallery.settings.heading_tag.options__2.label" },
        { "value": "h3", "label": "t:sections.gallery.settings.heading_tag.options__3.label" },
        { "value": "h4", "label": "t:sections.gallery.settings.heading_tag.options__4.label" },
        { "value": "p", "label": "t:sections.gallery.settings.heading_tag.options__5.label" }
      ],
      "default": "h2"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.gallery.settings.heading_size.label",
      "info": "t:sections.gallery.settings.heading_size.info",
      "options": [
        { "value": "display", "label": "t:sections.gallery.settings.heading_size.options__1.label" },
        { "value": "xl", "label": "t:sections.gallery.settings.heading_size.options__2.label" },
        { "value": "lg", "label": "t:sections.gallery.settings.heading_size.options__3.label" },
        { "value": "md", "label": "t:sections.gallery.settings.heading_size.options__4.label" },
        { "value": "sm", "label": "t:sections.gallery.settings.heading_size.options__5.label" },
        { "value": "xs", "label": "t:sections.gallery.settings.heading_size.options__6.label" },
        { "value": "body", "label": "t:sections.gallery.settings.heading_size.options__7.label" }
      ],
      "default": "lg"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.gallery.settings.layout.label",
      "options": [
        { "value": "grid-2col", "label": "t:sections.gallery.settings.layout.options__1.label" },
        { "value": "grid-3col", "label": "t:sections.gallery.settings.layout.options__2.label" },
        { "value": "grid-4col", "label": "t:sections.gallery.settings.layout.options__3.label" }
      ],
      "default": "grid-3col"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "t:sections.gallery.settings.image_ratio.label",
      "options": [
        { "value": "square", "label": "t:sections.gallery.settings.image_ratio.options__1.label" },
        { "value": "portrait", "label": "t:sections.gallery.settings.image_ratio.options__2.label" },
        { "value": "landscape", "label": "t:sections.gallery.settings.image_ratio.options__3.label" }
      ],
      "default": "square"
    },
    { "type": "checkbox", "id": "show_captions", "label": "t:sections.gallery.settings.show_captions.label", "default": false },
    {
      "type": "select",
      "id": "caption_position",
      "label": "t:sections.gallery.settings.caption_position.label",
      "options": [
        { "value": "hover", "label": "t:sections.gallery.settings.caption_position.options__1.label" },
        { "value": "below", "label": "t:sections.gallery.settings.caption_position.options__2.label" }
      ],
      "default": "below"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "t:sections.gallery.settings.color_scheme.label",
      "options": [
        { "value": "cream", "label": "t:sections.gallery.settings.color_scheme.options__1.label" },
        { "value": "parchment", "label": "t:sections.gallery.settings.color_scheme.options__2.label" },
        { "value": "linen", "label": "t:sections.gallery.settings.color_scheme.options__3.label" },
        { "value": "white", "label": "t:sections.gallery.settings.color_scheme.options__4.label" },
        { "value": "invert", "label": "t:sections.gallery.settings.color_scheme.options__5.label" }
      ],
      "default": "cream"
    },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.gallery.settings.padding_top.label", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "t:sections.gallery.settings.padding_bottom.label", "default": 80 }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.gallery.blocks.image.name",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "t:sections.gallery.blocks.image.settings.image.label" },
        { "type": "text", "id": "caption", "label": "t:sections.gallery.blocks.image.settings.caption.label" },
        { "type": "url", "id": "url", "label": "t:sections.gallery.blocks.image.settings.url.label" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.gallery.presets.name",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
