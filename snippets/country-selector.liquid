{%- comment -%}
  Country/region + language selectors using the localization form.
  Each select carries its own value and auto-submits via <localization-form>.

  @param {boolean} show_country
  @param {boolean} show_language
  @param {string} id - unique suffix for label/select ids
{%- endcomment -%}
<div class="country-selector">
  {%- if show_country and localization.available_countries.size > 1 -%}
    <localization-form class="country-selector__form">
      {%- form 'localization' -%}
        <input type="hidden" name="locale_code" value="{{ localization.language.iso_code }}">
        <label class="visually-hidden" for="Country-{{ id }}">{{ 'localization.country_label' | t }}</label>
        <div class="select country-selector__select">
          <select name="country_code" id="Country-{{ id }}">
            {%- for country in localization.available_countries -%}
              <option value="{{ country.iso_code }}"{% if country.iso_code == localization.country.iso_code %} selected{% endif %}>
                {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
              </option>
            {%- endfor -%}
          </select>
          {% render 'icon', name: 'chevron-down' %}
        </div>
        <noscript><button type="submit" class="btn btn--small">{{ 'localization.update' | t }}</button></noscript>
      {%- endform -%}
    </localization-form>
  {%- endif -%}

  {%- if show_language and localization.available_languages.size > 1 -%}
    <localization-form class="country-selector__form">
      {%- form 'localization' -%}
        <input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">
        <label class="visually-hidden" for="Language-{{ id }}">{{ 'localization.language_label' | t }}</label>
        <div class="select country-selector__select">
          <select name="locale_code" id="Language-{{ id }}">
            {%- for language in localization.available_languages -%}
              <option value="{{ language.iso_code }}"{% if language.iso_code == localization.language.iso_code %} selected{% endif %}>
                {{ language.endonym_name | capitalize }}
              </option>
            {%- endfor -%}
          </select>
          {% render 'icon', name: 'chevron-down' %}
        </div>
        <noscript><button type="submit" class="btn btn--small">{{ 'localization.update' | t }}</button></noscript>
      {%- endform -%}
    </localization-form>
  {%- endif -%}
</div>

{% stylesheet %}
  .country-selector { display: flex; align-items: center; gap: var(--space-4); flex-wrap: wrap; }
  .country-selector__form { display: inline-flex; }
  .country-selector__select { display: inline-flex; align-items: center; }
  .country-selector__select select {
    min-height: 44px;
    padding: 0.4em 2em 0.4em 0.5em;
    border: 0;
    background: transparent;
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: inherit;
    cursor: pointer;
  }
  .country-selector__select .icon { width: 0.9rem; right: 0.4em; }
{% endstylesheet %}
