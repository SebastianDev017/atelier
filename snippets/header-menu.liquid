{%- comment -%}
  Renders the sidebar navigation as an index. Each top-level menu
  item becomes an uppercase category label;
  its child links list vertically beneath it (always visible — no
  disclosure). Flat menus simply render as a list of links.
  The active link carries aria-current="page".

  @param {object} menu - the link_list to render
  @param {string} section_id - reserved for unique ids
{%- endcomment -%}
<ul class="sidebar-nav__list">
  {%- for link in menu.links -%}
    <li class="sidebar-nav__group">
      <a
        class="nav-link"
        href="{{ link.url }}"
        {% if link.current %}aria-current="page"{% endif %}
      >
        <span class="nav-link__text">{{ link.title | escape }}</span>
      </a>
      {%- if link.links.size > 0 -%}
        <ul class="sidebar-nav__sub">
          {%- for child in link.links -%}
            <li>
              <a
                class="sidebar-nav__sublink"
                href="{{ child.url }}"
                {% if child.current %}aria-current="page"{% endif %}
              >{{ child.title | escape }}</a>
              {%- if child.links.size > 0 -%}
                <ul class="sidebar-nav__sub sidebar-nav__sub--level-3">
                  {%- for grandchild in child.links -%}
                    <li>
                      <a
                        class="sidebar-nav__sublink sidebar-nav__sublink--level-3"
                        href="{{ grandchild.url }}"
                        {% if grandchild.current %}aria-current="page"{% endif %}
                      >{{ grandchild.title | escape }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </li>
  {%- endfor -%}
</ul>
