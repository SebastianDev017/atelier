{%- comment -%}
  Trust badges — four reassurance badges shown beneath the buy buttons on the
  product page. Editorial style: a small stroke icon + a mono uppercase label,
  laid out as a 2x2 grid. Labels are editable via the block; icons are fixed.

  @param {object} [block] - the main-product 'trust_badges' block (for labels + shopify_attributes)
{%- endcomment -%}
<ul class="trust-badges"{% if block %} {{ block.shopify_attributes }}{% endif %}>
  <li class="trust-badge">
    {% render 'icon', name: 'lock' %}
    <span class="trust-badge__label">{{ block.settings.badge_1 | default: 'Secure checkout' | escape }}</span>
  </li>
  <li class="trust-badge">
    {% render 'icon', name: 'truck' %}
    <span class="trust-badge__label">{{ block.settings.badge_2 | default: 'Free shipping over $150' | escape }}</span>
  </li>
  <li class="trust-badge">
    {% render 'icon', name: 'return' %}
    <span class="trust-badge__label">{{ block.settings.badge_3 | default: '30-day returns' | escape }}</span>
  </li>
  <li class="trust-badge">
    {% render 'icon', name: 'sparkle' %}
    <span class="trust-badge__label">{{ block.settings.badge_4 | default: 'Made to order' | escape }}</span>
  </li>
</ul>

{% stylesheet %}
  .trust-badges {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3) var(--space-4);
    margin-top: var(--space-5);
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
    list-style: none;
  }
  .trust-badge { display: flex; align-items: center; gap: var(--space-3); }
  .trust-badge .icon { width: 1.15rem; height: 1.15rem; flex: none; color: var(--color-muted); }
  .trust-badge__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    line-height: 1.3;
    color: var(--color-muted);
  }
  @media (max-width: 480px) {
    .trust-badges { grid-template-columns: 1fr; }
  }
{% endstylesheet %}
