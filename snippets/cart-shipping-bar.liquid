{%- comment -%}
  Free-shipping progress bar. Shared by the cart drawer (cart-drawer-contents)
  and the cart page (main-cart). Gated on the cart_show_free_shipping_bar and
  cart_free_shipping_threshold theme settings. The remaining amount is formatted
  to currency BEFORE interpolation so | money applies to the value, not to the
  whole translated sentence.
{%- endcomment -%}
{%- if settings.cart_show_free_shipping_bar and settings.cart_free_shipping_threshold > 0 -%}
  {%- liquid
    assign threshold_cents = settings.cart_free_shipping_threshold | times: 100
    assign remaining = threshold_cents | minus: cart.total_price
    assign pct = cart.total_price | times: 100.0 | divided_by: threshold_cents
    if pct > 100
      assign pct = 100
    endif
    assign remaining_money = remaining | money
  -%}
  <div class="cart-shipping" style="--cart-progress: {{ pct }}%;">
    <p class="cart-shipping__label caption" aria-live="polite">
      {%- if remaining > 0 -%}
        {{ 'cart.free_shipping_progress_html' | t: remaining: remaining_money }}
      {%- else -%}
        {{ 'cart.free_shipping_reached' | t }}
      {%- endif -%}
    </p>
    <div class="cart-shipping__track"><span class="cart-shipping__fill"></span></div>
  </div>
{%- endif -%}

{% stylesheet %}
  .cart-shipping__label { margin: 0; }
  .cart-shipping__track {
    height: 2px;
    margin-top: var(--space-2);
    background-color: var(--color-border);
    overflow: hidden;
  }
  .cart-shipping__fill {
    display: block;
    height: 100%;
    width: var(--cart-progress, 0%);
    background-color: var(--color-text);
    transition: width var(--duration-slow) var(--ease-editorial);
  }
{% endstylesheet %}
