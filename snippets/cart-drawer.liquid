{%- comment -%}
  Cart drawer shell. Rendered once globally in theme.liquid (drawer mode).
  The inner [data-cart-contents] is swapped after AJAX cart updates by
  <cart-drawer> in cart.js.
{%- endcomment -%}
<cart-drawer class="cart-drawer" data-cart-drawer aria-hidden="true">
  <div class="cart-drawer__overlay overlay" data-drawer-overlay tabindex="-1"></div>
  <div class="cart-drawer__panel color-scheme--cream" role="dialog" aria-modal="true" aria-label="{{ 'cart.title' | t }}">
    <div class="cart-drawer__head">
      <h2 class="cart-drawer__title h5">{{ 'cart.title' | t }}</h2>
      <button type="button" class="header__icon-btn" data-drawer-close aria-label="{{ 'accessibility.close_cart' | t }}">
        {% render 'icon', name: 'close' %}
      </button>
    </div>
    {% render 'cart-drawer-contents' %}
  </div>
</cart-drawer>

{% stylesheet %}
  .cart-drawer {
    position: fixed;
    inset: 0;
    z-index: var(--z-drawer);
    visibility: hidden;
    pointer-events: none;
  }
  .cart-drawer.is-open { visibility: visible; pointer-events: auto; }
  /* Overlay and panel are siblings inside .cart-drawer. The overlay inherits
     z-index:var(--z-overlay) from .overlay, which would paint ABOVE the panel
     and swallow its clicks — so pin the stack explicitly: overlay below, panel
     above. This is what makes the panel's buttons clickable. */
  .cart-drawer__overlay { position: absolute; z-index: 1; overscroll-behavior: none; }
  .cart-drawer.is-open .cart-drawer__overlay { opacity: 1; visibility: visible; }

  .cart-drawer__panel {
    position: absolute;
    top: 0; right: 0; bottom: 0;
    z-index: 2;
    width: min(92vw, 28rem);
    display: flex;
    flex-direction: column;
    /* Hardcoded cream so the panel is always solid even if a color setting resolves nil. */
    background-color: #FAF7F2;
    color: var(--color-text);
    transform: translateX(100%);
    transition: transform var(--duration-base) var(--ease-editorial);
  }
  .cart-drawer.is-open .cart-drawer__panel { transform: translateX(0); }

  .cart-drawer__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-5) var(--space-6);
    border-bottom: 1px solid var(--color-border);
    flex: none;
  }

  .cart-drawer__contents { display: flex; flex-direction: column; flex: 1; min-height: 0; }
  .cart-drawer__items {
    flex: 1 1 auto;
    /* min-height:0 lets this flex child shrink below its content height so it
       actually scrolls when the cart (plus the bundle strip + footer) overflows. */
    min-height: 0;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    /* Stop the scroll from chaining to the page (body) at the list's top/bottom. */
    overscroll-behavior: contain;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding: var(--space-6);
    margin: 0;
  }

  /* Bundle suggestions strip — flex:none so it sits between the scrollable items
     and the footer without stealing scroll height. Card styles live in base.css. */
  .cart-bundle { flex: none; padding: var(--space-5) var(--space-6); border-top: 1px solid var(--color-border); }
  .cart-bundle__heading { font-family: var(--font-mono); font-size: 0.6875rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--color-muted); margin: 0 0 var(--space-3); }
  .cart-bundle__track { display: flex; gap: var(--space-3); overflow-x: auto; scrollbar-width: none; }
  .cart-bundle__track::-webkit-scrollbar { display: none; }

  /* Busy state during a line-item update (cart.js toggles .is-loading on <cart-drawer>).
     0.55 keeps the cream ground reading solid; subtotal/footer stay legible. */
  .cart-drawer.is-loading .cart-drawer__items { opacity: 0.55; pointer-events: none; transition: opacity var(--duration-fast) var(--ease-editorial); }

  /* Free-shipping bar visuals live in snippets/cart-shipping-bar.liquid; the drawer only positions it. */
  .cart-drawer__contents .cart-shipping { padding: var(--space-4) var(--space-6) 0; }

  .cart-drawer__footer { flex: none; padding: var(--space-6); border-top: 1px solid var(--color-border); display: flex; flex-direction: column; gap: var(--space-4); }
  .cart-drawer__note summary { min-height: 44px; display: inline-flex; align-items: center; }
  .cart-drawer__subtotal { display: flex; align-items: baseline; justify-content: space-between; font-size: var(--text-md); }
  .cart-drawer__subtotal-value { font-family: var(--font-heading); font-size: var(--text-xl); }
  .cart-drawer__taxes { margin-top: calc(var(--space-2) * -1); }
  .cart-drawer__actions { display: flex; flex-direction: column; gap: var(--space-3); align-items: center; }

  .cart-drawer__empty { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: var(--space-4); text-align: center; padding: var(--space-16) var(--space-6); flex: 1; }
{% endstylesheet %}
