{%- comment -%}
  Renders an inline SVG icon. All icons share a 24x24 viewBox and inherit
  currentColor / stroke from the .icon class in base.css.

  @param {string} name - icon id (see the case statement below)
  Usage: {% render 'icon', name: 'cart' %}
{%- endcomment -%}
{%- liquid
  assign name = name | default: 'arrow-right'
-%}
<svg class="icon icon--{{ name }}" viewBox="0 0 24 24" role="presentation" focusable="false" aria-hidden="true">
  {%- case name -%}
    {%- when 'cart' -%}
      <path d="M3 4h2l2.4 12.2a1 1 0 0 0 1 .8h8.8a1 1 0 0 0 1-.8L21 8H6"/><circle cx="9" cy="20" r="1"/><circle cx="18" cy="20" r="1"/>
    {%- when 'account' -%}
      <circle cx="12" cy="8" r="4"/><path d="M5 21c0-3.9 3.1-7 7-7s7 3.1 7 7"/>
    {%- when 'search' -%}
      <circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/>
    {%- when 'menu' -%}
      <path d="M3 6h18M3 12h18M3 18h18"/>
    {%- when 'close' -%}
      <path d="M6 6l12 12M18 6 6 18"/>
    {%- when 'chevron-down' -%}
      <path d="m6 9 6 6 6-6"/>
    {%- when 'chevron-left' -%}
      <path d="m15 6-6 6 6 6"/>
    {%- when 'chevron-right' -%}
      <path d="m9 6 6 6-6 6"/>
    {%- when 'arrow-right' -%}
      <path d="M4 12h16M14 6l6 6-6 6"/>
    {%- when 'arrow-left' -%}
      <path d="M20 12H4M10 6l-6 6 6 6"/>
    {%- when 'minus' -%}
      <path d="M5 12h14"/>
    {%- when 'plus' -%}
      <path d="M12 5v14M5 12h14"/>
    {%- when 'check' -%}
      <path d="m5 12 4.5 4.5L19 7"/>
    {%- when 'star' -%}
      <path class="icon--filled" d="m12 3 2.6 5.6 6 .7-4.4 4.2 1.2 6L12 16.8 6.6 19.5l1.2-6L3.4 9.3l6-.7Z" fill="currentColor" stroke="none"/>
    {%- when 'star-outline' -%}
      <path d="m12 3 2.6 5.6 6 .7-4.4 4.2 1.2 6L12 16.8 6.6 19.5l1.2-6L3.4 9.3l6-.7Z"/>
    {%- when 'truck' -%}
      <path d="M3 6h11v9H3zM14 9h4l3 3v3h-7z"/><circle cx="7" cy="18" r="1.5"/><circle cx="17" cy="18" r="1.5"/>
    {%- when 'globe' -%}
      <circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.4 3.8 5.6 3.8 9S14.5 18.6 12 21c-2.5-2.4-3.8-5.6-3.8-9S9.5 5.4 12 3Z"/>
    {%- when 'instagram' -%}
      <rect x="3" y="3" width="18" height="18" rx="4"/><circle cx="12" cy="12" r="4"/><circle cx="17" cy="7" r="1" fill="currentColor" stroke="none"/>
    {%- when 'facebook' -%}
      <path d="M14 8h2V5h-2c-2 0-3 1.3-3 3v2H9v3h2v6h3v-6h2.2l.8-3H14V8.2c0-.1.1-.2.3-.2Z" fill="currentColor" stroke="none"/>
    {%- when 'pinterest' -%}
      <path d="M12 3a9 9 0 0 0-3.3 17.4c-.1-.8-.2-2 0-2.9l1.2-5s-.3-.6-.3-1.5c0-1.4.8-2.4 1.8-2.4.9 0 1.3.6 1.3 1.4 0 .9-.6 2.2-.9 3.4-.2.9.5 1.7 1.4 1.7 1.7 0 2.9-2.2 2.9-4.7 0-2-1.3-3.4-3.7-3.4-2.7 0-4.3 2-4.3 4 0 .8.3 1.4.7 1.8.2.2.2.3.1.5l-.2.9c0 .3-.2.4-.5.2-1.2-.5-1.8-1.9-1.8-3.5 0-2.6 2.2-5.7 6.5-5.7 3.5 0 5.7 2.5 5.7 5.2 0 3.5-2 6.2-4.9 6.2-1 0-1.9-.5-2.2-1.1l-.6 2.4c-.2.8-.7 1.6-1 2.2A9 9 0 1 0 12 3Z" fill="currentColor" stroke="none"/>
    {%- when 'tiktok' -%}
      <path d="M14 4c.3 2 1.7 3.6 3.7 3.9v2.6c-1.3 0-2.6-.4-3.7-1.1v5.3a4.9 4.9 0 1 1-4.9-4.9c.3 0 .5 0 .8.1v2.7a2.2 2.2 0 1 0 1.6 2.1V4Z" fill="currentColor" stroke="none"/>
    {%- when 'youtube' -%}
      <rect x="3" y="6" width="18" height="12" rx="3"/><path d="m10 9 5 3-5 3z" fill="currentColor" stroke="none"/>
    {%- when 'share' -%}
      <circle cx="6" cy="12" r="2"/><circle cx="18" cy="6" r="2"/><circle cx="18" cy="18" r="2"/><path d="m8 11 8-4M8 13l8 4"/>
    {%- when 'filter' -%}
      <path d="M3 6h18M6 12h12M10 18h4"/>
    {%- when 'pause' -%}
      <path d="M8 5v14M16 5v14"/>
    {%- when 'play' -%}
      <path d="M7 4v16l13-8z" fill="currentColor" stroke="none"/>
    {%- else -%}
      <path d="M4 12h16M14 6l6 6-6 6"/>
  {%- endcase -%}
</svg>
